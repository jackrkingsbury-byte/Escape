<section class="section" id="faq">
  <div class="wrap">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="reveal">{{ section.settings.heading }}</h2>
    <div class="faq">
      {%- for block in section.blocks -%}
        <div class="faq__item" {{ block.shopify_attributes }}>
          <button class="faq__q" type="button">{{ block.settings.q }}</button>
          <div class="faq__a"><p>{{ block.settings.a }}</p></div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Good things to know" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions, answered." }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Q&A",
      "settings": [
        { "type": "text", "id": "q", "label": "Question", "default": "How do I get access after paying?" },
        { "type": "textarea", "id": "a", "label": "Answer", "default": "Right after checkout you'll get an email with your unique access code and a link. Enter the code on the ESCAPE site and you're in — usually within a minute." }
      ]
    }
  ],
  "presets": [{
    "name": "FAQ",
    "blocks": [
      { "type": "qa", "settings": { "q": "How do I get access after paying?", "a": "Right after checkout you'll get an email with a unique access code and a link. Enter the code on the ESCAPE site and you're in — usually within a minute." } },
      { "type": "qa", "settings": { "q": "Is this a subscription?", "a": "No. It's a once-off payment. Inner Circle is lifetime access including all future updates." } },
      { "type": "qa", "settings": { "q": "How old do I need to be?", "a": "ESCAPE is built for 16–25 year olds, but anyone who wants to break autopilot will get value." } },
      { "type": "qa", "settings": { "q": "What if it's not for me?", "a": "You're covered by a 7-day money-back guarantee. Email us within a week and we'll refund you in full." } },
      { "type": "qa", "settings": { "q": "What's Grade Forge?", "a": "It's our study/grades system, bundled free inside the Inner Circle plan to upgrade your school life alongside everything else." } }
    ]
  }]
}
{% endschema %}
