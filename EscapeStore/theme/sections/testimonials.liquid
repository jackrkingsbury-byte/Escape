<section class="section" id="proof">
  <div class="wrap">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="reveal">{{ section.settings.heading }}</h2>
    <div class="quotes">
      {%- for block in section.blocks -%}
        <figure class="quote reveal" {{ block.shopify_attributes }}>
          <div class="stars">{% for i in (1..5) %}★{% endfor %}</div>
          <p>"{{ block.settings.quote }}"</p>
          <figcaption class="quote__who">
            <span class="quote__av">{{ block.settings.name | slice: 0 }}</span>
            <span><b>{{ block.settings.name }}</b><span>{{ block.settings.meta }}</span></span>
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "No overnight miracles. Just louder lives." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What members say after 30 days." }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "I stopped doomscrolling and actually built a morning I'm proud of." },
        { "type": "text", "id": "name", "label": "Name", "default": "Thando" },
        { "type": "text", "id": "meta", "label": "Meta", "default": "19 · 41-day streak" }
      ]
    }
  ],
  "presets": [{
    "name": "Testimonials",
    "blocks": [
      { "type": "quote", "settings": { "quote": "I stopped doomscrolling and built a morning I'm actually proud of.", "name": "Thando", "meta": "19 · 41-day streak" } },
      { "type": "quote", "settings": { "quote": "The dares are tiny but they add up. I'm a different person 2 months in.", "name": "Megan", "meta": "22 · finished the 90 days" } },
      { "type": "quote", "settings": { "quote": "Bought it on a whim. Best R299 I've spent on myself, no contest.", "name": "Sipho", "meta": "20 · PRO member" } }
    ]
  }]
}
{% endschema %}
