<section class="section" id="stack">
  <div class="wrap center">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="reveal">{{ section.settings.heading }}</h2>
    <p class="lead mx-auto reveal" style="text-align:center">{{ section.settings.subheading }}</p>

    <div class="stack reveal">
      {%- assign total = 0 -%}
      {%- for block in section.blocks -%}
        {%- assign total = total | plus: block.settings.value -%}
        <div class="stack__row" {{ block.shopify_attributes }}>
          <span>{{ block.settings.item }}</span>
          <span>R{{ block.settings.value }}</span>
        </div>
      {%- endfor -%}
      <div class="stack__row stack__row--total">
        <span>Total value</span>
        <span>R{{ total }}</span>
      </div>
    </div>

    <div class="stack__price reveal">
      <span class="was">R{{ section.settings.was_price }}</span>
      <span class="now">R{{ section.settings.now_price }}</span>
      <p>{{ section.settings.note }}</p>
      <a class="btn btn--gold btn--lg" href="{{ section.settings.cta_url | default: '#pricing' }}">{{ section.settings.cta_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bonus stack",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stack it up" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Then look at the price again." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Bought separately, here's what all of this is actually worth." },
    { "type": "number", "id": "was_price", "label": "Crossed-out price (R)", "default": 1295 },
    { "type": "number", "id": "now_price", "label": "Real price (R)", "default": 299 },
    { "type": "text", "id": "note", "label": "Note under price", "default": "One payment. Lifetime updates. 7-day money-back guarantee." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Claim this price" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Value row",
      "settings": [
        { "type": "text", "id": "item", "label": "Item", "default": "The ESCAPE core course" },
        { "type": "number", "id": "value", "label": "Value (R)", "default": 499 }
      ]
    }
  ],
  "presets": [{
    "name": "Bonus stack",
    "blocks": [
      { "type": "row", "settings": { "item": "The ESCAPE 90-day core course", "value": 499 } },
      { "type": "row", "settings": { "item": "5 Bonus Kits (confidence, focus, money…)", "value": 350 } },
      { "type": "row", "settings": { "item": "Habit tracker + weekly review system", "value": 199 } },
      { "type": "row", "settings": { "item": "Letter to Future You + notebook", "value": 99 } },
      { "type": "row", "settings": { "item": "Certificate of completion", "value": 49 } },
      { "type": "row", "settings": { "item": "Lifetime updates + future drops", "value": 99 } }
    ]
  }]
}
{% endschema %}
