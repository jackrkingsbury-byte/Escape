# --- Public (safe to expose to the browser) ---
# WhatsApp number for the "Book a demo" click-to-chat link (digits only or +country).
NEXT_PUBLIC_WA_NUMBER=27000000000
NEXT_PUBLIC_CONTACT_EMAIL=hello@nevermiss.app

# Supabase (public keys — safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only secrets (NEVER commit real values) ---
# Supabase service role — bypasses RLS; used only by server webhooks/jobs.
SUPABASE_SERVICE_ROLE_KEY=

