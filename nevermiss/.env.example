# --- Public (safe to expose to the browser) ---
# WhatsApp number for the "Book a demo" click-to-chat link (digits only or +country).
NEXT_PUBLIC_WA_NUMBER=27000000000
NEXT_PUBLIC_CONTACT_EMAIL=hello@nevermiss.app

# Supabase (public keys — safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only secrets (NEVER commit real values) ---
# Supabase service role — bypasses RLS; used only by server webhooks/jobs.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI reply engine ---
# Anthropic API key (separate from Claude Pro). Required for the AI to reply.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-sonnet-5)
ANTHROPIC_MODEL=

# --- Twilio — WhatsApp, SMS & Voice ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# WhatsApp sender (sandbox or approved number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# SMS-capable Twilio number for missed-call text-back + SMS follow-up, e.g. +27...
TWILIO_SMS_FROM=
# Public base URL of the deployed app (used to verify Twilio webhooks)
APP_BASE_URL=https://escape-nevermiss3.vercel.app
#
# Twilio webhook URLs to configure:
#   Voice (missed-call):  {APP_BASE_URL}/api/voice/incoming
#   SMS follow-up:        {APP_BASE_URL}/api/sms/inbound
#   WhatsApp (optional):  {APP_BASE_URL}/api/whatsapp/inbound

# Added later:
# YOCO_SECRET_KEY=
