{% raw %}
<style>
  .ts{position:relative;padding:clamp(30px,5vw,52px) 0;background:#0a0812;border-top:1px solid rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.06)}
  .ts__wrap{max-width:1000px;margin:0 auto;padding:0 22px}
  .ts__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
  @media(max-width:760px){.ts__grid{grid-template-columns:repeat(2,1fr)}}
  .ts__item{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.08);border-radius:15px;padding:15px 16px;transition:transform .25s,border-color .25s}
  .ts__item:hover{transform:translateY(-3px);border-color:rgba(255,194,75,.3)}
  .ts__ic{flex:none;width:42px;height:42px;border-radius:12px;display:grid;place-items:center;font-size:1.3rem;background:linear-gradient(135deg,rgba(255,194,75,.16),rgba(124,92,255,.14));border:1px solid rgba(255,255,255,.08)}
  .ts__tt{font-weight:700;font-size:.92rem;color:#fff;margin:0;line-height:1.2}
  .ts__td{font-size:.74rem;color:#8b877f;margin:3px 0 0;line-height:1.3}
</style>
{% endraw %}
<section class="ts" id="trust">
  <div class="ts__wrap">
    <div class="ts__grid">
      {%- for block in section.blocks -%}
        <div class="ts__item reveal" {{ block.shopify_attributes }}>
          <span class="ts__ic">{{ block.settings.icon }}</span>
          <div><p class="ts__tt">{{ block.settings.title }}</p><p class="ts__td">{{ block.settings.text }}</p></div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Trust strip",
  "blocks": [
    { "type": "item", "name": "Trust item", "settings": [
      { "type": "text", "id": "icon", "label": "Icon (emoji)" },
      { "type": "text", "id": "title", "label": "Title" },
      { "type": "text", "id": "text", "label": "Text" }
    ]}
  ],
  "max_blocks": 4,
  "presets": [{
    "name": "Trust strip",
    "blocks": [
      { "type": "item", "settings": { "icon": "🔒", "title": "Secure checkout", "text": "Encrypted, handled by Shopify" }},
      { "type": "item", "settings": { "icon": "↩️", "title": "7-day guarantee", "text": "Don't feel it? Full refund" }},
      { "type": "item", "settings": { "icon": "⚡", "title": "Instant access", "text": "Straight to Day 1, no waiting" }},
      { "type": "item", "settings": { "icon": "✅", "title": "Once-off payment", "text": "No subscription, ever" }}
    ]
  }]
}
{% endschema %}
