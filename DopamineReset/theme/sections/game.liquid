{% raw %}
<style>
  .gm{position:relative;padding:clamp(56px,9vw,110px) 0;overflow:hidden;background:linear-gradient(180deg,#0c0a12,#140f1d)}
  .gm__wrap{max-width:860px;margin:0 auto;padding:0 22px;position:relative;z-index:1}
  .gm__eye{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.72rem;letter-spacing:.3em;text-transform:uppercase;color:#ffc24b;margin-bottom:12px;text-align:center}
  .gm h2{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:clamp(1.9rem,5vw,3.2rem);line-height:1.05;letter-spacing:-.01em;margin:0 0 10px;text-align:center;color:#fff}
  .gm__sub{color:#cfccc4;text-align:center;max-width:48ch;margin:0 auto 26px;line-height:1.55;font-size:clamp(1rem,2vw,1.15rem)}

  .gm__hud{position:sticky;top:10px;z-index:5;background:rgba(18,14,26,.92);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.1);border-radius:18px;padding:16px 18px;margin-bottom:22px;box-shadow:0 18px 40px rgba(0,0,0,.4)}
  .gm__hudtop{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:10px}
  .gm__lvl{display:flex;align-items:center;gap:10px}
  .gm__badge{width:46px;height:46px;border-radius:13px;display:grid;place-items:center;font-size:1.5rem;background:linear-gradient(135deg,#ff8a3d,#ffc24b);box-shadow:0 8px 20px rgba(255,138,61,.4);transition:transform .25s}
  .gm__badge.pop{transform:scale(1.25) rotate(-6deg)}
  .gm__lvlt b{display:block;font-family:var(--serif,'Fraunces',serif);font-size:1.15rem;color:#fff;line-height:1}
  .gm__lvlt span{font-size:.78rem;color:#8b877f}
  .gm__xp{text-align:right}.gm__xp b{font-family:var(--mono,monospace);font-size:1.3rem;color:#ffc24b}.gm__xp span{display:block;font-size:.72rem;color:#8b877f}
  .gm__bar{height:14px;border-radius:999px;background:#241d31;overflow:hidden;position:relative;border:1px solid rgba(255,255,255,.06)}
  .gm__bar i{position:absolute;inset:0;width:0;border-radius:999px;background:linear-gradient(90deg,#ffc24b,#ff5c8a,#7c5cff);background-size:200% 100%;animation:gmflow 3s linear infinite;transition:width .5s cubic-bezier(.2,.8,.2,1)}
  @keyframes gmflow{to{background-position:200% 0}}

  .gm__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:13px}
  .gm__card{position:relative;border-radius:18px;overflow:hidden;border:1px solid rgba(255,255,255,.1);background:#181222;padding:18px 16px;cursor:pointer;text-align:left;transition:transform .15s,border-color .2s;min-height:128px;display:flex;flex-direction:column;justify-content:space-between}
  .gm__card:active{transform:scale(.96)}
  .gm__card .cbg{position:absolute;inset:0;z-index:0;opacity:0;transition:opacity .3s}
  .gm__card>*{position:relative;z-index:1}
  .gm__card .e{font-size:2rem}
  .gm__card b{display:block;font-weight:700;color:#fff;font-size:.98rem;line-height:1.15;margin-top:8px}
  .gm__card .xp{font-family:var(--mono,monospace);font-size:.74rem;color:#ffc24b;margin-top:4px}
  .gm__card.done{border-color:rgba(90,212,138,.5)}
  .gm__card.done .cbg{opacity:.9}
  .gm__card.done b,.gm__card.done .xp{color:#fff}
  .gm__card.done::after{content:"✓";position:absolute;top:10px;right:12px;z-index:2;width:26px;height:26px;border-radius:50%;background:#5ad48a;color:#06270f;font-weight:800;display:grid;place-items:center;font-size:.9rem}

  .gm__foot{margin-top:24px;text-align:center}
  .gm__msg{min-height:24px;color:#ffd24b;font-weight:700;margin-bottom:14px;transition:opacity .2s}
  .gm__cta{display:inline-flex;align-items:center;gap:9px;font-weight:800;border-radius:999px;padding:17px 36px;font-size:1.08rem;background:linear-gradient(135deg,#ffc24b,#ff8a3d);color:#2a1400;box-shadow:0 16px 40px rgba(255,138,61,.4);transition:transform .15s}
  .gm__cta.hot{animation:gmpulse 1.3s ease-in-out infinite}
  @keyframes gmpulse{0%,100%{transform:scale(1)}50%{transform:scale(1.045)}}
  .gm__reset{display:block;margin:14px auto 0;color:#8b877f;font-size:.85rem;text-decoration:underline}
  .gm__note{color:#8b877f;font-size:.86rem;margin-top:10px}

  .gm__cf{position:fixed;left:0;top:0;width:100%;height:100%;pointer-events:none;z-index:60}
  .gm__cf span{position:absolute;top:-12px;width:9px;height:14px;border-radius:2px;animation:gmfall linear forwards}
  @keyframes gmfall{to{transform:translateY(105vh) rotate(540deg);opacity:.2}}
  @media (prefers-reduced-motion:reduce){.gm__bar i,.gm__cta.hot{animation:none}}
</style>

<section class="gm" id="game">
  <div class="orbs"><span class="orb orb--a" style="top:-40px;left:8%"></span><span class="orb orb--c" style="bottom:-50px;right:10%"></span></div>
  <div class="gm__wrap">
    <p class="gm__eye">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p class="gm__sub">{{ section.settings.sub }}</p>

    <div class="gm__hud">
      <div class="gm__hudtop">
        <div class="gm__lvl"><div class="gm__badge" id="gmBadge">🌱</div>
          <div class="gm__lvlt"><b id="gmLvlName">Level 1 · Asleep</b><span id="gmNext">Tap a habit to gain XP</span></div></div>
        <div class="gm__xp"><b id="gmXp">0</b><span>XP</span></div>
      </div>
      <div class="gm__bar"><i id="gmFill"></i></div>
    </div>

    <div class="gm__grid" id="gmGrid"></div>

    <div class="gm__foot">
      <div class="gm__msg" id="gmMsg">Every habit you'd beat = real XP your brain actually feels.</div>
      <a class="gm__cta" id="gmCta" href="{{ section.settings.cta_url | default: '#pricing' }}">{{ section.settings.cta_label }}</a>
      <a class="gm__reset" id="gmReset" href="#">↺ Reset</a>
      <p class="gm__note">{{ section.settings.note }}</p>
    </div>
  </div>
  <div class="gm__cf" id="gmCf"></div>
</section>

<script>
(function(){
  var grid=document.getElementById('gmGrid');if(!grid)return;
  var HABITS=[
    {e:'📵',t:'Quit the doomscroll',xp:25,g:'linear-gradient(135deg,#ff5c8a,#7c5cff)'},
    {e:'🌅',t:'Win your mornings',xp:20,g:'linear-gradient(135deg,#ff8a3d,#ffc24b)'},
    {e:'🎯',t:'Deep focus, 1 hour',xp:30,g:'linear-gradient(135deg,#2bd3c6,#4f8cff)'},
    {e:'🏃',t:'Move your body',xp:20,g:'linear-gradient(135deg,#5ad48a,#bfe65a)'},
    {e:'😴',t:'Real, deep sleep',xp:25,g:'linear-gradient(135deg,#7c5cff,#4f8cff)'},
    {e:'🤝',t:'One real connection',xp:25,g:'linear-gradient(135deg,#ff6b6b,#ff8a3d)'}
  ];
  var LEVELS=[
    {min:0,n:'Asleep',b:'🌱'},{min:25,n:'Waking up',b:'☕'},{min:55,n:'Clearing',b:'⚡'},
    {min:90,n:'Locked in',b:'🔥'},{min:120,n:'Glowing',b:'🌟'},{min:145,n:'Unstoppable',b:'💎'}
  ];
  var MAX=0;HABITS.forEach(function(h){MAX+=h.xp});
  var xp=0,done={};
  var fill=document.getElementById('gmFill'),xpEl=document.getElementById('gmXp'),badge=document.getElementById('gmBadge'),
      lvlName=document.getElementById('gmLvlName'),nextEl=document.getElementById('gmNext'),msg=document.getElementById('gmMsg'),
      cta=document.getElementById('gmCta'),cf=document.getElementById('gmCf');
  var MSGS=['Nice — that one alone changes your week.','+XP. Your brain just felt that.','Look at that bar move. 📈','This is the exact loop the reset builds.','Almost maxed — imagine this every day.'];

  grid.innerHTML=HABITS.map(function(h,i){return '<button class="gm__card" data-i="'+i+'"><div class="cbg" style="background:'+h.g+'"></div><div><span class="e">'+h.e+'</span><b>'+h.t+'</b></div><span class="xp">+'+h.xp+' XP</span></button>'}).join('');

  function lvlFor(x){var L=LEVELS[0],idx=0;for(var i=0;i<LEVELS.length;i++){if(x>=LEVELS[i].min){L=LEVELS[i];idx=i}}return {L:L,idx:idx}}
  function confetti(){var c=['#ffc24b','#ff5c8a','#7c5cff','#5ad48a','#2bd3c6'];var h='';for(var i=0;i<26;i++){h+='<span style="left:'+Math.random()*100+'%;background:'+c[i%5]+';animation-duration:'+(1.1+Math.random()*1.1)+'s;animation-delay:'+(Math.random()*.25)+'s"></span>'}cf.innerHTML=h;setTimeout(function(){cf.innerHTML=''},2600)}

  function render(burst){
    xpEl.textContent=xp;
    fill.style.width=Math.min(100,xp/MAX*100)+'%';
    var lf=lvlFor(xp);
    lvlName.textContent='Level '+(lf.idx+1)+' · '+lf.L.n;
    badge.textContent=lf.L.b;
    if(burst){badge.classList.add('pop');setTimeout(function(){badge.classList.remove('pop')},260)}
    var nl=LEVELS[lf.idx+1];
    nextEl.textContent=nl?((nl.min-xp)+' XP to Level '+(lf.idx+2)):'Max level — this is Day 7 you. 🎉';
    if(xp>=MAX){cta.textContent='Claim Level 6 — start the reset · R199';cta.classList.add('hot')}
    else if(xp>=55){cta.textContent='Lock in this feeling — R199';cta.classList.add('hot')}
    else{cta.classList.remove('hot')}
  }
  render(false);

  grid.addEventListener('click',function(e){
    var b=e.target.closest('[data-i]');if(!b)return;var i=+b.getAttribute('data-i');
    if(done[i]){done[i]=false;b.classList.remove('done');xp-=HABITS[i].xp;render(false);return}
    done[i]=true;b.classList.add('done');xp+=HABITS[i].xp;
    msg.textContent=MSGS[Math.floor(Math.random()*MSGS.length)];
    var before=lvlFor(xp-HABITS[i].xp).idx,after=lvlFor(xp).idx;
    render(true);
    if(after>before){confetti()}
    if(xp>=MAX){msg.textContent='That’s a full reset. Now make it real. 👇';confetti()}
  });
  document.getElementById('gmReset').addEventListener('click',function(e){e.preventDefault();xp=0;done={};[].slice.call(grid.querySelectorAll('.gm__card')).forEach(function(c){c.classList.remove('done')});msg.textContent='Round two — see how high you climb.';render(false)});
})();
</script>
{% endraw %}

{% schema %}
{
  "name": "XP Game",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Play it out" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tap what you'd quit. Watch yourself level up." },
    { "type": "textarea", "id": "sub", "label": "Sub", "default": "This is the exact dopamine loop the reset rebuilds — small wins, instant XP, real momentum. Try it." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Start my reset — R199" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "text", "id": "note", "label": "Note", "default": "7-day money-back guarantee · instant access" }
  ],
  "presets": [{ "name": "XP Game" }]
}
{% endschema %}
