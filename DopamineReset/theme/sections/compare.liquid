{% raw %}
<style>
  .cmp{padding:clamp(56px,9vw,110px) 0;position:relative;overflow:hidden;background:#0c0a12}
  .cmp__wrap{max-width:900px;margin:0 auto;padding:0 22px;position:relative;z-index:1}
  .cmp__eye{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.72rem;letter-spacing:.3em;text-transform:uppercase;color:#ffc24b;text-align:center;margin-bottom:12px}
  .cmp h2{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:clamp(1.9rem,5vw,3.2rem);line-height:1.05;text-align:center;margin:0 0 10px;color:#fff}
  .cmp__sub{color:#cfccc4;text-align:center;max-width:46ch;margin:0 auto 30px;line-height:1.55}
  .cmp__hl{background:linear-gradient(135deg,#ff5c8a,#7c5cff);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent}

  .cmp__box{position:relative;border-radius:22px;overflow:hidden;border:1px solid rgba(255,255,255,.12);aspect-ratio:16/11;touch-action:none;user-select:none;box-shadow:0 30px 70px rgba(0,0,0,.5)}
  .cmp__pane{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;padding:clamp(18px,5vw,46px);color:#fff}
  .cmp__after{background:radial-gradient(120% 120% at 80% 10%,#ff8a3d,transparent 55%),radial-gradient(120% 120% at 10% 100%,#7c5cff,transparent 55%),linear-gradient(135deg,#2a1640,#3a1f2e)}
  .cmp__before{background:linear-gradient(135deg,#1b1b22,#0e0e14);clip-path:inset(0 calc(100% - var(--pos,50%)) 0 0)}
  .cmp__tag{display:inline-flex;align-items:center;gap:7px;align-self:flex-start;font-family:var(--mono,monospace);font-size:.66rem;letter-spacing:.18em;text-transform:uppercase;padding:6px 12px;border-radius:999px;margin-bottom:14px}
  .cmp__before .cmp__tag{background:rgba(255,255,255,.08);color:#b8b4ad}
  .cmp__after .cmp__tag{background:rgba(255,255,255,.16);color:#fff}
  .cmp__face{font-size:clamp(2.4rem,8vw,4.2rem);line-height:1;margin-bottom:10px;filter:drop-shadow(0 8px 20px rgba(0,0,0,.4))}
  .cmp__h{font-family:var(--serif,'Fraunces',serif);font-size:clamp(1.2rem,3.4vw,1.9rem);font-weight:600;line-height:1.1;margin:0 0 16px;max-width:14ch}
  .cmp__before .cmp__h{color:#cfccc4}
  .cmp__rows{display:grid;gap:9px;max-width:280px}
  .cmp__row{font-size:.82rem}
  .cmp__row .lbl{display:flex;justify-content:space-between;margin-bottom:4px;color:rgba(255,255,255,.85)}
  .cmp__bar{height:8px;border-radius:999px;background:rgba(255,255,255,.12);overflow:hidden}
  .cmp__bar i{display:block;height:100%;border-radius:999px}
  .cmp__before .cmp__bar i{background:linear-gradient(90deg,#6a6a78,#4b4b5a)}
  .cmp__after .cmp__bar i{background:linear-gradient(90deg,#ffc24b,#ff5c8a)}
  .cmp__handle{position:absolute;top:0;bottom:0;left:var(--pos,50%);width:3px;background:linear-gradient(180deg,#ffc24b,#ff5c8a);transform:translateX(-50%);z-index:3;cursor:ew-resize}
  .cmp__grip{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:46px;height:46px;border-radius:50%;background:#fff;color:#2a1400;display:grid;place-items:center;font-weight:800;box-shadow:0 8px 24px rgba(0,0,0,.5)}
  .cmp__hint{text-align:center;color:#8b877f;font-size:.84rem;margin-top:14px}
  .cmp__cta{display:flex;justify-content:center;margin-top:26px}
  .cmp__btn{display:inline-flex;align-items:center;gap:8px;font-weight:800;border-radius:999px;padding:16px 34px;font-size:1.06rem;background:linear-gradient(135deg,#ffc24b,#ff8a3d);color:#2a1400;box-shadow:0 16px 40px rgba(255,138,61,.36)}
</style>

<section class="cmp" id="compare">
  <div class="cmp__wrap">
    <p class="cmp__eye">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p class="cmp__sub">{{ section.settings.sub }}</p>

    <div class="cmp__box" id="cmpBox" style="--pos:50%">
      <div class="cmp__pane cmp__after">
        <span class="cmp__tag">After the reset ☀️</span>
        <div class="cmp__face">😄</div>
        <h3 class="cmp__h">Clear, driven and actually present</h3>
        <div class="cmp__rows">
          <div class="cmp__row"><div class="lbl"><span>Focus</span><span>High</span></div><div class="cmp__bar"><i style="width:88%"></i></div></div>
          <div class="cmp__row"><div class="lbl"><span>Mood</span><span>Bright</span></div><div class="cmp__bar"><i style="width:84%"></i></div></div>
          <div class="cmp__row"><div class="lbl"><span>Energy</span><span>Charged</span></div><div class="cmp__bar"><i style="width:90%"></i></div></div>
          <div class="cmp__row"><div class="lbl"><span>Sleep</span><span>Deep</span></div><div class="cmp__bar"><i style="width:82%"></i></div></div>
        </div>
      </div>
      <div class="cmp__pane cmp__before">
        <span class="cmp__tag">Before · right now 🌫️</span>
        <div class="cmp__face">😵‍💫</div>
        <h3 class="cmp__h">Foggy, flat and always tired</h3>
        <div class="cmp__rows">
          <div class="cmp__row"><div class="lbl"><span>Focus</span><span>Scattered</span></div><div class="cmp__bar"><i style="width:24%"></i></div></div>
          <div class="cmp__row"><div class="lbl"><span>Mood</span><span>Flat</span></div><div class="cmp__bar"><i style="width:30%"></i></div></div>
          <div class="cmp__row"><div class="lbl"><span>Energy</span><span>Drained</span></div><div class="cmp__bar"><i style="width:22%"></i></div></div>
          <div class="cmp__row"><div class="lbl"><span>Sleep</span><span>Restless</span></div><div class="cmp__bar"><i style="width:28%"></i></div></div>
        </div>
      </div>
      <div class="cmp__handle" id="cmpHandle"><span class="cmp__grip">⇆</span></div>
    </div>
    <p class="cmp__hint">← Drag to see the difference 7 days makes →</p>
    <div class="cmp__cta"><a class="cmp__btn" href="{{ section.settings.cta_url | default: '#pricing' }}">{{ section.settings.cta_label }}</a></div>
  </div>
</section>

<script>
(function(){
  var box=document.getElementById('cmpBox'),handle=document.getElementById('cmpHandle');
  if(!box||!handle)return;
  var dragging=false;
  function setPos(clientX){var r=box.getBoundingClientRect();var p=(clientX-r.left)/r.width*100;p=p<4?4:p>96?96:p;box.style.setProperty('--pos',p+'%')}
  function down(e){dragging=true;move(e)}
  function move(e){if(!dragging)return;var x=e.touches?e.touches[0].clientX:e.clientX;setPos(x);if(e.cancelable)e.preventDefault()}
  function up(){dragging=false}
  handle.addEventListener('mousedown',down);box.addEventListener('mousedown',down);
  window.addEventListener('mousemove',move);window.addEventListener('mouseup',up);
  handle.addEventListener('touchstart',down,{passive:false});box.addEventListener('touchstart',down,{passive:false});
  window.addEventListener('touchmove',move,{passive:false});window.addEventListener('touchend',up);
  // gentle auto-demo nudge on first view
  if('IntersectionObserver' in window){var seen=false;var io=new IntersectionObserver(function(es){es.forEach(function(en){if(en.isIntersecting&&!seen){seen=true;var p=50,d=-1,n=0;var t=setInterval(function(){p+=d*2;if(p<=34){d=1}if(p>=66){d=-1}box.style.setProperty('--pos',p+'%');n++;if(n>34){clearInterval(t);box.style.setProperty('--pos','50%')}},28)}})},{threshold:.5});io.observe(box)}
})();
</script>
{% endraw %}

{% schema %}
{
  "name": "Before / After",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "See the difference" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Same you. One week apart." },
    { "type": "textarea", "id": "sub", "label": "Sub", "default": "Drag the slider. This is what reclaiming your dopamine actually feels like — across your focus, mood, energy and sleep." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "I want the after — R199" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "presets": [{ "name": "Before / After" }]
}
{% endschema %}
