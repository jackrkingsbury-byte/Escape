{% raw %}
<style>
  .su{position:relative;padding:clamp(56px,8vw,96px) 0;background:#0a0812}
  .su__wrap{max-width:1000px;margin:0 auto;padding:0 22px}
  .su__head{text-align:center;max-width:640px;margin:0 auto clamp(30px,4vw,46px)}
  .su__eye{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.72rem;letter-spacing:.3em;text-transform:uppercase;color:#ffc24b;margin:0 0 12px}
  .su__title{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:clamp(1.7rem,4vw,2.7rem);line-height:1.08;color:#fff;margin:0}
  .su__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  @media(max-width:760px){.su__grid{grid-template-columns:1fr}}
  .su__card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:18px;padding:24px 22px;text-align:center;transition:transform .25s,border-color .25s}
  .su__card:hover{transform:translateY(-4px);border-color:rgba(255,194,75,.32)}
  .su__ic{width:54px;height:54px;margin:0 auto 14px;border-radius:15px;display:grid;place-items:center;font-size:1.6rem;background:linear-gradient(135deg,rgba(255,194,75,.16),rgba(124,92,255,.14));border:1px solid rgba(255,255,255,.08)}
  .su__ct{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:1.15rem;color:#fff;margin:0 0 7px}
  .su__cx{font-size:.94rem;line-height:1.5;color:#bdb9b1;margin:0}
  .su__cx a{color:#ffc24b;text-decoration:none;border-bottom:1px solid rgba(255,194,75,.4)}
  .su__cx a:hover{border-color:#ffc24b}
</style>
{% endraw %}
<section class="su" id="support">
  <div class="su__wrap">
    <div class="su__head reveal">
      <p class="su__eye">{{ section.settings.eyebrow }}</p>
      <h2 class="su__title">{{ section.settings.heading }}</h2>
    </div>
    <div class="su__grid">
      <div class="su__card reveal">
        <span class="su__ic">💬</span>
        <h3 class="su__ct">{{ section.settings.s1_title }}</h3>
        <p class="su__cx">
          {{ section.settings.s1_text }}
          {%- if section.settings.support_email != blank -%}<br><a href="mailto:{{ section.settings.support_email }}">{{ section.settings.support_email }}</a>{%- endif -%}
        </p>
      </div>
      <div class="su__card reveal">
        <span class="su__ic">🔐</span>
        <h3 class="su__ct">{{ section.settings.s2_title }}</h3>
        <p class="su__cx">{{ section.settings.s2_text }}</p>
      </div>
      <div class="su__card reveal">
        <span class="su__ic">↩️</span>
        <h3 class="su__ct">{{ section.settings.s3_title }}</h3>
        <p class="su__cx">{{ section.settings.s3_text }}</p>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Support & privacy",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "We've got your back" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real support, real privacy, zero risk" },
    { "type": "paragraph", "content": "Set your real support email below so buyers can reach you." },
    { "type": "text", "id": "s1_title", "label": "Card 1 title", "default": "Talk to a human" },
    { "type": "textarea", "id": "s1_text", "label": "Card 1 text", "default": "Stuck or unsure about anything? Email us and a real person replies — usually within a day." },
    { "type": "text", "id": "support_email", "label": "Support email", "default": "" },
    { "type": "text", "id": "s2_title", "label": "Card 2 title", "default": "Your data's safe" },
    { "type": "textarea", "id": "s2_text", "label": "Card 2 text", "default": "Checkout is encrypted and handled by Shopify. We never see your card details and we'll never sell your information." },
    { "type": "text", "id": "s3_title", "label": "Card 3 title", "default": "Nothing to lose" },
    { "type": "textarea", "id": "s3_text", "label": "Card 3 text", "default": "If the reset doesn't make your week better, the 7-day money-back guarantee has you covered. No forms, no hassle." }
  ],
  "presets": [{ "name": "Support & privacy" }]
}
{% endschema %}
