<section class="section cta-final">
  <div class="wrap">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="reveal">{{ section.settings.heading }}</h2>
    <p class="lead mx-auto reveal" style="text-align:center">{{ section.settings.subheading }}</p>
    <div class="reveal" style="margin-top:26px">
      <a class="btn btn--gold btn--lg" href="{{ section.settings.cta_url | default: '#pricing' }}">{{ section.settings.cta_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The turning point most people never find" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Most people scroll through life. ESCAPE members live it." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "90 days from now you'll either be someone you're proud of — or exactly where you are today. Pick." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Start your escape" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "presets": [{ "name": "Final CTA" }]
}
{% endschema %}
