{% raw %}
<style>
  .hiw{position:relative;padding:clamp(72px,11vw,128px) 0;background:radial-gradient(120% 80% at 80% 0%,#15101f 0%,#080d1c 60%);overflow:hidden}
  .hiw__glow{position:absolute;width:46vmax;height:46vmax;border-radius:50%;filter:blur(90px);opacity:.32;pointer-events:none}
  .hiw__glow.g1{background:radial-gradient(circle,#7c5cff,transparent 65%);top:-14vmax;left:-10vmax}
  .hiw__glow.g2{background:radial-gradient(circle,#7c5cff,transparent 65%);bottom:-16vmax;right:-8vmax}
  .hiw__wrap{position:relative;z-index:1;max-width:1000px;margin:0 auto;padding:0 22px}
  .hiw__head{text-align:center;max-width:760px;margin:0 auto clamp(46px,6vw,72px)}
  .hiw__eye{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.72rem;letter-spacing:.3em;text-transform:uppercase;color:#4de3ff;margin:0 0 14px}
  .hiw__title{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:clamp(2rem,5vw,3.3rem);line-height:1.05;letter-spacing:-.02em;color:#fff;margin:0 0 16px}
  .hiw__lead{color:#cfccc4;font-size:clamp(1rem,1.7vw,1.18rem);line-height:1.6;margin:0}

  .hiw__steps{position:relative;display:grid;gap:clamp(18px,2.4vw,26px)}
  .hiw__steps::before{content:"";position:absolute;left:31px;top:18px;bottom:18px;width:2px;background:linear-gradient(180deg,#4de3ff,#ff5c8a,#7c5cff,#2bd3c6);opacity:.5;border-radius:2px}
  @media(max-width:640px){.hiw__steps::before{left:23px}}

  .hiw__step{position:relative;display:grid;grid-template-columns:64px 1fr;gap:18px;align-items:start}
  @media(max-width:640px){.hiw__step{grid-template-columns:48px 1fr;gap:13px}}
  .hiw__num{position:relative;z-index:2;width:64px;height:64px;border-radius:50%;display:grid;place-items:center;font-family:var(--serif,'Fraunces',serif);font-weight:700;font-size:1.5rem;color:#1a1020;
    background:linear-gradient(135deg,#4de3ff,#7c5cff);box-shadow:0 10px 30px rgba(124,92,255,.4),inset 0 1px 0 rgba(255,255,255,.5)}
  @media(max-width:640px){.hiw__num{width:48px;height:48px;font-size:1.15rem}}
  .hiw__step:nth-child(2) .hiw__num{background:linear-gradient(135deg,#7c5cff,#ff5c8a);box-shadow:0 10px 30px rgba(255,92,138,.4),inset 0 1px 0 rgba(255,255,255,.5)}
  .hiw__step:nth-child(3) .hiw__num{background:linear-gradient(135deg,#ff5c8a,#7c5cff);box-shadow:0 10px 30px rgba(124,92,255,.4),inset 0 1px 0 rgba(255,255,255,.5);color:#fff}
  .hiw__step:nth-child(4) .hiw__num{background:linear-gradient(135deg,#7c5cff,#4f8cff);box-shadow:0 10px 30px rgba(79,140,255,.4),inset 0 1px 0 rgba(255,255,255,.5);color:#fff}
  .hiw__step:nth-child(5) .hiw__num{background:linear-gradient(135deg,#2bd3c6,#5ad48a);box-shadow:0 10px 30px rgba(43,211,198,.4),inset 0 1px 0 rgba(255,255,255,.5);color:#0a1f1c}

  .hiw__card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.09);border-radius:18px;padding:20px 22px;backdrop-filter:blur(8px);transition:transform .25s,border-color .25s,background .25s}
  .hiw__card:hover{transform:translateY(-3px);border-color:rgba(77,227,255,.35);background:rgba(255,255,255,.06)}
  .hiw__when{display:inline-block;font-family:var(--mono,'JetBrains Mono',monospace);font-size:.66rem;letter-spacing:.16em;text-transform:uppercase;color:#4de3ff;background:rgba(77,227,255,.1);border:1px solid rgba(77,227,255,.25);border-radius:999px;padding:4px 11px;margin-bottom:10px}
  .hiw__st{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:1.28rem;color:#fff;margin:0 0 7px;line-height:1.2}
  .hiw__sx{color:#bdb9b1;font-size:1rem;line-height:1.55;margin:0}

  .hiw__cta{text-align:center;margin-top:clamp(40px,5vw,60px)}
  .hiw__btnwrap{position:relative;display:inline-flex}
  .hiw__btnwrap::before{content:"";position:absolute;inset:-4px;border-radius:999px;background:linear-gradient(135deg,#4de3ff,#7c5cff);filter:blur(14px);opacity:.5;z-index:-1;animation:hiwglow 2.6s ease-in-out infinite}
  @keyframes hiwglow{0%,100%{opacity:.35;transform:scale(.97)}50%{opacity:.72;transform:scale(1.05)}}
  .hiw__btn{display:inline-flex;align-items:center;gap:8px;font-weight:800;border-radius:999px;padding:16px 34px;font-size:1.05rem;background:linear-gradient(135deg,#4de3ff,#7c5cff);color:#041420;box-shadow:0 16px 40px rgba(124,92,255,.36);transition:transform .15s}
  .hiw__btn:hover{transform:translateY(-2px)}
  .hiw__rea{margin:16px 0 0;color:#8b877f;font-size:.9rem}
  .hiw__rea b{color:#cfccc4}
  @media (prefers-reduced-motion:reduce){.hiw__btnwrap::before{animation:none}}
</style>
{% endraw %}

<section class="hiw" id="how">
  <span class="hiw__glow g1"></span><span class="hiw__glow g2"></span>
  <div class="hiw__wrap">
    <div class="hiw__head reveal">
      <p class="hiw__eye">{{ section.settings.eyebrow }}</p>
      <h2 class="hiw__title">{{ section.settings.heading }}</h2>
      <p class="hiw__lead">{{ section.settings.lead }}</p>
    </div>

    <div class="hiw__steps">
      {%- for block in section.blocks -%}
        <div class="hiw__step reveal" {{ block.shopify_attributes }}>
          <div class="hiw__num">{{ forloop.index }}</div>
          <div class="hiw__card">
            {%- if block.settings.when != blank -%}<span class="hiw__when">{{ block.settings.when }}</span>{%- endif -%}
            <h3 class="hiw__st">{{ block.settings.title }}</h3>
            <p class="hiw__sx">{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="hiw__cta reveal">
      <span class="hiw__btnwrap"><a class="hiw__btn" href="{{ section.settings.cta_url | default: '#pricing' }}">{{ section.settings.cta_label }}</a></span>
      <p class="hiw__rea">{{ section.settings.reassurance }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "From payment to feeling better" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How the reset actually works" },
    { "type": "textarea", "id": "lead", "label": "Lead", "default": "No app to download, no waiting, no guesswork. Here's exactly what happens from the moment you tap buy." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Start my reset — R199" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "text", "id": "reassurance", "label": "Reassurance line", "default": "One payment · instant access · 7-day money-back guarantee" }
  ],
  "blocks": [
    { "type": "step", "name": "Step", "settings": [
      { "type": "text", "id": "when", "label": "When (small label)" },
      { "type": "text", "id": "title", "label": "Title" },
      { "type": "textarea", "id": "text", "label": "Text" }
    ]}
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "How it works",
    "blocks": [
      { "type": "step", "settings": { "when": "Right now", "title": "Tap buy — pay once, securely", "text": "R199, one payment, through Shopify's secure checkout. No subscription, no card tricks, no shipping — it's instant digital access." }},
      { "type": "step", "settings": { "when": "10 seconds later", "title": "Land straight on Day 1", "text": "The second payment clears you're taken right into your member dashboard on Day 1. No email hunting, no access codes, no waiting around." }},
      { "type": "step", "settings": { "when": "Every day · 10 min", "title": "Do one simple daily action", "text": "Open the app, do that day's 10-minute action, tick it off. Stuck on a craving? The urge-surfing tools beat it in under 90 seconds." }},
      { "type": "step", "settings": { "when": "By about day 3", "title": "Feel the fog start to lift", "text": "Your streak builds, your focus sharpens, and small things start feeling good again. The tracker shows your mood and momentum climbing." }},
      { "type": "step", "settings": { "when": "Day 7 & beyond", "title": "Keep your tools for life", "text": "Finish the 7 days a different person — and keep lifetime access to every protocol, the tracker and all future updates to come back to whenever you need a reset." }}
    ]
  }]
}
{% endschema %}
