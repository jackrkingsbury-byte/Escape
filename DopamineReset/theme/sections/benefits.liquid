{%- liquid
  assign grads = "linear-gradient(135deg,#ff8a3d,#ffc24b)|linear-gradient(135deg,#ff5c8a,#7c5cff)|linear-gradient(135deg,#2bd3c6,#4f8cff)|linear-gradient(135deg,#5ad48a,#bfe65a)|linear-gradient(135deg,#7c5cff,#ff5c8a)|linear-gradient(135deg,#ffd24b,#ff6b6b)" | split: "|"
-%}
{% raw %}
<style>
  .bn{padding:clamp(56px,9vw,110px) 0;position:relative;overflow:hidden}
  .bn::before{content:"";position:absolute;inset:auto -10% -30% -10%;height:60%;z-index:0;pointer-events:none;
    background:radial-gradient(50% 60% at 30% 100%,rgba(255,92,138,.18),transparent 70%),radial-gradient(50% 60% at 80% 100%,rgba(124,92,255,.16),transparent 70%);filter:blur(10px)}
  .bn__wrap{max-width:1120px;margin:0 auto;padding:0 22px;position:relative;z-index:1}
  .bn__eye{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.72rem;letter-spacing:.3em;text-transform:uppercase;color:#ffc24b;margin-bottom:14px}
  .bn h2{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:clamp(1.9rem,4.6vw,3.2rem);line-height:1.04;letter-spacing:-.01em;margin:0 0 14px;max-width:18ch}
  .bn__lead{color:#b8b4ad;font-size:clamp(1.05rem,2vw,1.25rem);max-width:52ch;margin:0 0 8px;line-height:1.55}
  .bn__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;margin-top:40px}
  .bn__card{position:relative;border-radius:20px;overflow:hidden;min-height:230px;display:flex;flex-direction:column;
    justify-content:flex-end;padding:22px;border:1px solid rgba(255,255,255,.08);cursor:default;
    transition:transform .2s,box-shadow .2s}
  .bn__card:hover{transform:translateY(-6px);box-shadow:0 24px 50px rgba(0,0,0,.5)}
  .bn__bg{position:absolute;inset:0;z-index:0;opacity:.92}
  .bn__bg::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.05) 0%,rgba(8,6,12,.72) 100%)}
  .bn__emoji{position:absolute;top:18px;left:20px;z-index:1;font-size:2.7rem;filter:drop-shadow(0 3px 10px rgba(0,0,0,.4))}
  .bn__txt{position:relative;z-index:1}
  .bn__txt b{display:block;font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:1.3rem;color:#fff;line-height:1.1;margin-bottom:6px}
  .bn__txt span{color:rgba(255,255,255,.88);font-size:.95rem;line-height:1.45;display:block}
  .bn__strip{display:flex;flex-wrap:wrap;gap:10px;margin-top:34px}
  .bn__chip{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);
    border-radius:999px;padding:9px 16px;font-size:.9rem;color:#e8e6e0}
  .bn__chip b{color:#ffc24b}
  .bn__cta{margin-top:38px;display:flex;gap:14px;flex-wrap:wrap;align-items:center}
  .bn__btn{display:inline-flex;align-items:center;gap:8px;font-weight:800;border-radius:999px;padding:16px 32px;font-size:1.05rem;
    background:linear-gradient(135deg,#ffc24b,#ff8a3d);color:#2a1400;box-shadow:0 16px 40px rgba(255,138,61,.34);transition:transform .15s}
  .bn__btn:hover{transform:translateY(-2px)}
  .bn__note{color:#7e7a73;font-size:.92rem}
</style>
{% endraw %}

<section class="bn" id="why">
  <div class="bn__wrap">
    <p class="bn__eye">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p class="bn__lead">{{ section.settings.lead }}</p>

    <div class="bn__grid">
      {%- for block in section.blocks -%}
        {%- assign g = grads[forloop.index0 | modulo: 6] -%}
        <article class="bn__card" {{ block.shopify_attributes }}>
          <div class="bn__bg" style="background:{{ g }}"></div>
          <span class="bn__emoji">{{ block.settings.emoji }}</span>
          <div class="bn__txt"><b>{{ block.settings.title }}</b><span>{{ block.settings.text }}</span></div>
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.show_strip -%}
    <div class="bn__strip">
      <span class="bn__chip">⏱️ <b>~10 min</b> a day</span>
      <span class="bn__chip">📅 <b>7 days</b> to feel it</span>
      <span class="bn__chip">🛡️ <b>7-day</b> money-back</span>
      <span class="bn__chip">⚡ <b>Instant</b> access</span>
    </div>
    {%- endif -%}

    <div class="bn__cta">
      <a class="bn__btn" href="{{ section.settings.cta_url | default: '#pricing' }}">{{ section.settings.cta_label }}</a>
      <span class="bn__note">{{ section.settings.note }}</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Benefits / Why",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why this matters" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "This isn't about your phone. It's about your life." },
    { "type": "textarea", "id": "lead", "label": "Lead", "default": "Cheap dopamine quietly steals your focus, your mood and your drive. Get it back, and everything downstream gets better — school, money, health, the people you love." },
    { "type": "checkbox", "id": "show_strip", "label": "Show the chips row", "default": true },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Start the reset — R199" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "text", "id": "note", "label": "Note", "default": "Most people feel the shift by day 3." }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji", "default": "🧠" },
        { "type": "text", "id": "title", "label": "Title", "default": "Razor focus" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Get hours back. Actually finish what you start." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "Benefits / Why",
    "blocks": [
      { "type": "benefit", "settings": { "emoji": "🧠", "title": "Razor focus", "text": "Get hours back. Read, study, work — and actually finish." } },
      { "type": "benefit", "settings": { "emoji": "😌", "title": "Real happiness", "text": "Normal life feels good again — not grey, not flat." } },
      { "type": "benefit", "settings": { "emoji": "⚡", "title": "Real energy", "text": "Wake up clear instead of foggy and already drained." } },
      { "type": "benefit", "settings": { "emoji": "📈", "title": "Drive for your future", "text": "Chase real goals — grades, money, the life you want." } },
      { "type": "benefit", "settings": { "emoji": "❤️", "title": "Better relationships", "text": "Be present with people. Phone down, fully there." } },
      { "type": "benefit", "settings": { "emoji": "💪", "title": "Self-respect", "text": "Do hard things on purpose. Feel proud of yourself again." } }
    ]
  }]
}
{% endschema %}
