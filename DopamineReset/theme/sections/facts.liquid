{% raw %}
<style>
  .ft{position:relative;overflow:hidden;padding:clamp(56px,9vw,110px) 0;background:linear-gradient(180deg,#0b0913,#140f1d)}
  .ft__wrap{max-width:1060px;margin:0 auto;padding:0 22px;position:relative;z-index:1}
  .ft__eye{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.72rem;letter-spacing:.3em;text-transform:uppercase;color:#ffc24b;text-align:center;margin-bottom:12px}
  .ft h2{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:clamp(1.9rem,5vw,3.2rem);line-height:1.04;text-align:center;color:#fff;margin:0 0 10px}
  .ft h2 .g{background:linear-gradient(135deg,#ff5c8a,#7c5cff);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent}
  .ft__sub{color:#cfccc4;text-align:center;max-width:48ch;margin:0 auto 34px;line-height:1.55}

  .ft__hero{display:grid;grid-template-columns:1fr;gap:16px;margin-bottom:16px}
  .ft__big{position:relative;overflow:hidden;border-radius:22px;padding:28px;border:1px solid rgba(255,255,255,.1);background:radial-gradient(120% 130% at 85% 10%,rgba(255,138,61,.3),transparent 55%),radial-gradient(120% 130% at 10% 100%,rgba(124,92,255,.28),transparent 55%),#15121d;text-align:center}
  .ft__bignum{font-family:var(--serif,'Fraunces',serif);font-weight:700;font-size:clamp(3rem,11vw,6rem);line-height:1;background:linear-gradient(135deg,#ffc24b,#ff5c8a,#7c5cff);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent}
  .ft__bigtxt{color:#e8e6e0;font-size:clamp(1.05rem,2.2vw,1.3rem);max-width:40ch;margin:10px auto 0;line-height:1.5}

  .ft__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px}
  .ft__card{position:relative;border-radius:20px;padding:24px 22px;border:1px solid rgba(255,255,255,.1);background:#15121d;overflow:hidden;transition:transform .2s,box-shadow .2s}
  .ft__card:hover{transform:translateY(-4px);box-shadow:0 22px 50px rgba(0,0,0,.45)}
  .ft__icon{width:60px;height:60px;border-radius:18px;display:grid;place-items:center;font-size:1.9rem;margin-bottom:16px;position:relative;transform-style:preserve-3d;animation:ft3d 6s ease-in-out infinite;box-shadow:0 12px 26px rgba(0,0,0,.45),inset 0 2px 6px rgba(255,255,255,.35)}
  @keyframes ft3d{0%,100%{transform:perspective(500px) rotateY(-16deg) rotateX(8deg) translateY(0)}50%{transform:perspective(500px) rotateY(16deg) rotateX(-6deg) translateY(-6px)}}
  .ft__card:nth-child(1) .ft__icon{background:linear-gradient(145deg,#ff8a3d,#ff5c8a)}
  .ft__card:nth-child(2) .ft__icon{background:linear-gradient(145deg,#7c5cff,#4f8cff)}
  .ft__card:nth-child(3) .ft__icon{background:linear-gradient(145deg,#2bd3c6,#4f8cff)}
  .ft__card:nth-child(4) .ft__icon{background:linear-gradient(145deg,#5ad48a,#bfe65a)}
  .ft__num{font-family:var(--serif,'Fraunces',serif);font-weight:700;font-size:1.7rem;color:#ffc24b;display:block;line-height:1;margin-bottom:6px}
  .ft__card b{display:block;color:#fff;font-size:1.05rem;margin-bottom:8px}
  .ft__card p{color:#b8b4ad;font-size:.95rem;line-height:1.55;margin:0}
  .ft__note{text-align:center;color:#6f6b63;font-size:.8rem;margin-top:24px;max-width:60ch;margin-left:auto;margin-right:auto}
  @media (prefers-reduced-motion:reduce){.ft__icon{animation:none}}
</style>
{% endraw %}

<section class="ft" id="facts">
  <div class="ft__wrap">
    <p class="ft__eye">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p class="ft__sub">{{ section.settings.sub }}</p>

    <div class="ft__hero">
      <div class="ft__big">
        <div class="ft__bignum">{{ section.settings.big_num }}</div>
        <p class="ft__bigtxt">{{ section.settings.big_text }}</p>
      </div>
    </div>

    <div class="ft__grid">
      {%- for block in section.blocks -%}
        <article class="ft__card" {{ block.shopify_attributes }}>
          <div class="ft__icon">{{ block.settings.icon }}</div>
          {%- if block.settings.stat != blank -%}<span class="ft__num">{{ block.settings.stat }}</span>{%- endif -%}
          <b>{{ block.settings.title }}</b>
          <p>{{ block.settings.text }}</p>
        </article>
      {%- endfor -%}
    </div>
    <p class="ft__note">{{ section.settings.note }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Facts",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The science, simply" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "It's not you. It's how the feed is <span class=\"g\">built</span>." },
    { "type": "textarea", "id": "sub", "label": "Sub", "default": "A few honest facts about what cheap dopamine does to your brain — and why a short reset works." },
    { "type": "text", "id": "big_num", "label": "Big number", "default": "2½ hours" },
    { "type": "textarea", "id": "big_text", "label": "Big text", "default": "is what the average person spends on social apps every single day. That's roughly 38 days a year — gone to the scroll." },
    { "type": "text", "id": "note", "label": "Note", "default": "General research on attention and reward — shared for context, not medical advice." }
  ],
  "blocks": [
    { "type": "fact", "name": "Fact", "settings": [
      { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "🎰" },
      { "type": "text", "id": "stat", "label": "Stat (optional)" },
      { "type": "text", "id": "title", "label": "Title", "default": "Built like a slot machine" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "Feeds use unpredictable, variable rewards — the exact design that makes gambling so hard to put down." }
    ]}
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "Facts",
    "blocks": [
      { "type": "fact", "settings": { "icon": "🎰", "title": "Built like a slot machine", "text": "Feeds run on unpredictable, variable rewards — the same design that makes gambling hard to put down." } },
      { "type": "fact", "settings": { "icon": "🧲", "title": "Wanting isn't liking", "stat": "≠", "text": "Dopamine drives the urge to seek more, not the pleasure itself. That's why you can scroll for an hour and still feel empty." } },
      { "type": "fact", "settings": { "icon": "⏱️", "stat": "~23 min", "title": "To refocus after a ping", "text": "Research on attention suggests it takes the average person around 23 minutes to fully refocus after one distraction." } },
      { "type": "fact", "settings": { "icon": "🌱", "stat": "days", "title": "Your brain bounces back", "text": "The reward system is plastic. Lower the flood of stimulation and your baseline starts recovering — often within days." } }
    ]
  }]
}
{% endschema %}
