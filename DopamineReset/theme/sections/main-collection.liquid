<section class="section">
  <div class="wrap">
    <div class="page-head">
      <p class="eyebrow">Collection</p>
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}<div class="rte" style="margin-top:14px">{{ collection.description }}</div>{%- endif -%}
    </div>
    <div class="coll-grid">
      {%- for product in collection.products -%}
        <a class="card" href="{{ product.url }}">
          <div class="card__img">
            {%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 460 }}" alt="{{ product.title | escape }}">{%- else -%}Reset{%- endif -%}
          </div>
          <div class="card__body"><b>{{ product.title }}</b><span>{{ product.price | money }}</span></div>
        </a>
      {%- else -%}
        <p>No products yet. Add your products in Shopify Admin.</p>
      {%- endfor -%}
    </div>
    {%- if paginate.pages > 1 -%}<div style="margin-top:30px">{{ paginate | default_pagination }}</div>{%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
