{% raw %}
<style>
  .cs{position:relative;padding:clamp(72px,10vw,120px) 0;background:radial-gradient(110% 90% at 80% 0%,#0d1230 0%,#060913 60%);overflow:hidden}
  .cs__glow{position:absolute;width:44vmax;height:44vmax;border-radius:50%;filter:blur(100px);opacity:.25;pointer-events:none;background:radial-gradient(circle,#4de3ff,transparent 65%);top:-14vmax;right:-10vmax}
  .cs__wrap{position:relative;z-index:1;max-width:1080px;margin:0 auto;padding:0 26px}
  .cs__grid{display:grid;grid-template-columns:minmax(0,440px) 1fr;gap:clamp(30px,5vw,70px);align-items:center}
  @media(max-width:880px){.cs__grid{grid-template-columns:1fr;gap:36px}}

  /* the machine */
  .cs__machine{position:relative;display:flex;flex-direction:column;align-items:center}
  .cs__orbwrap{position:relative;width:120px;height:120px;margin-bottom:-34px;z-index:2}
  .cs__orb{position:absolute;inset:18px;border-radius:50%;background:radial-gradient(circle at 34% 30%,#d9fbff,#4de3ff 42%,#1b6fae 78%,#0a2540);box-shadow:0 0 34px rgba(77,227,255,.55),0 14px 30px rgba(0,0,0,.5);animation:csbreathe 3.4s ease-in-out infinite}
  .cs__orb::after{content:"";position:absolute;left:26%;top:20%;width:24%;height:14%;border-radius:50%;background:rgba(255,255,255,.85);filter:blur(2px)}
  @keyframes csbreathe{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
  .cs__ring{position:absolute;inset:0;border-radius:50%;border:1px solid rgba(77,227,255,.4);border-left-color:transparent;border-right-color:transparent;animation:csspin 7s linear infinite}
  .cs__ring.r2{inset:7px;border-color:rgba(124,92,255,.35);border-top-color:transparent;border-bottom-color:transparent;animation-duration:11s;animation-direction:reverse}
  @keyframes csspin{to{transform:rotate(360deg)}}

  /* chat window */
  .cs__chat{position:relative;width:100%;border-radius:24px;padding:44px 18px 16px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);backdrop-filter:blur(10px);box-shadow:0 30px 70px rgba(0,0,0,.45);min-height:320px;display:flex;flex-direction:column;gap:9px}
  .cs__tag{position:absolute;top:14px;left:0;right:0;text-align:center;font-family:var(--mono,'JetBrains Mono',monospace);font-size:.6rem;letter-spacing:.28em;text-transform:uppercase;color:#4de3ff}
  .cs__msg{max-width:86%;padding:11px 14px;border-radius:16px;font-size:.93rem;line-height:1.5;color:#fff;opacity:0;transform:translateY(10px);transition:opacity .35s,transform .35s}
  .cs__msg.on{opacity:1;transform:none}
  .cs__msg.c{background:rgba(0,0,0,.32);border:1px solid rgba(255,255,255,.12);border-bottom-left-radius:6px;align-self:flex-start}
  .cs__msg.u{background:linear-gradient(135deg,#7c5cff,#5a3ff0);border-bottom-right-radius:6px;align-self:flex-end}
  .cs__type{display:none;align-self:flex-start;padding:12px 14px;background:rgba(0,0,0,.32);border:1px solid rgba(255,255,255,.12);border-radius:16px;border-bottom-left-radius:6px}
  .cs__type.on{display:inline-flex;gap:4px}
  .cs__type i{width:6px;height:6px;border-radius:50%;background:#9fd9ec;animation:cstp 1s infinite}
  .cs__type i:nth-child(2){animation-delay:.15s}.cs__type i:nth-child(3){animation-delay:.3s}
  @keyframes cstp{0%,100%{opacity:.3;transform:translateY(0)}50%{opacity:1;transform:translateY(-3px)}}

  /* copy side */
  .cs__eye{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.64rem;letter-spacing:.34em;text-transform:uppercase;color:#4de3ff;margin:0 0 14px}
  .cs__title{font-family:var(--serif,'Fraunces',serif);font-weight:500;font-size:clamp(1.9rem,4.4vw,3rem);line-height:1.07;letter-spacing:-.02em;color:#fff;margin:0 0 16px}
  .cs__lead{color:#98a0b5;font-size:clamp(.96rem,1.5vw,1.08rem);line-height:1.65;margin:0 0 24px}
  .cs__list{list-style:none;margin:0 0 28px;padding:0;display:grid;gap:12px}
  .cs__list li{display:flex;gap:12px;align-items:flex-start;color:#c9cede;font-size:.96rem;line-height:1.5}
  .cs__list .ic{flex:none;width:30px;height:30px;border-radius:9px;display:grid;place-items:center;font-size:.95rem;background:linear-gradient(135deg,rgba(77,227,255,.18),rgba(124,92,255,.16));border:1px solid rgba(255,255,255,.1)}
  .cs__btn{display:inline-flex;align-items:center;gap:8px;font-weight:800;border-radius:999px;padding:15px 30px;font-size:1rem;background:linear-gradient(135deg,#4de3ff,#7c5cff);color:#041420;box-shadow:0 16px 38px rgba(124,92,255,.4);transition:transform .15s}
  .cs__btn:hover{transform:translateY(-2px)}
  .cs__note{margin:12px 0 0;color:#5f6b85;font-size:.8rem}
  @media (prefers-reduced-motion:reduce){.cs__orb,.cs__ring,.cs__type i{animation:none}.cs__msg{opacity:1;transform:none}}
</style>
{% endraw %}
<section class="cs" id="coach">
  <span class="cs__glow"></span>
  <div class="cs__wrap">
    <div class="cs__grid">
      <div class="cs__machine reveal">
        <div class="cs__orbwrap"><span class="cs__ring"></span><span class="cs__ring r2"></span><span class="cs__orb"></span></div>
        <div class="cs__chat" id="csChat">
          <span class="cs__tag">{{ section.settings.tag }}</span>
          <div class="cs__type" id="csType"><i></i><i></i><i></i></div>
        </div>
      </div>
      <div class="reveal">
        <p class="cs__eye">{{ section.settings.eyebrow }}</p>
        <h2 class="cs__title">{{ section.settings.heading }}</h2>
        <p class="cs__lead">{{ section.settings.lead }}</p>
        <ul class="cs__list">
          {%- for block in section.blocks -%}
            <li {{ block.shopify_attributes }}><span class="ic">{{ block.settings.icon }}</span><span>{{ block.settings.text }}</span></li>
          {%- endfor -%}
        </ul>
        <a class="cs__btn" href="{{ section.settings.cta_url | default: '#pricing' }}">{{ section.settings.cta_label }}</a>
        <p class="cs__note">{{ section.settings.note }}</p>
      </div>
    </div>
  </div>
</section>

{% raw %}
<script>
(function(){
  var chat=document.getElementById('csChat'),type=document.getElementById('csType');
  if(!chat||!type)return;
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var SCRIPT=[
    {w:'c',t:"Morning 👋 Day 3 of your reset. How's the head feeling?"},
    {w:'u',t:"Honestly? Itching to scroll."},
    {w:'c',t:"Totally normal on day 3 — that itch is the rewiring. 90 seconds of urge-surfing, then today's challenge. Ready?"},
    {w:'u',t:"Let's do it 💪"},
    {w:'c',t:"That's it. Challenge done, +30 XP, streak safe. See you tomorrow 🔥"}
  ];
  var msgs=[],started=false;
  function addMsg(m,instant){
    var d=document.createElement('div');d.className='cs__msg '+m.w;d.textContent=m.t;
    chat.insertBefore(d,type);msgs.push(d);
    if(instant){d.classList.add('on');return;}
    requestAnimationFrame(function(){requestAnimationFrame(function(){d.classList.add('on');});});
  }
  function clearMsgs(){for(var i=0;i<msgs.length;i++)if(msgs[i].parentNode)msgs[i].parentNode.removeChild(msgs[i]);msgs=[];}
  function play(i){
    if(i>=SCRIPT.length){setTimeout(function(){clearMsgs();play(0);},3600);return;}
    var m=SCRIPT[i];
    if(m.w==='c'){type.classList.add('on');
      setTimeout(function(){type.classList.remove('on');addMsg(m);setTimeout(function(){play(i+1);},1300);},850);}
    else{setTimeout(function(){addMsg(m);setTimeout(function(){play(i+1);},1100);},450);}
  }
  function start(){
    if(started)return;started=true;
    if(reduce){for(var i=0;i<SCRIPT.length;i++)addMsg(SCRIPT[i],true);return;}
    play(0);
  }
  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)start();});},{threshold:.35});
    io.observe(chat);
  }else{start();}
})();
</script>
{% endraw %}

{% schema %}
{
  "name": "AI coach spotlight",
  "settings": [
    { "type": "text", "id": "tag", "label": "Chat window tag", "default": "Live from the app · your coach" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Meet your coach" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A coach in your corner. Every single day." },
    { "type": "textarea", "id": "lead", "label": "Lead", "default": "Not a PDF. A built-in coach that knows your day, your streak and your mood — and tells you exactly what to do next." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Get my coach — R199" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "text", "id": "note", "label": "Small note", "default": "Included in the reset · no subscription" }
  ],
  "blocks": [
    { "type": "point", "name": "Point", "settings": [
      { "type": "text", "id": "icon", "label": "Icon (emoji)" },
      { "type": "text", "id": "text", "label": "Text" }
    ]}
  ],
  "max_blocks": 5,
  "presets": [{
    "name": "AI coach spotlight",
    "blocks": [
      { "type": "point", "settings": { "icon": "👋", "text": "Checks in every morning and reads how you're doing" }},
      { "type": "point", "settings": { "icon": "🌊", "text": "Craving hits? It walks you through a 90-second rescue" }},
      { "type": "point", "settings": { "icon": "🎯", "text": "Hands you one clear 10-minute challenge a day" }},
      { "type": "point", "settings": { "icon": "📈", "text": "Tracks your streak, XP and mood — and adjusts" }}
    ]
  }]
}
{% endschema %}
