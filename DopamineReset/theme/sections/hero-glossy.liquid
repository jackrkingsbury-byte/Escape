{% raw %}
<style>
  .hp{position:relative;overflow:hidden;min-height:clamp(580px,94vh,900px);display:flex;align-items:center;background:radial-gradient(90% 95% at 70% 26%,#15102a 0%,#080610 62%)}
  .hp__orbs{position:absolute;inset:0;z-index:0;pointer-events:none;overflow:hidden}
  .hp__orb{position:absolute;border-radius:50%;filter:blur(70px);opacity:.45;mix-blend-mode:screen;animation:hpo 18s ease-in-out infinite}
  .hp__orb.o1{width:34vmax;height:34vmax;background:radial-gradient(circle,#ff8a3d,transparent 65%);top:-8vmax;right:2vmax}
  .hp__orb.o2{width:30vmax;height:30vmax;background:radial-gradient(circle,#7c5cff,transparent 65%);bottom:-12vmax;right:24vmax;animation-duration:23s}
  @keyframes hpo{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-3vmax,3vmax) scale(1.12)}}

  /* 3D stage */
  .hp__stage{position:absolute;top:0;right:0;bottom:0;width:55%;z-index:1;touch-action:pan-y;perspective:1100px;perspective-origin:52% 38%}
  .hp__media{position:absolute;inset:0;transform-style:preserve-3d;will-change:transform}
  .hp__backdrop{position:absolute;inset:-12%;z-index:0;transform:translateZ(-60px) scale(1.18);
    background:radial-gradient(58% 52% at 52% 40%,rgba(124,92,255,.28),transparent 70%)}
  .hp__floor{position:absolute;left:50%;bottom:9%;width:54%;height:9%;transform:translateX(-50%);z-index:1;border-radius:50%;
    background:radial-gradient(closest-side,rgba(0,0,0,.55),transparent);filter:blur(8px)}
  .hp__halo{position:absolute;left:50%;top:40%;width:60%;aspect-ratio:1;transform:translate(-50%,-50%) translateZ(-30px);border-radius:50%;filter:blur(58px);z-index:1;
    background:radial-gradient(circle,rgba(255,194,75,0),transparent 70%)}
  .hp__person{position:absolute;inset:0;z-index:3;transform-style:preserve-3d;will-change:transform,filter;
    filter:saturate(.55) brightness(.74) contrast(.99)}
  .hp__face{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:50% 16%;
    filter:drop-shadow(0 26px 34px rgba(0,0,0,.6))}
  .hp__face.happy{opacity:0;will-change:opacity}
  .hp__spark{position:absolute;border-radius:50%;background:#ffd98a;box-shadow:0 0 10px 2px rgba(255,200,120,.8);z-index:4;opacity:0;pointer-events:none}

  /* mood slider */
  .hp__ctl{position:absolute;left:50%;bottom:26px;transform:translateX(-50%);z-index:6;display:flex;align-items:center;gap:12px;width:min(78%,360px);
    background:rgba(10,8,18,.55);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.14);border-radius:999px;padding:9px 14px}
  .hp__cface{font-size:1.4rem;filter:drop-shadow(0 3px 6px rgba(0,0,0,.5))}
  .hp__track{position:relative;flex:1;height:8px;border-radius:999px;background:rgba(255,255,255,.18);cursor:pointer}
  .hp__fill{position:absolute;left:0;top:0;bottom:0;width:20%;border-radius:999px;background:linear-gradient(90deg,#5170c8,#ff5c8a,#ffc24b)}
  .hp__knob{position:absolute;top:50%;left:20%;width:24px;height:24px;border-radius:50%;background:#fff;transform:translate(-50%,-50%);box-shadow:0 4px 14px rgba(0,0,0,.5);cursor:grab}
  .hp__knob:active{cursor:grabbing}
  .hp__hint{position:absolute;left:50%;bottom:64px;transform:translateX(-50%);z-index:6;font-family:var(--mono,monospace);font-size:.64rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.6);transition:opacity .4s;pointer-events:none}

  .hp__scrim{position:absolute;inset:0;z-index:2;pointer-events:none;background:linear-gradient(90deg,rgba(8,6,12,.96) 0%,rgba(8,6,12,.74) 36%,rgba(8,6,12,.08) 66%,transparent 100%)}
  .hp__wrap{position:relative;z-index:3;max-width:1120px;margin:0 auto;padding:0 22px;width:100%;pointer-events:none}
  .hp__wrap a{pointer-events:auto}
  .hp__in{max-width:600px}
  .hp__scar{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono,'JetBrains Mono',monospace);font-size:.78rem;color:#ffc24b;border:1px solid rgba(255,194,75,.4);border-radius:999px;padding:7px 15px;margin-bottom:18px;background:rgba(255,194,75,.05)}
  .hp__scar i{width:8px;height:8px;border-radius:50%;background:#5ad48a;box-shadow:0 0 0 0 rgba(90,212,138,.6);animation:hppi 2s infinite}
  @keyframes hppi{70%{box-shadow:0 0 0 9px rgba(90,212,138,0)}100%{box-shadow:0 0 0 0 rgba(90,212,138,0)}}
  .hp__eye{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.72rem;letter-spacing:.3em;text-transform:uppercase;color:#ffc24b;margin:0 0 14px}
  .hp h1{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:clamp(2.3rem,6.4vw,4.4rem);line-height:1.02;letter-spacing:-.02em;margin:0 0 18px;color:#fff}
  .hp__sub{color:#cfccc4;font-size:clamp(1.05rem,2.1vw,1.32rem);line-height:1.55;max-width:46ch;margin:0 0 30px}
  .hp__cta{display:flex;gap:13px;flex-wrap:wrap;align-items:center}
  .hp__btnwrap{position:relative;display:inline-flex}
  .hp__btnwrap::before{content:"";position:absolute;inset:-4px;border-radius:999px;background:linear-gradient(135deg,#ffc24b,#ff8a3d);filter:blur(14px);opacity:.55;z-index:-1;animation:hpglow 2.6s ease-in-out infinite}
  @keyframes hpglow{0%,100%{opacity:.4;transform:scale(.97)}50%{opacity:.8;transform:scale(1.06)}}
  .hp__btn{position:relative;display:inline-flex;align-items:center;gap:8px;font-weight:800;border-radius:999px;padding:16px 32px;font-size:1.06rem;background:linear-gradient(135deg,#ffc24b,#ff8a3d);color:#2a1400;box-shadow:0 16px 40px rgba(255,138,61,.36);transition:transform .15s;overflow:hidden}
  .hp__btn::after{content:"";position:absolute;top:0;left:-120%;width:60%;height:100%;background:linear-gradient(105deg,transparent,rgba(255,255,255,.6),transparent);transform:skewX(-18deg);animation:hpshine 3.4s ease-in-out infinite}
  @keyframes hpshine{0%{left:-120%}28%,100%{left:160%}}
  .hp__btn:hover{transform:translateY(-2px)}
  .hp__btn--ghost{background:transparent;border:1px solid rgba(255,255,255,.22);color:#fff;box-shadow:none}
  .hp__btn--ghost::after{display:none}
  .hp__btn--ghost:hover{border-color:#ffc24b;color:#ffc24b}
  .hp__trust{display:flex;gap:24px;flex-wrap:wrap;margin-top:34px;color:#8b877f;font-size:.9rem}
  .hp__trust b{color:#fff;font-family:var(--serif,'Fraunces',serif);font-size:1.05rem}
  @media(max-width:820px){
    .hp{min-height:auto;padding:84px 0 36px}
    .hp__stage{position:relative;width:100%;height:58vh;order:-1}
    .hp__scrim{background:linear-gradient(180deg,transparent 0%,rgba(8,6,12,.35) 60%,#080610 100%)}
    .hp__in{max-width:100%}
  }
  @media (prefers-reduced-motion:reduce){.hp__orb,.hp__btnwrap::before,.hp__btn::after{animation:none}}
</style>
{% endraw %}

<section class="hp" id="heroPerson">
  <div class="hp__orbs"><span class="hp__orb o1"></span><span class="hp__orb o2"></span></div>
  <div class="hp__stage" id="hpStage">
    <div class="hp__media">
      <span class="hp__backdrop" id="hpBack"></span>
      <span class="hp__halo" id="hpHalo"></span>
      <span class="hp__floor"></span>
      <div class="hp__person" id="hpPerson">
        <img class="hp__face" id="hpSad" src="{{ 'hero-sad-cut.png' | asset_url }}" alt="A young man looking flat before the reset">
        <img class="hp__face happy" id="hpHappy" src="{{ 'hero-happy-cut.png' | asset_url }}" alt="The same young man smiling after the reset">
      </div>
    </div>
    <div class="hp__hint" id="hpHint">Drag — watch the shift</div>
    <div class="hp__ctl" id="hpCtl">
      <span class="hp__cface">😔</span>
      <div class="hp__track" id="hpTrack"><div class="hp__fill" id="hpFill"></div><div class="hp__knob" id="hpKnob"></div></div>
      <span class="hp__cface">😄</span>
    </div>
  </div>
  <div class="hp__scrim"></div>
  <div class="hp__wrap"><div class="hp__in">
    {%- if section.settings.scarcity_label != blank -%}
      {%- assign ph = '{' | append: 'n' | append: '}' -%}
      <div class="hp__scar"><i></i> {{ section.settings.scarcity_label | replace: ph, section.settings.scarcity_base }}</div>
    {%- endif -%}
    <p class="hp__eye">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p class="hp__sub">{{ section.settings.subheading }}</p>
    <div class="hp__cta">
      <span class="hp__btnwrap"><a class="hp__btn" href="{{ section.settings.cta1_url | default: '#pricing' }}">{{ section.settings.cta1_label }}</a></span>
      <a class="hp__btn hp__btn--ghost" href="{{ section.settings.cta2_url | default: '#why' }}">{{ section.settings.cta2_label }}</a>
    </div>
    <div class="hp__trust">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}><b>{{ block.settings.stat }}</b> {{ block.settings.label }}</div>
      {%- endfor -%}
    </div>
  </div></div>
</section>

{% raw %}
<script>
(function(){
  var stage=document.getElementById('hpStage'),media=stage&&stage.querySelector('.hp__media'),
      person=document.getElementById('hpPerson'),back=document.getElementById('hpBack'),happy=document.getElementById('hpHappy'),
      halo=document.getElementById('hpHalo'),track=document.getElementById('hpTrack'),fill=document.getElementById('hpFill'),
      knob=document.getElementById('hpKnob'),hint=document.getElementById('hpHint');
  if(!stage||!person)return;
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function lerp(a,b,t){return a+(b-a)*t}

  // sparkles around the head
  var sparks=[];
  if(media){for(var i=0;i<14;i++){var s=document.createElement('span');s.className='hp__spark';var sz=2+Math.random()*4;
    s.style.width=sz+'px';s.style.height=sz+'px';s.style.left=(18+Math.random()*64)+'%';s.style.top=(10+Math.random()*64)+'%';
    s.dataset.ph=(Math.random()*6.28).toFixed(2);s.dataset.sp=(0.4+Math.random()*0.8).toFixed(2);media.appendChild(s);sparks.push(s);}}

  var target=0.85,val=0.18,touched=false,t0=Date.now();
  function setTarget(v){target=v<0?0:v>1?1:v;touched=true;if(hint)hint.style.opacity='0';}
  function fromClientX(x){var r=track.getBoundingClientRect();setTarget((x-r.left)/r.width);}
  var tdrag=false;
  function dn(e){tdrag=true;fromClientX(e.touches?e.touches[0].clientX:e.clientX);if(e.cancelable)e.preventDefault();}
  function mv(e){if(!tdrag)return;fromClientX(e.touches?e.touches[0].clientX:e.clientX);if(e.cancelable)e.preventDefault();}
  function up(){tdrag=false;}
  track.addEventListener('mousedown',dn);knob.addEventListener('mousedown',dn);
  track.addEventListener('touchstart',dn,{passive:false});knob.addEventListener('touchstart',dn,{passive:false});
  window.addEventListener('mousemove',mv);window.addEventListener('touchmove',mv,{passive:false});
  window.addEventListener('mouseup',up);window.addEventListener('touchend',up);
  // drag on the person
  var cdrag=false,cx0=0,cv0=0;
  person.addEventListener('mousedown',function(e){cdrag=true;cx0=e.clientX;cv0=target;e.preventDefault();});
  person.addEventListener('touchstart',function(e){cdrag=true;cx0=e.touches[0].clientX;cv0=target;},{passive:true});
  window.addEventListener('mousemove',function(e){if(!cdrag)return;setTarget(cv0+(e.clientX-cx0)/300);});
  window.addEventListener('touchmove',function(e){if(!cdrag)return;setTarget(cv0+(e.touches[0].clientX-cx0)/300);},{passive:true});
  window.addEventListener('mouseup',function(){cdrag=false;});window.addEventListener('touchend',function(){cdrag=false;});
  // pointer parallax
  var tpx=0,tpy=0,px=0,py=0;
  window.addEventListener('pointermove',function(e){var r=stage.getBoundingClientRect();tpx=((e.clientX-r.left)/r.width-0.5);tpy=((e.clientY-r.top)/r.height-0.5);});

  function frame(){
    requestAnimationFrame(frame);
    var t=(Date.now()-t0)/1000;
    if(!touched&&!reduce)target=0.5+0.46*Math.sin(t*0.5);
    val+=(target-val)*0.10;
    var m=val, sm=m*m*(3-2*m);
    // slider UI
    fill.style.width=(m*100)+'%';knob.style.left=(m*100)+'%';
    // crossfade neutral -> real smile
    happy.style.opacity=sm.toFixed(3);
    // mood grade on the person: cold/dim (sad) -> warm/bright (happy)
    person.style.filter='saturate('+lerp(0.5,1.22,m).toFixed(3)+') brightness('+lerp(0.72,1.12,m).toFixed(3)+') contrast('+lerp(0.99,1.05,m).toFixed(3)+') sepia('+(sm*0.22).toFixed(3)+') hue-rotate('+lerp(8,-12,m).toFixed(2)+'deg)';
    // halo grows + warms
    var hg=Math.max(0,(m-0.2));
    halo.style.background='radial-gradient(circle,rgba('+Math.round(lerp(120,255,m))+','+Math.round(lerp(140,200,m))+','+Math.round(lerp(255,120,m))+','+(hg*0.6).toFixed(3)+'),transparent 70%)';
    // backdrop warms too
    if(back)back.style.background='radial-gradient(58% 52% at 52% 40%,rgba('+Math.round(lerp(124,255,m))+','+Math.round(lerp(92,150,m))+','+Math.round(lerp(255,90,m))+','+lerp(0.22,0.4,m).toFixed(3)+'),transparent 70%)';
    // 3D: tilt whole scene; push person forward, backdrop back, parallax differently
    px+=(tpx-px)*0.06;py+=(tpy-py)*0.06;
    var breathe=reduce?0:Math.sin(t*0.9)*0.006, bob=reduce?0:Math.sin(t*0.9)*4;
    var ry=px*11, rx=py*-7;
    if(media)media.style.transform='rotateY('+ry.toFixed(2)+'deg) rotateX('+rx.toFixed(2)+'deg)';
    person.style.transform='translateZ(62px) scale('+(1.04+breathe).toFixed(3)+') translate('+(px*-20).toFixed(1)+'px,'+(py*-14-bob).toFixed(1)+'px)';
    if(back)back.style.transform='translateZ(-60px) scale(1.18) translate('+(px*10).toFixed(1)+'px,'+(py*8).toFixed(1)+'px)';
    // sparkles
    for(var i=0;i<sparks.length;i++){var s=sparks[i],ph=+s.dataset.ph,sp=+s.dataset.sp;
      s.style.opacity=(Math.max(0,m-0.45)*1.8*(0.5+0.5*Math.sin(t*sp*2+ph))).toFixed(3);
      s.style.transform='translateZ(70px) translateY('+(Math.sin(t*sp+ph)*6).toFixed(1)+'px)';}
  }
  frame();
})();
</script>
{% endraw %}

{% schema %}
{
  "name": "Hero person",
  "settings": [
    { "type": "paragraph", "content": "The hero shows a cut-out person who pops out in 3D and crossfades from a flat/neutral face to a real smile as it animates and as you drag the slider. The frames live in theme assets as hero-sad-cut.png and hero-happy-cut.png — replace those files to use your own." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your brain is fried. Here's the reset." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Quit cheap dopamine. Feel good for real — in 7 days." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Endless scrolling fried your reward system, so nothing feels good anymore. The Dopamine Reset rewires it in a week — 10 minutes a day. Drag the slider → that's the shift." },
    { "type": "text", "id": "cta1_label", "label": "Primary CTA", "default": "Start the reset — R199" },
    { "type": "url", "id": "cta1_url", "label": "Primary CTA link" },
    { "type": "text", "id": "cta2_label", "label": "Secondary CTA", "default": "Why it works" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA link" },
    { "type": "text", "id": "scarcity_label", "label": "Scarcity text (n = number)", "default": "Only {n} resets left at the R199 launch price" },
    { "type": "number", "id": "scarcity_base", "label": "Number", "default": 40 }
  ],
  "blocks": [
    { "type": "stat", "name": "Trust stat", "settings": [
      { "type": "text", "id": "stat", "label": "Number", "default": "7 days" },
      { "type": "text", "id": "label", "label": "Label", "default": "to feel it" }
    ]}
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Hero person" }]
}
{% endschema %}
