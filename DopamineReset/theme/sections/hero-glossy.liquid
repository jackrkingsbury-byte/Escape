{% raw %}
<style>
  .hg{position:relative;overflow:hidden;min-height:clamp(580px,94vh,880px);display:flex;align-items:center;background:radial-gradient(90% 95% at 70% 26%,#1b1233 0%,#0a0812 60%)}
  .hg__orbs{position:absolute;inset:0;z-index:0;overflow:hidden;pointer-events:none}
  .hg__orb{position:absolute;border-radius:50%;filter:blur(64px);opacity:.5;mix-blend-mode:screen;animation:hgo 16s ease-in-out infinite}
  .hg__orb.o1{width:36vmax;height:36vmax;background:radial-gradient(circle,#ff8a3d,transparent 65%);top:-10vmax;right:0}
  .hg__orb.o2{width:32vmax;height:32vmax;background:radial-gradient(circle,#7c5cff,transparent 65%);bottom:-12vmax;right:22vmax;animation-duration:21s}
  .hg__orb.o3{width:26vmax;height:26vmax;background:radial-gradient(circle,#2bd3c6,transparent 65%);top:28%;right:42%;animation-duration:24s}
  @keyframes hgo{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-3vmax,3vmax) scale(1.14)}}

  .hg__stage{position:absolute;top:0;right:0;bottom:0;width:56%;z-index:1}
  .hg__canvas{position:absolute;inset:0;width:100%;height:100%;display:block}
  .hg__fallback{position:absolute;inset:0;display:none;place-items:center;z-index:0}
  .hg__fig{font-size:clamp(5rem,17vw,11rem);line-height:1;filter:drop-shadow(0 18px 40px rgba(0,0,0,.55));animation:hgfloat 5.5s ease-in-out infinite}
  .hg__halo{position:absolute;width:46%;aspect-ratio:1;border-radius:50%;filter:blur(34px);background:radial-gradient(circle,rgba(255,194,75,.4),rgba(124,92,255,.16) 50%,transparent 68%);animation:hgpulse 5s ease-in-out infinite}
  @keyframes hgfloat{0%,100%{transform:translateY(0) rotate(0)}50%{transform:translateY(-16px) rotate(4deg)}}
  @keyframes hgpulse{0%,100%{transform:scale(.85);opacity:.6}50%{transform:scale(1.08);opacity:.95}}

  .hg__scrim{position:absolute;inset:0;z-index:2;pointer-events:none;background:linear-gradient(90deg,rgba(8,6,12,.95) 0%,rgba(8,6,12,.74) 40%,rgba(8,6,12,.12) 70%,transparent 100%)}
  .hg__wrap{position:relative;z-index:3;max-width:1120px;margin:0 auto;padding:0 22px;width:100%}
  .hg__in{max-width:600px}
  .hg__scar{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono,'JetBrains Mono',monospace);font-size:.78rem;color:#ffc24b;border:1px solid rgba(255,194,75,.4);border-radius:999px;padding:7px 15px;margin-bottom:18px;background:rgba(255,194,75,.05)}
  .hg__scar i{width:8px;height:8px;border-radius:50%;background:#5ad48a;box-shadow:0 0 0 0 rgba(90,212,138,.6);animation:hgpi 2s infinite}
  @keyframes hgpi{70%{box-shadow:0 0 0 9px rgba(90,212,138,0)}100%{box-shadow:0 0 0 0 rgba(90,212,138,0)}}
  .hg__eye{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.72rem;letter-spacing:.3em;text-transform:uppercase;color:#ffc24b;margin:0 0 14px}
  .hg h1{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:clamp(2.3rem,6.4vw,4.4rem);line-height:1.02;letter-spacing:-.02em;margin:0 0 18px;color:#fff}
  .hg__sub{color:#cfccc4;font-size:clamp(1.05rem,2.1vw,1.32rem);line-height:1.55;max-width:46ch;margin:0 0 30px}
  .hg__cta{display:flex;gap:13px;flex-wrap:wrap}
  .hg__btn{display:inline-flex;align-items:center;gap:8px;font-weight:800;border-radius:999px;padding:16px 32px;font-size:1.06rem;background:linear-gradient(135deg,#ffc24b,#ff8a3d);color:#2a1400;box-shadow:0 16px 40px rgba(255,138,61,.36);transition:transform .15s}
  .hg__btn:hover{transform:translateY(-2px)}
  .hg__btn--ghost{background:transparent;border:1px solid rgba(255,255,255,.22);color:#fff;box-shadow:none}
  .hg__btn--ghost:hover{border-color:#ffc24b;color:#ffc24b}
  .hg__trust{display:flex;gap:24px;flex-wrap:wrap;margin-top:34px;color:#8b877f;font-size:.9rem}
  .hg__trust b{color:#fff;font-family:var(--serif,'Fraunces',serif);font-size:1.05rem}
  @media(max-width:820px){
    .hg{min-height:auto;padding:88px 0 36px}
    .hg__stage{position:relative;width:100%;height:48vh;order:-1}
    .hg__scrim{background:linear-gradient(180deg,transparent 0%,rgba(8,6,12,.35) 55%,#0a0812 100%)}
    .hg__in{max-width:100%}
  }
  @media (prefers-reduced-motion:reduce){.hg__fig,.hg__halo,.hg__orb{animation:none}}
</style>
{% endraw %}

<section class="hg" id="heroGlossy">
  <div class="hg__orbs"><span class="hg__orb o1"></span><span class="hg__orb o2"></span><span class="hg__orb o3"></span></div>
  <div class="hg__stage" id="hgStage">
    <canvas class="hg__canvas" id="hgCanvas"></canvas>
    <div class="hg__fallback" id="hgFallback"><span class="hg__halo"></span><span class="hg__fig">😄</span></div>
  </div>
  <div class="hg__scrim"></div>
  <div class="hg__wrap"><div class="hg__in">
    {%- if section.settings.scarcity_label != blank -%}
      {%- assign ph = '{' | append: 'n' | append: '}' -%}
      <div class="hg__scar"><i></i> {{ section.settings.scarcity_label | replace: ph, section.settings.scarcity_base }}</div>
    {%- endif -%}
    <p class="hg__eye">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p class="hg__sub">{{ section.settings.subheading }}</p>
    <div class="hg__cta">
      <a class="hg__btn" href="{{ section.settings.cta1_url | default: '#pricing' }}">{{ section.settings.cta1_label }}</a>
      <a class="hg__btn hg__btn--ghost" href="{{ section.settings.cta2_url | default: '#why' }}">{{ section.settings.cta2_label }}</a>
    </div>
    <div class="hg__trust">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}><b>{{ block.settings.stat }}</b> {{ block.settings.label }}</div>
      {%- endfor -%}
    </div>
  </div></div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
{% raw %}
<script>
(function(){
  var stage=document.getElementById('hgStage'),cv=document.getElementById('hgCanvas'),fb=document.getElementById('hgFallback'),sec=document.getElementById('heroGlossy');
  if(!stage||!cv)return;
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var THREE=window.THREE;
  function fail(){if(fb)fb.style.display='grid';}
  if(!THREE){fail();return;}
  try{var tc=document.createElement('canvas');if(!(tc.getContext('webgl')||tc.getContext('experimental-webgl'))){fail();return;}}catch(e){fail();return;}
  var renderer;try{renderer=new THREE.WebGLRenderer({canvas:cv,alpha:true,antialias:true});}catch(e){fail();return;}
  renderer.setPixelRatio(Math.min(window.devicePixelRatio||1,2));
  if(renderer.outputEncoding!==undefined)renderer.outputEncoding=THREE.sRGBEncoding;
  if(renderer.toneMapping!==undefined){renderer.toneMapping=THREE.ACESFilmicToneMapping;renderer.toneMappingExposure=1.08;}

  var scene=new THREE.Scene();
  var camera=new THREE.PerspectiveCamera(38,1,0.1,100);camera.position.set(0,0.1,4.3);camera.lookAt(0,0.05,0);
  var group=new THREE.Group();scene.add(group);

  // ---- procedural studio environment (coloured reflections, no external HDR) ----
  var envScene=new THREE.Scene();
  (function(){
    var c=document.createElement('canvas');c.width=8;c.height=256;var ctx=c.getContext('2d');
    var grd=ctx.createLinearGradient(0,0,0,256);grd.addColorStop(0,'#5a4a82');grd.addColorStop(.5,'#16121f');grd.addColorStop(1,'#050409');
    ctx.fillStyle=grd;ctx.fillRect(0,0,8,256);
    var tex=new THREE.CanvasTexture(c);tex.mapping=THREE.EquirectangularReflectionMapping;envScene.background=tex;
    var lights=[[2.8,1.8,1.2,0xffe6c0,2.4],[-2.6,1,-1.2,0xff8a3d,1.7],[1.4,-2.2,1.6,0x7c5cff,1.6],[-1.6,2.4,2,0x2bd3c6,1.3],[2.2,0.4,-2,0xff5c8a,1.3]];
    for(var i=0;i<lights.length;i++){var L=lights[i];var pl=new THREE.Mesh(new THREE.PlaneGeometry(1.7,1.7),new THREE.MeshBasicMaterial({color:L[3]}));pl.position.set(L[0],L[1],L[2]);pl.lookAt(0,0,0);pl.scale.setScalar(L[4]);envScene.add(pl);}
  })();
  var pmrem=new THREE.PMREMGenerator(renderer);pmrem.compileEquirectangularShader();
  var envRT=pmrem.fromScene(envScene,0.04);scene.environment=envRT.texture;

  scene.add(new THREE.AmbientLight(0xffffff,0.3));
  var key=new THREE.DirectionalLight(0xffffff,1.2);key.position.set(2,3,3);scene.add(key);
  var fillL=new THREE.PointLight(0x7c5cff,2.4,20);fillL.position.set(-3,-1,2);scene.add(fillL);

  // ---- glossy smiling head ----
  var headMat=new THREE.MeshPhysicalMaterial({color:0xeaeaf2,metalness:0.62,roughness:0.06,clearcoat:1,clearcoatRoughness:0.06,envMapIntensity:1.85});
  var head=new THREE.Mesh(new THREE.SphereGeometry(1.06,72,54),headMat);group.add(head);
  var eyeMat=new THREE.MeshPhysicalMaterial({color:0x161019,metalness:0.35,roughness:0.12,clearcoat:1,clearcoatRoughness:0.1,envMapIntensity:1.2});
  function eye(x){var e=new THREE.Mesh(new THREE.SphereGeometry(0.135,32,32),eyeMat);e.position.set(x,0.2,0.9);group.add(e);return e;}
  var le=eye(-0.36),re=eye(0.36);
  // glossy catch-light on eyes
  var glintMat=new THREE.MeshBasicMaterial({color:0xffffff});
  function glint(x){var g=new THREE.Mesh(new THREE.SphereGeometry(0.035,12,12),glintMat);g.position.set(x+0.04,0.27,1.02);group.add(g);}
  glint(-0.36);glint(0.36);
  // smile: half-torus arc, opening up
  var smileMat=new THREE.MeshPhysicalMaterial({color:0x2a1320,metalness:0.45,roughness:0.1,clearcoat:1,clearcoatRoughness:0.08,envMapIntensity:1.3});
  var smile=new THREE.Mesh(new THREE.TorusGeometry(0.4,0.08,18,48,Math.PI),smileMat);
  smile.position.set(0,-0.18,0.86);smile.rotation.z=Math.PI;group.add(smile);
  // rosy glossy cheeks
  var cheekMat=new THREE.MeshPhysicalMaterial({color:0xff5c8a,metalness:0.2,roughness:0.18,clearcoat:1,transparent:true,opacity:0.55,envMapIntensity:1});
  function cheek(x){var c=new THREE.Mesh(new THREE.SphereGeometry(0.16,24,24),cheekMat);c.position.set(x,-0.1,0.82);c.scale.set(1,0.7,0.4);group.add(c);}
  cheek(-0.62);cheek(0.62);

  // ---- floating glossy orbs (the references' extra 3D objects) ----
  var orbs=[],OC=[0xff8a3d,0x7c5cff,0x2bd3c6,0xff5c8a,0xffc24b,0x5ad48a];
  var ON=window.innerWidth<820?4:6;
  for(var i=0;i<ON;i++){
    var rad=0.13+Math.random()*0.16;
    var om=new THREE.MeshPhysicalMaterial({color:OC[i%OC.length],metalness:0.55,roughness:0.05,clearcoat:1,clearcoatRoughness:0.05,envMapIntensity:1.7});
    var o=new THREE.Mesh(new THREE.IcosahedronGeometry(rad,2),om);
    var ang=Math.random()*6.2832,dist=1.7+Math.random()*0.9,yy=(Math.random()-0.5)*2.2;
    o.userData={a:ang,d:dist,y:yy,sp:0.1+Math.random()*0.25,bob:Math.random()*6.28};
    scene.add(o);orbs.push(o);
  }

  function size(){var w=stage.clientWidth||1,h=stage.clientHeight||1;renderer.setSize(w,h,false);camera.aspect=w/h;camera.updateProjectionMatrix();}
  window.addEventListener('resize',size);size();

  var px=0,tpx=0,py=0,tpy=0;
  window.addEventListener('pointermove',function(e){tpx=(e.clientX/window.innerWidth-0.5);tpy=(e.clientY/window.innerHeight-0.5);});

  var hsl={h:0,s:0,l:0},t0=Date.now();
  function frame(){
    requestAnimationFrame(frame);
    var t=(Date.now()-t0)/1000;
    // colourful chrome: slow hue drift
    var hue=(t*0.03)%1;headMat.color.setHSL(hue,0.32,0.78);
    // smile "gets happy": grows in over the first ~1.6s, then a gentle happy bounce
    var grow=Math.min(1,t/1.6),bounce=reduce?1:(1+Math.sin(t*1.6)*0.05);
    smile.scale.set(grow*bounce,grow*bounce,1);
    // blink
    var blink=1;if(!reduce){var bc=(t%4.2);if(bc>4.0)blink=Math.max(0.1,1-(bc-4.0)/0.1);}
    le.scale.y=blink;re.scale.y=blink;
    // gentle face-forward sway + breathe
    px+=(tpx-px)*0.05;py+=(tpy-py)*0.05;
    group.rotation.y=px*0.5+(reduce?0:Math.sin(t*0.4)*0.13);
    group.rotation.x=-py*0.3+(reduce?0:Math.sin(t*0.32)*0.05);
    group.position.y=reduce?0:Math.sin(t*1.2)*0.05;
    // orbit the glossy orbs
    for(var i=0;i<orbs.length;i++){var o=orbs[i],u=o.userData;u.a+=u.sp*0.01;
      o.position.set(Math.cos(u.a)*u.d,u.y+Math.sin(t*0.8+u.bob)*0.18,Math.sin(u.a)*u.d*0.7-0.3);
      o.rotation.x=t*0.5;o.rotation.y=t*0.4;}
    renderer.render(scene,camera);
  }
  frame();
})();
</script>
{% endraw %}

{% schema %}
{
  "name": "Hero 3D Glossy",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your brain is fried. Here's the reset." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Quit cheap dopamine. Feel good for real — in 7 days." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Endless scrolling fried your reward system, so nothing feels good anymore. The Dopamine Reset rewires it in a week — 10 minutes a day." },
    { "type": "text", "id": "cta1_label", "label": "Primary CTA", "default": "Start the reset — R199" },
    { "type": "url", "id": "cta1_url", "label": "Primary CTA link" },
    { "type": "text", "id": "cta2_label", "label": "Secondary CTA", "default": "Why it works" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA link" },
    { "type": "text", "id": "scarcity_label", "label": "Scarcity text (n = number)", "default": "Only {n} resets left at the R199 launch price" },
    { "type": "number", "id": "scarcity_base", "label": "Number", "default": 40 }
  ],
  "blocks": [
    { "type": "stat", "name": "Trust stat", "settings": [
      { "type": "text", "id": "stat", "label": "Number", "default": "7 days" },
      { "type": "text", "id": "label", "label": "Label", "default": "to feel it" }
    ]}
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Hero 3D Glossy" }]
}
{% endschema %}
