{% raw %}
<style>
  /* ecosystem backdrop — same family as the hero */
  #pricing{background:radial-gradient(90% 95% at 70% 10%,#0d1230 0%,#060913 62%);overflow:hidden}
  #pricing::before{content:"";position:absolute;left:50%;top:-30%;width:70vmax;height:55vmax;transform:translateX(-50%);border-radius:50%;filter:blur(120px);opacity:.13;pointer-events:none;background:radial-gradient(circle,#7c5cff,transparent 65%)}
  #pricing .wrap{position:relative;z-index:2}
  #pricing .pr__objs{position:absolute;inset:0;z-index:1;pointer-events:none}
  #pricing .pr__obj{position:absolute;display:inline-flex;align-items:center;gap:8px;font-size:1.5rem;line-height:1;
    background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.12);border-radius:16px;padding:13px 15px;
    backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);box-shadow:0 18px 44px rgba(0,0,0,.4);
    animation:prfloat 6.5s ease-in-out infinite alternate}
  #pricing .pr__obj--tag{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.72rem;letter-spacing:.12em;color:#cfe9ff;text-transform:uppercase;padding:11px 15px}
  @keyframes prfloat{from{transform:translateY(-9px)}to{transform:translateY(11px)}}
  @media(max-width:820px){#pricing .pr__obj{display:none}#pricing .pr__obj--keep{display:inline-flex;transform:scale(.85)}}
  @media (prefers-reduced-motion:reduce){#pricing .pr__obj{animation:none}}
  /* the coach, present at the buy moment */
  #pricing .pr__coach{display:flex;align-items:center;justify-content:center;gap:16px;margin:30px auto 0;max-width:560px}
  #pricing .pr__orbwrap{position:relative;flex:none;width:64px;height:64px}
  #pricing .pr__orb{position:absolute;inset:8px;border-radius:50%;background:radial-gradient(circle at 32% 28%,#bdf3ff,#4de3ff 45%,#155a8a 78%,#0a2036);box-shadow:0 0 26px rgba(77,227,255,.55),0 0 70px rgba(77,227,255,.25),inset 0 -6px 14px rgba(0,20,40,.5);animation:prbreathe 3.6s ease-in-out infinite}
  #pricing .pr__ring{position:absolute;inset:0;border-radius:50%;border:1px solid rgba(77,227,255,.35);animation:prspin 9s linear infinite}
  #pricing .pr__ring::before{content:"";position:absolute;top:-3px;left:50%;width:6px;height:6px;border-radius:50%;background:#4de3ff;box-shadow:0 0 10px #4de3ff}
  @keyframes prbreathe{0%,100%{transform:scale(1)}50%{transform:scale(1.09)}}
  @keyframes prspin{to{transform:rotate(360deg)}}
  #pricing .pr__bub{position:relative;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.14);border-radius:4px 18px 18px 18px;padding:13px 17px;color:#dfe6f5;font-size:.95rem;line-height:1.45;text-align:left;min-height:47px;display:flex;align-items:center;backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px)}
  #pricing .pr__bub .cur{display:inline-block;width:2px;height:1em;background:#4de3ff;margin-left:3px;vertical-align:-2px;animation:prblink 1s steps(1) infinite}
  @keyframes prblink{50%{opacity:0}}
  @media (prefers-reduced-motion:reduce){#pricing .pr__orb,#pricing .pr__ring{animation:none}#pricing .pr__bub .cur{display:none}}
  #pricing .tiers{display:grid;grid-template-columns:repeat(auto-fit,minmax(272px,1fr));gap:22px;max-width:880px;margin:38px auto 0;align-items:stretch}
  #pricing .tier{position:relative;text-align:left;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.1);border-radius:26px;padding:32px 28px 28px;
    transition:transform .3s cubic-bezier(.2,.8,.2,1),box-shadow .3s,border-color .3s;display:flex;flex-direction:column}
  #pricing .tier:hover{transform:translateY(-6px);border-color:rgba(77,227,255,.35);box-shadow:0 30px 60px -22px rgba(0,0,0,.65)}
  #pricing .tier--featured{background:linear-gradient(165deg,rgba(77,227,255,.1),rgba(124,92,255,.08)),rgba(255,255,255,.03);box-shadow:0 28px 80px -26px rgba(124,92,255,.55)}
  #pricing .tier--featured::before{content:"";position:absolute;inset:-1px;border-radius:27px;padding:1.5px;background:linear-gradient(135deg,#4de3ff,#7c5cff,#ff5c8a);
    -webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none}
  #pricing .tier__badge{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#4de3ff,#7c5cff);color:#041420;font-weight:800;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;border-radius:999px;padding:7px 16px;box-shadow:0 10px 26px rgba(124,92,255,.45);white-space:nowrap}
  #pricing .tier__name{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:1.35rem;color:#fff;margin:0 0 4px}
  #pricing .tier__tag{color:#98a0b5;font-size:.88rem;margin:0 0 18px}
  #pricing .tier__price{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:2.7rem;line-height:1;color:#fff;margin:0 0 20px;letter-spacing:-.02em}
  #pricing .tier__price small{font-family:var(--sans,'Hanken Grotesk',sans-serif);font-weight:500;font-size:.85rem;color:#8b93aa;letter-spacing:0}
  #pricing .tier__feats{list-style:none;margin:0 0 24px;padding:18px 0 0;border-top:1px solid rgba(255,255,255,.09);display:grid;gap:10px;flex:1}
  #pricing .tier__feats li{position:relative;padding-left:28px;color:#c9cede;font-size:.94rem;line-height:1.45}
  #pricing .tier__feats li::before{content:"✓";position:absolute;left:0;top:0;width:19px;height:19px;border-radius:6px;display:grid;place-items:center;font-size:.68rem;font-weight:800;color:#041420;background:linear-gradient(135deg,#4de3ff,#7c5cff)}
  /* tap-for-more feature details */
  #pricing .fx__t{display:flex;align-items:center;justify-content:space-between;gap:10px;width:100%;background:none;border:0;padding:0;margin:0;color:inherit;font:inherit;text-align:left;cursor:pointer}
  #pricing .fx__i{flex:none;width:18px;height:18px;border-radius:50%;border:1px solid rgba(255,255,255,.25);color:#9fb2d8;display:grid;place-items:center;font-size:.8rem;line-height:1;transition:transform .3s,color .2s,border-color .2s}
  #pricing .fx.open .fx__i{transform:rotate(45deg);color:#4de3ff;border-color:rgba(77,227,255,.5)}
  #pricing .fx__d{overflow:hidden;max-height:0;opacity:0;transition:max-height .35s ease,opacity .3s ease;color:#8f97ad;font-size:.86rem;line-height:1.5;padding-right:26px}
  #pricing .fx.open .fx__d{max-height:130px;opacity:1;margin-top:6px}
  #pricing .tier .btn{border-radius:999px;padding:15px 22px;font-weight:800}
  #pricing .tier--featured .btn{position:relative;overflow:hidden;background:linear-gradient(135deg,#4de3ff,#7c5cff);color:#041420;box-shadow:0 16px 38px rgba(124,92,255,.45)}
  #pricing .tier--featured .btn::after{content:"";position:absolute;top:0;left:-120%;width:60%;height:100%;background:linear-gradient(105deg,transparent,rgba(255,255,255,.45),transparent);transform:skewX(-18deg);animation:prshine 3.4s ease-in-out infinite}
  @keyframes prshine{0%{left:-120%}30%,100%{left:160%}}
  @media (prefers-reduced-motion:reduce){#pricing .tier--featured .btn::after{animation:none}}
</style>
{% endraw %}
<section class="section" id="pricing">
  <div class="pr__objs" aria-hidden="true">
    <span class="pr__obj pr__obj--keep" style="left:4%;top:9%;animation-delay:0s">🧠</span>
    <span class="pr__obj pr__obj--keep" style="right:5%;top:13%;animation-delay:.9s">🤖</span>
    <span class="pr__obj pr__obj--tag" style="left:7%;bottom:12%;animation-delay:1.5s">+50 XP</span>
    <span class="pr__obj" style="right:8%;bottom:18%;animation-delay:2.1s">🏆</span>
    <span class="pr__obj pr__obj--tag" style="right:22%;top:6%;animation-delay:2.7s">🔥 streak</span>
    <span class="pr__obj" style="left:20%;top:4%;animation-delay:3.3s">🚀</span>
  </div>
  <div class="wrap center">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="reveal">{{ section.settings.heading }}</h2>
    <p class="lead mx-auto reveal" style="text-align:center">{{ section.settings.subheading }}</p>

    <div class="pr__coach reveal" aria-hidden="true">
      <div class="pr__orbwrap"><span class="pr__ring"></span><span class="pr__orb"></span></div>
      <div class="pr__bub"><span id="prCoachTxt"></span><span class="cur"></span></div>
    </div>

    <div class="tiers">
      {%- for block in section.blocks -%}
        {%- assign product = block.settings.product -%}
        <div class="tier {% if block.settings.featured %}tier--featured{% endif %} reveal" {{ block.shopify_attributes }}>
          {%- if block.settings.featured and block.settings.badge != blank -%}
            <div class="tier__badge">{{ block.settings.badge }}</div>
          {%- endif -%}
          <div class="tier__name">{{ block.settings.name }}</div>
          <div class="tier__tag">{{ block.settings.tagline }}</div>

          <div class="tier__price">
            {%- if product != blank -%}
              {{ product.price | money }}
            {%- else -%}
              {{ block.settings.price }}
            {%- endif -%}
            {%- if block.settings.price_suffix != blank -%}<small> {{ block.settings.price_suffix }}</small>{%- endif -%}
          </div>

          <ul class="tier__feats">
            {%- assign feats = block.settings.features | newline_to_br | split: '<br />' -%}
            {%- for f in feats -%}
              {%- assign t = f | strip -%}
              {%- if t != blank -%}
                {%- assign parts = t | split: ' | ' -%}
                {%- if parts.size > 1 -%}
                  <li class="fx"><button type="button" class="fx__t" aria-expanded="false">{{ parts[0] }}<span class="fx__i">+</span></button><div class="fx__d">{{ parts[1] }}</div></li>
                {%- else -%}
                  <li>{{ t }}</li>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>

          {%- if product != blank and product.available -%}
            <form method="post" action="{{ routes.cart_add_url }}" accept-charset="UTF-8">
              <input type="hidden" name="form_type" value="product">
              <input type="hidden" name="utf8" value="✓">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" class="btn {% if block.settings.featured %}btn--gold{% else %}btn--ghost{% endif %} btn--block btn--lg">
                {{ block.settings.cta_label | default: 'Get this plan' }}
              </button>
            </form>
          {%- else -%}
            <a href="{{ block.settings.cta_url | default: '#' }}" class="btn {% if block.settings.featured %}btn--gold{% else %}btn--ghost{% endif %} btn--block btn--lg">
              {{ block.settings.cta_label | default: 'Get this plan' }}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    <p class="reveal" style="margin-top:28px;color:var(--ink-faint);font-size:.9rem">{{ section.settings.footnote }}</p>
  </div>
</section>

{% raw %}
<style>
  #buyfx{position:fixed;inset:0;z-index:99999;display:none;place-items:center;text-align:center;background:radial-gradient(circle at 50% 38%,#2a1a4a,#0a0810 70%);overflow:hidden}
  #buyfx.on{display:grid}
  #buyfx .bfin{position:relative;z-index:2;padding:24px}
  #buyfx .fig{font-size:clamp(4rem,17vw,9rem);line-height:1;filter:drop-shadow(0 14px 34px rgba(0,0,0,.5));animation:bfp 1.1s ease-in-out infinite}
  @keyframes bfp{0%,100%{transform:scale(1)}50%{transform:scale(1.12)}}
  #buyfx .bfline{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:clamp(1.3rem,4.6vw,2.2rem);color:#fff;margin:22px auto 0;max-width:18ch;line-height:1.15;min-height:2.2em}
  #buyfx .bfbar{width:min(72vw,320px);height:8px;border-radius:999px;background:rgba(255,255,255,.14);overflow:hidden;margin:26px auto 0}
  #buyfx .bfbar i{display:block;height:100%;width:0;border-radius:999px;background:linear-gradient(90deg,#4de3ff,#ff5c8a,#7c5cff);transition:width .55s ease}
  #buyfx .bfsub{color:#cbb8ff;font-size:.86rem;margin-top:14px;font-family:var(--mono,monospace);letter-spacing:.04em}
  #buyfx .bfp{position:absolute;border-radius:50%;opacity:.8;animation:bfrise linear infinite}
  @keyframes bfrise{0%{transform:translateY(0) scale(1);opacity:0}10%{opacity:.85}100%{transform:translateY(-90vh) scale(.4);opacity:0}}
  @media (prefers-reduced-motion:reduce){#buyfx .fig{animation:none}}
</style>
<div id="buyfx" aria-hidden="true">
  <div class="bfparts" id="bfParts"></div>
  <div class="bfin">
    <div class="fig" id="bfFig">😮‍💨</div>
    <div class="bfline" id="bfLine">Taking a deep breath…</div>
    <div class="bfbar"><i id="bfBar"></i></div>
    <div class="bfsub">Securing your spot…</div>
  </div>
</div>
<script>
(function(){
  var fx=document.getElementById('buyfx');if(!fx)return;
  var fig=document.getElementById('bfFig'),line=document.getElementById('bfLine'),bar=document.getElementById('bfBar'),parts=document.getElementById('bfParts');
  var forms=[].slice.call(document.querySelectorAll('#pricing form'));
  var stages=[{e:'😮‍💨',t:'Taking a deep breath…'},{e:'🌫️',t:'Clearing the fog…'},{e:'⚡',t:'Switching your energy on…'},{e:'🔥',t:'Locking in your focus…'},{e:'😄',t:'You’re about to become a different person.'}];
  var cols=['#4de3ff','#ff5c8a','#7c5cff','#5ad48a','#2bd3c6'];
  function makeParts(){var h='';for(var i=0;i<26;i++){var sz=(5+Math.random()*9).toFixed(0);h+='<span class="bfp" style="left:'+Math.random()*100+'%;bottom:-20px;width:'+sz+'px;height:'+sz+'px;background:'+cols[i%5]+';animation-duration:'+(2.4+Math.random()*2).toFixed(1)+'s;animation-delay:'+(Math.random()*1.5).toFixed(1)+'s"></span>'}parts.innerHTML=h}
  function play(cb){fx.classList.add('on');makeParts();var i=0;bar.style.width='0%';
    function step(){if(i<stages.length){fig.textContent=stages[i].e;line.textContent=stages[i].t;bar.style.width=((i+1)/stages.length*100)+'%';i++;setTimeout(step,520)}else{setTimeout(cb,650)}}
    step();}
  forms.forEach(function(f){f.addEventListener('submit',function(e){if(f.getAttribute('data-go'))return;e.preventDefault();play(function(){f.setAttribute('data-go','1');f.submit()})})});
})();
</script>
<script>
(function(){
  [].slice.call(document.querySelectorAll('#pricing .fx__t')).forEach(function(b){
    b.addEventListener('click',function(){
      var li=b.parentNode,open=li.classList.toggle('open');
      b.setAttribute('aria-expanded',open?'true':'false');
    });
  });
})();
</script>
<script>
(function(){
  var el=document.getElementById('prCoachTxt');if(!el)return;
  var MSGS=[
    'Day 1 unlocks the second you pay ⚡',
    'I check in with you every day for 7 days 🤖',
    'Your streak starts tonight 🔥',
    'R199 once. No subscription. All yours.'
  ];
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if(reduce){el.textContent=MSGS[0];return}
  var mi=0,started=false;
  function typeMsg(msg,done){
    var i=0;el.textContent='';
    (function step(){
      if(i<msg.length){el.textContent+=msg.charAt(i++);setTimeout(step,34)}
      else{setTimeout(done,2600)}
    })();
  }
  function wipe(done){
    (function step(){
      var t=el.textContent;
      if(t.length){el.textContent=t.slice(0,-1);setTimeout(step,11)}
      else{done()}
    })();
  }
  function loop(){typeMsg(MSGS[mi%MSGS.length],function(){mi++;wipe(loop)})}
  function start(){if(started)return;started=true;loop()}
  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(es){es.forEach(function(en){if(en.isIntersecting){start();io.disconnect()}})},{threshold:.3});
    io.observe(el.parentNode);
  }else{start()}
})();
</script>
{% endraw %}

{% schema %}
{
  "name": "Pricing tiers",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Choose your escape" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three ways in. One direction — up." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Link each tier to a Shopify product to enable instant checkout, or leave it as a link." },
    { "type": "text", "id": "footnote", "label": "Footnote", "default": "All plans: instant access code by email · 7-day money-back guarantee · secure checkout." }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Tier",
      "settings": [
        { "type": "product", "id": "product", "label": "Linked Shopify product", "info": "If set, the price and a working buy button are used automatically." },
        { "type": "text", "id": "name", "label": "Name", "default": "ESCAPE PRO" },
        { "type": "text", "id": "tagline", "label": "Tagline", "default": "For people ready to commit" },
        { "type": "text", "id": "price", "label": "Price (if no product linked)", "default": "R299" },
        { "type": "text", "id": "price_suffix", "label": "Price suffix", "default": "once-off" },
        { "type": "textarea", "id": "features", "label": "Features (one per line)", "info": "Add ' | ' after a feature to attach a tap-for-more detail line.", "default": "Everything in Starter\n5 Bonus Kits\nWeekly Review + My Stats\nLetter to Future You\nPriority support" },
        { "type": "checkbox", "id": "featured", "label": "Highlight as most popular", "default": false },
        { "type": "text", "id": "badge", "label": "Badge text", "default": "Most popular" },
        { "type": "text", "id": "cta_label", "label": "Button label", "default": "Get this plan" },
        { "type": "url", "id": "cta_url", "label": "Button link (if no product)" }
