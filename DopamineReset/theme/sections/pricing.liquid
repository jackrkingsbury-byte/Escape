    }
  ],
  "max_blocks": 3,
  "presets": [{
    "name": "Pricing tiers",
    "blocks": [
      { "type": "tier", "settings": { "name": "ESCAPE Starter", "tagline": "Test the water", "price": "R149", "price_suffix": "once-off", "features": "Full ESCAPE core course\nDaily dares\nHabit tracker + notebook\nCertificate of completion", "featured": false, "cta_label": "Start with Starter" } },
      { "type": "tier", "settings": { "name": "ESCAPE PRO", "tagline": "For people ready to commit", "price": "R299", "price_suffix": "once-off", "features": "Everything in Starter\n5 Bonus Kits\nWeekly Review + My Stats\nLetter to Future You + 10 things you want\nPriority email support", "featured": true, "badge": "Most popular", "cta_label": "Get ESCAPE PRO" } },
      { "type": "tier", "settings": { "name": "Inner Circle", "tagline": "Lifetime · the whole-life upgrade", "price": "R599", "price_suffix": "lifetime", "features": "Everything in PRO\nGrade Forge bundled in\nLifetime access + every future drop\nFounding-member certificate badge", "featured": false, "cta_label": "Join the Inner Circle" } }
    ]
  }]
}
