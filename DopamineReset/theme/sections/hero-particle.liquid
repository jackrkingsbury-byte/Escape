{% raw %}
<style>
  .hp{position:relative;overflow:hidden;min-height:clamp(580px,94vh,880px);display:flex;align-items:center;background:radial-gradient(90% 95% at 70% 26%,#1b1233 0%,#0b0913 60%)}
  .hp__orbs{position:absolute;inset:0;z-index:0;overflow:hidden;pointer-events:none}
  .hp__orb{position:absolute;border-radius:50%;filter:blur(64px);opacity:.5;mix-blend-mode:screen;animation:hpo 16s ease-in-out infinite}
  .hp__orb.o1{width:36vmax;height:36vmax;background:radial-gradient(circle,#ff8a3d,transparent 65%);top:-10vmax;right:0}
  .hp__orb.o2{width:32vmax;height:32vmax;background:radial-gradient(circle,#7c5cff,transparent 65%);bottom:-12vmax;right:22vmax;animation-duration:21s}
  .hp__orb.o3{width:26vmax;height:26vmax;background:radial-gradient(circle,#2bd3c6,transparent 65%);top:28%;right:42%;animation-duration:24s}
  @keyframes hpo{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-3vmax,3vmax) scale(1.14)}}

  .hp__stage{position:absolute;top:0;right:0;bottom:0;width:56%;z-index:1}
  .hp__canvas{position:absolute;inset:0;width:100%;height:100%;display:block}
  .hp__fallback{position:absolute;inset:0;display:grid;place-items:center;z-index:0}
  .hp__fig{font-size:clamp(5rem,17vw,11rem);line-height:1;filter:drop-shadow(0 18px 40px rgba(0,0,0,.55));animation:hpfloat 5.5s ease-in-out infinite}
  .hp__halo{position:absolute;width:46%;aspect-ratio:1;border-radius:50%;filter:blur(34px);background:radial-gradient(circle,rgba(255,194,75,.4),rgba(124,92,255,.16) 50%,transparent 68%);animation:hppulse 5s ease-in-out infinite}
  @keyframes hpfloat{0%,100%{transform:translateY(0) rotate(0)}50%{transform:translateY(-16px) rotate(4deg)}}
  @keyframes hppulse{0%,100%{transform:scale(.85);opacity:.6}50%{transform:scale(1.08);opacity:.95}}

  .hp__scrim{position:absolute;inset:0;z-index:2;pointer-events:none;background:linear-gradient(90deg,rgba(8,6,12,.95) 0%,rgba(8,6,12,.74) 40%,rgba(8,6,12,.12) 70%,transparent 100%)}
  .hp__wrap{position:relative;z-index:3;max-width:1120px;margin:0 auto;padding:0 22px;width:100%}
  .hp__in{max-width:600px}
  .hp__scar{display:inline-flex;align-items:center;gap:8px;font-family:var(--mono,'JetBrains Mono',monospace);font-size:.78rem;color:#ffc24b;border:1px solid rgba(255,194,75,.4);border-radius:999px;padding:7px 15px;margin-bottom:18px;background:rgba(255,194,75,.05)}
  .hp__scar i{width:8px;height:8px;border-radius:50%;background:#5ad48a;box-shadow:0 0 0 0 rgba(90,212,138,.6);animation:hppi 2s infinite}
  @keyframes hppi{70%{box-shadow:0 0 0 9px rgba(90,212,138,0)}100%{box-shadow:0 0 0 0 rgba(90,212,138,0)}}
  .hp__eye{font-family:var(--mono,'JetBrains Mono',monospace);font-size:.72rem;letter-spacing:.3em;text-transform:uppercase;color:#ffc24b;margin:0 0 14px}
  .hp h1{font-family:var(--serif,'Fraunces',serif);font-weight:600;font-size:clamp(2.3rem,6.4vw,4.4rem);line-height:1.02;letter-spacing:-.02em;margin:0 0 18px;color:#fff}
  .hp__sub{color:#cfccc4;font-size:clamp(1.05rem,2.1vw,1.32rem);line-height:1.55;max-width:46ch;margin:0 0 30px}
  .hp__cta{display:flex;gap:13px;flex-wrap:wrap}
  .hp__btn{display:inline-flex;align-items:center;gap:8px;font-weight:800;border-radius:999px;padding:16px 32px;font-size:1.06rem;background:linear-gradient(135deg,#ffc24b,#ff8a3d);color:#2a1400;box-shadow:0 16px 40px rgba(255,138,61,.36);transition:transform .15s}
  .hp__btn:hover{transform:translateY(-2px)}
  .hp__btn--ghost{background:transparent;border:1px solid rgba(255,255,255,.22);color:#fff;box-shadow:none}
  .hp__btn--ghost:hover{border-color:#ffc24b;color:#ffc24b}
  .hp__trust{display:flex;gap:24px;flex-wrap:wrap;margin-top:34px;color:#8b877f;font-size:.9rem}
  .hp__trust b{color:#fff;font-family:var(--serif,'Fraunces',serif);font-size:1.05rem}
  .hp__state{position:absolute;bottom:18px;left:50%;transform:translateX(-50%);z-index:2;font-family:var(--mono,monospace);font-size:.66rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.5);transition:.4s}
  @media(max-width:820px){
    .hp{min-height:auto;padding:88px 0 36px}
    .hp__stage{position:relative;width:100%;height:48vh;order:-1}
    .hp__scrim{background:linear-gradient(180deg,transparent 0%,rgba(8,6,12,.35) 55%,#0b0913 100%)}
    .hp__in{max-width:100%}
  }
  @media (prefers-reduced-motion:reduce){.hp__fig,.hp__halo,.hp__orb{animation:none}}
</style>
{% endraw %}

<section class="hp" id="heroParticle">
  <div class="hp__orbs"><span class="hp__orb o1"></span><span class="hp__orb o2"></span><span class="hp__orb o3"></span></div>
  <div class="hp__stage" id="hpStage">
    <canvas class="hp__canvas" id="hpCanvas"></canvas>
    <div class="hp__fallback" id="hpFallback"><span class="hp__halo"></span><span class="hp__fig" id="hpFig">🧍</span></div>
    <div class="hp__state" id="hpState"></div>
  </div>
  <div class="hp__scrim"></div>
  <div class="hp__wrap"><div class="hp__in">
    {%- if section.settings.scarcity_label != blank -%}
      {%- assign ph = '{' | append: 'n' | append: '}' -%}
      <div class="hp__scar"><i></i> {{ section.settings.scarcity_label | replace: ph, section.settings.scarcity_base }}</div>
    {%- endif -%}
    <p class="hp__eye">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p class="hp__sub">{{ section.settings.subheading }}</p>
    <div class="hp__cta">
      <a class="hp__btn" href="{{ section.settings.cta1_url | default: '#pricing' }}">{{ section.settings.cta1_label }}</a>
      <a class="hp__btn hp__btn--ghost" href="{{ section.settings.cta2_url | default: '#why' }}">{{ section.settings.cta2_label }}</a>
    </div>
    <div class="hp__trust">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }}><b>{{ block.settings.stat }}</b> {{ block.settings.label }}</div>
      {%- endfor -%}
    </div>
  </div></div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
{% raw %}
<script>
(function(){
  var stage=document.getElementById('hpStage'),cv=document.getElementById('hpCanvas'),fb=document.getElementById('hpFallback'),stateEl=document.getElementById('hpState'),sec=document.getElementById('heroParticle');
  if(!stage||!cv)return;
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var THREE=window.THREE;
  function fail(){if(fb)fb.style.display='grid';}
  if(!THREE){fail();return;}
  try{var tc=document.createElement('canvas');if(!(tc.getContext('webgl')||tc.getContext('experimental-webgl'))){fail();return;}}catch(e){fail();return;}
  var renderer;try{renderer=new THREE.WebGLRenderer({canvas:cv,alpha:true,antialias:true});}catch(e){fail();return;}
  renderer.setPixelRatio(Math.min(window.devicePixelRatio||1,2));
  if(fb)fb.style.display='none';

  var scene=new THREE.Scene();
  var camera=new THREE.PerspectiveCamera(42,1,0.1,100);camera.position.set(0,1.04,3.3);camera.lookAt(0,1.02,0);
  var group=new THREE.Group();scene.add(group);

  // ---- humanoid skeleton: sad (slumped, grey) vs happy (upright, arms up, colour) ----
  var BONES=[
    {sa:[0,1.44,.20],sb:[0,1.63,.22], ha:[0,1.68,0], hb:[0,2.02,0], r:.30, w:3.2},   // head
    {sa:[0,0.90,.06],sb:[0,1.44,.13], ha:[0,1.00,0], hb:[0,1.66,0], r:.27, w:3.4},   // torso
    {sa:[0,0.82,0],  sb:[0,0.96,0],   ha:[0,0.90,0], hb:[0,1.04,0], r:.31, w:1.6},   // hips
    {sa:[-.24,1.40,.06],sb:[-.30,0.86,.14], ha:[-.26,1.56,0], hb:[-.92,2.06,0], r:.10, w:1.4}, // L arm
    {sa:[ .24,1.40,.06],sb:[ .30,0.86,.14], ha:[ .26,1.56,0], hb:[ .92,2.06,0], r:.10, w:1.4}, // R arm
    {sa:[-.16,0.82,0],sb:[-.20,0.0,0], ha:[-.17,0.90,0], hb:[-.22,0.0,0], r:.12, w:1.7},      // L leg
    {sa:[ .16,0.82,0],sb:[ .20,0.0,0], ha:[ .17,0.90,0], hb:[ .22,0.0,0], r:.12, w:1.7}       // R leg
  ];
  var N=Math.round((window.innerWidth<820?2600:4400));
  var FACE=window.innerWidth<820?110:170, TOT=N+FACE;
  var sumW=0;for(var b=0;b<BONES.length;b++)sumW+=BONES[b].w;
  var sadP=new Float32Array(TOT*3),hapP=new Float32Array(TOT*3),sadC=new Float32Array(TOT*3),hapC=new Float32Array(TOT*3),ph=new Float32Array(TOT);
  function lerp3(a,bb,t){return [a[0]+(bb[0]-a[0])*t,a[1]+(bb[1]-a[1])*t,a[2]+(bb[2]-a[2])*t]}
  var idx=0,col=new THREE.Color();
  for(var bi=0;bi<BONES.length;bi++){
    var bone=BONES[bi];var cnt=(bi===BONES.length-1)?(N-idx):Math.round(bone.w/sumW*N);
    for(var k=0;k<cnt && idx<N;k++){
      var t=Math.random();
      var u=Math.random()*2-1,th=Math.random()*6.2832,rr=bone.r*Math.cbrt(Math.random());
      var sq=Math.sqrt(1-u*u),ox=rr*sq*Math.cos(th),oy=rr*u,oz=rr*sq*Math.sin(th);
      var sp=lerp3(bone.sa,bone.sb,t),hp=lerp3(bone.ha,bone.hb,t);
      sadP[idx*3]=sp[0]+ox;sadP[idx*3+1]=sp[1]+oy;sadP[idx*3+2]=sp[2]+oz;
      hapP[idx*3]=hp[0]+ox;hapP[idx*3+1]=hp[1]+oy;hapP[idx*3+2]=hp[2]+oz;
      // sad colour: cold desaturated grey-blue
      var gnoise=0.42+Math.random()*0.12;sadC[idx*3]=gnoise*0.9;sadC[idx*3+1]=gnoise*0.95;sadC[idx*3+2]=gnoise*1.05;
      // happy colour: vibrant spectrum by height + spread
      var hue=( (hp[1]/2.1)*0.78 + (idx%60)/60*0.16 )%1;
      col.setHSL(hue,0.85,0.6);hapC[idx*3]=col.r;hapC[idx*3+1]=col.g;hapC[idx*3+2]=col.b;
      ph[idx]=Math.random()*6.2832;idx++;
    }
  }
  // ---- glowing face: eyes + smile that light up only when happy ----
  var hcS=[0,1.535,0.21],hcH=[0,1.85,0],fc=N;
  function putFace(fx,fy,fz,br){sadP[fc*3]=hcS[0]+fx;sadP[fc*3+1]=hcS[1]+fy;sadP[fc*3+2]=hcS[2]+fz;hapP[fc*3]=hcH[0]+fx;hapP[fc*3+1]=hcH[1]+fy;hapP[fc*3+2]=hcH[2]+fz;sadC[fc*3]=0.04;sadC[fc*3+1]=0.04;sadC[fc*3+2]=0.05;hapC[fc*3]=br[0];hapC[fc*3+1]=br[1];hapC[fc*3+2]=br[2];ph[fc]=Math.random()*6.2832;fc++;}
  var EY=22;
  for(var e=0;e<EY;e++){var a=Math.random()*6.2832,rE=0.03*Math.sqrt(Math.random());putFace(-0.10+Math.cos(a)*rE,0.075+Math.sin(a)*rE,0.27,[1,1,1]);}
  for(var e2=0;e2<EY;e2++){var a2=Math.random()*6.2832,rE2=0.03*Math.sqrt(Math.random());putFace(0.10+Math.cos(a2)*rE2,0.075+Math.sin(a2)*rE2,0.27,[1,1,1]);}
  var smileN=TOT-fc;for(var s=0;s<smileN;s++){var xx=-0.13+(s/(smileN-1))*0.26;var yy=-0.03+0.055*Math.pow(xx/0.13,2)+(Math.random()-0.5)*0.012;putFace(xx,yy,0.27,[1,0.94,0.74]);}
  var pos=new Float32Array(TOT*3),cur=new Float32Array(TOT*3);
  for(var i0=0;i0<TOT*3;i0++){pos[i0]=sadP[i0];cur[i0]=sadC[i0];}
  var geo=new THREE.BufferGeometry();
  geo.setAttribute('position',new THREE.BufferAttribute(pos,3));
  geo.setAttribute('color',new THREE.BufferAttribute(cur,3));
  var mat=new THREE.PointsMaterial({size:0.035,vertexColors:true,transparent:true,opacity:0.96,blending:THREE.AdditiveBlending,depthWrite:false,sizeAttenuation:true});
  var human=new THREE.Points(geo,mat);group.add(human);

  // ---- colour sparkle aura (intensifies as it gets happy) ----
  var M=window.innerWidth<820?260:520,sp2=new Float32Array(M*3),sc2=new Float32Array(M*3),sv=new Float32Array(M);
  for(var m=0;m<M;m++){var ang=Math.random()*6.2832,rad=0.5+Math.random()*1.3;
    sp2[m*3]=Math.cos(ang)*rad;sp2[m*3+1]=Math.random()*2.2;sp2[m*3+2]=Math.sin(ang)*rad*0.7;
    col.setHSL(Math.random(),0.9,0.62);sc2[m*3]=col.r;sc2[m*3+1]=col.g;sc2[m*3+2]=col.b;sv[m]=0.15+Math.random()*0.5;}
  var g2=new THREE.BufferGeometry();g2.setAttribute('position',new THREE.BufferAttribute(sp2,3));g2.setAttribute('color',new THREE.BufferAttribute(sc2,3));
  var m2=new THREE.PointsMaterial({size:0.045,vertexColors:true,transparent:true,opacity:0,blending:THREE.AdditiveBlending,depthWrite:false});
  var aura=new THREE.Points(g2,m2);group.add(aura);

  // ground glow disc
  var disc=new THREE.Mesh(new THREE.CircleGeometry(1.1,40),new THREE.MeshBasicMaterial({color:0x7c5cff,transparent:true,opacity:0.0,blending:THREE.AdditiveBlending,depthWrite:false}));
  disc.rotation.x=-Math.PI/2;disc.position.y=0.01;group.add(disc);

  function size(){var w=stage.clientWidth||1,h=stage.clientHeight||1;renderer.setSize(w,h,false);camera.aspect=w/h;camera.updateProjectionMatrix();}
  window.addEventListener('resize',size);size();

  var px=0,tpx=0;
  window.addEventListener('pointermove',function(e){tpx=(e.clientX/window.innerWidth-0.5)});

  var STATES=['Tired','Distracted','Hopeful','Confident','Happy'];
  var t0=Date.now(),last=t0,rawT=0,lastP=-1,parr=geo.attributes.position.array,carr=geo.attributes.color.array;
  function sstep(x){x=x<0?0:x>1?1:x;return x*x*(3-2*x)}
  function frame(){
    requestAnimationFrame(frame);
    var now=Date.now(),dt=Math.min((now-last)/1000,0.05);last=now;var tt=(now-t0)/1000;
    if(!reduce)rawT+=dt;
    // progress: auto-play sad->happy over ~5.5s, then hold; scroll can also push it
    var sc=0;var r=sec.getBoundingClientRect();sc=(-r.top)/(window.innerHeight*0.9);if(sc<0)sc=0;if(sc>1)sc=1;
    var cyc=(rawT%9)/9,autoOsc=cyc<0.55?sstep(cyc/0.55):(cyc<0.78?1:1-sstep((cyc-0.78)/0.22));
    var p=Math.max(autoOsc,sc);if(reduce)p=1;
    // breathing + arm-raise overshoot feel
    var breathe=reduce?0:Math.sin(tt*1.5)*0.012*p;
    if(Math.abs(p-lastP)>0.0015){
      for(var i=0;i<TOT;i++){
        var sh=reduce?0:Math.sin(tt*2.0+ph[i])*0.012*(0.3+p*0.7);
        parr[i*3]  =sadP[i*3]  +(hapP[i*3]  -sadP[i*3])  *p + sh*0.4;
        parr[i*3+1]=sadP[i*3+1]+(hapP[i*3+1]-sadP[i*3+1])*p + breathe + sh*0.2;
        parr[i*3+2]=sadP[i*3+2]+(hapP[i*3+2]-sadP[i*3+2])*p;
        carr[i*3]  =sadC[i*3]  +(hapC[i*3]  -sadC[i*3])  *p;
        carr[i*3+1]=sadC[i*3+1]+(hapC[i*3+1]-sadC[i*3+1])*p;
        carr[i*3+2]=sadC[i*3+2]+(hapC[i*3+2]-sadC[i*3+2])*p;
      }
      geo.attributes.position.needsUpdate=true;geo.attributes.color.needsUpdate=true;
      lastP=p;
      if(stateEl){var si=Math.min(STATES.length-1,Math.floor(p*STATES.length));stateEl.textContent=STATES[si];}
    }
    // aura rises + brightens with happiness
    var ap=g2.attributes.position.array;for(var a=0;a<M;a++){ap[a*3+1]+=dt*(0.2+sv[a]);if(ap[a*3+1]>2.3)ap[a*3+1]=0;}g2.attributes.position.needsUpdate=true;
    m2.opacity=p*0.85;disc.material.opacity=p*0.28;disc.scale.setScalar(0.8+p*0.5);
    px+=(tpx-px)*0.05;
    group.rotation.y=px*0.6+(reduce?0:Math.sin(tt*0.3)*0.12);
    renderer.render(scene,camera);
  }
  frame();
})();
</script>
{% endraw %}

{% schema %}
{
  "name": "Hero 3D Particle",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Your brain is fried. Here's the reset." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Quit cheap dopamine. Feel good for real — in 7 days." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Endless scrolling fried your reward system, so nothing feels good anymore. The Dopamine Reset rewires it in a week — 10 minutes a day." },
    { "type": "text", "id": "cta1_label", "label": "Primary CTA", "default": "Start the reset — R199" },
    { "type": "url", "id": "cta1_url", "label": "Primary CTA link" },
    { "type": "text", "id": "cta2_label", "label": "Secondary CTA", "default": "Why it works" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA link" },
    { "type": "text", "id": "scarcity_label", "label": "Scarcity text (n = number)", "default": "Only {n} resets left at the R199 launch price" },
    { "type": "number", "id": "scarcity_base", "label": "Number", "default": 40 }
  ],
  "blocks": [
    { "type": "stat", "name": "Trust stat", "settings": [
      { "type": "text", "id": "stat", "label": "Number", "default": "7 days" },
      { "type": "text", "id": "label", "label": "Label", "default": "to feel it" }
    ]}
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Hero 3D Particle" }]
}
{% endschema %}
