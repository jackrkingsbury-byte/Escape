<section class="section">
  <div class="wrap">
    <div class="page-head"><p class="eyebrow">Almost there</p><h1>Your cart</h1></div>
    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" novalidate>
        <table class="cart-table">
          <thead><tr><th>Plan</th><th>Qty</th><th>Total</th></tr></thead>
          <tbody>
            {%- for item in cart.items -%}
              <tr>
                <td><b>{{ item.product.title }}</b>{% unless item.variant.title contains 'Default' %}<br><small style="color:var(--ink-faint)">{{ item.variant.title }}</small>{% endunless %}</td>
                <td>
                  <input type="number" min="0" name="updates[]" value="{{ item.quantity }}" style="width:64px;padding:8px;border-radius:8px;background:var(--bg-2);color:var(--ink);border:1px solid var(--line)">
                </td>
                <td>{{ item.final_line_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
        <div class="cart-foot">
          <button type="submit" name="update" class="btn btn--ghost">Update cart</button>
          <div style="text-align:right">
            <div style="color:var(--ink-faint);font-size:.9rem">Subtotal</div>
            <div style="font-family:var(--serif);font-size:1.8rem;color:var(--gold)">{{ cart.total_price | money }}</div>
          </div>
        </div>
        <div style="margin-top:20px;text-align:right">
          <button type="submit" name="checkout" class="btn btn--gold btn--lg">Checkout securely →</button>
        </div>
      </form>
    {%- else -%}
      <p>Your cart is empty.</p>
      <a class="btn btn--gold btn--lg" href="{{ routes.root_url }}#pricing">See the plans</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}
