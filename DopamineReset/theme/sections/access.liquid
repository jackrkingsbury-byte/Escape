    for(var d=1;d<=days;d++){var on=state.dates[y+'-'+(m+1)+'-'+d];h+='<span class="cal__c'+(on?' on':'')+(d===now.getDate()?' today':'')+'">'+d+'</span>'}
    el.innerHTML=h+'</div>';}
  function renderXpSrc(){var el=$('#xpSrc');if(!el)return;var src=[['7-day plan',dc()*30,'var(--amber)'],['Mind games',gp()*15,'var(--teal)'],['Articles',rd()*20,'var(--blue)'],['Check-ins',ck()*10,'var(--pink)'],['Cravings beaten',state.crave*5,'var(--orange)'],['Daily wins',state.wins.length*5,'var(--good)']];
    var max=1;for(var i=0;i<src.length;i++)if(src[i][1]>max)max=src[i][1];
    el.innerHTML='<div class="xps">'+src.map(function(s){return '<div class="xps__row"><div class="l"><span>'+s[0]+'</span><b>'+s[1]+' XP</b></div><div class="xps__bar"><i style="width:'+(s[1]/max*100)+'%;background:'+s[2]+'"></i></div></div>'}).join('')+'</div>';}
  var setThemes=$('#setThemes'),setAva=$('#setAva');
  if(setThemes)setThemes.innerHTML='<div class="setsw">'+THM.map(function(t){return '<div class="setsw__s'+((state.onb&&state.onb.theme===t.k)?' sel':'')+'" data-settheme="'+t.k+'" style="background:linear-gradient(135deg,'+t.a+','+t.v+')">'+t.n+'</div>'}).join('')+'</div>';
  if(setAva)setAva.innerHTML='<div class="setava">'+AVA.map(function(a){return '<button data-setava="'+a+'"'+(((state.onb&&state.onb.avatar)===a)?' class="sel"':'')+'>'+a+'</button>'}).join('')+'</div>';
  function updSnd(){var b=$('#sndToggle');if(b)b.textContent='Sound: '+(state.sound?'On':'Off')}updSnd();
  document.addEventListener('click',function(e){
    var st=e.target.closest('[data-settheme]');if(st){var k=st.getAttribute('data-settheme');if(!state.onb)state.onb={done:true};state.onb.theme=k;save();applyTheme(thmByKey(k));$$('[data-settheme]').forEach(function(x){x.classList.toggle('sel',x===st)});toast('🎨 Theme updated');return}
    var sa=e.target.closest('[data-setava]');if(sa){var av=sa.getAttribute('data-setava');if(!state.onb)state.onb={done:true};state.onb.avatar=av;save();applyAvatar(av);$$('[data-setava]').forEach(function(x){x.classList.toggle('sel',x===sa)});return}
    if(e.target.closest('#sndToggle')){state.sound=!state.sound;save();updSnd();if(state.sound)snd('win');return}
    if(e.target.closest('#replayOnb')){openOnb();return}
  });

  // ===== easy quick-actions hub + floating "What now?" =====
  var ACTS=[
    {e:'🔥',k:'today',t:"Today's challenge",s:'Your 10-min win',g:'linear-gradient(135deg,#ff8a3d,#ffc24b)'},
    {e:'🌊',k:'breathe',t:'Calm an urge',s:'Breathe for 60s',g:'linear-gradient(135deg,#2bd3c6,#4f8cff)'},
    {e:'🎮',k:'games',t:'Play a game',s:'Reset your brain',g:'linear-gradient(135deg,#7c5cff,#ff5c8a)'},
    {e:'💗',k:'journeys',t:'How I feel',s:'Get the right help',g:'linear-gradient(135deg,#ff5c8a,#7c5cff)'},
    {e:'📖',k:'articles',t:'Read something',s:'Quick 2-min reads',g:'linear-gradient(135deg,#2bd3c6,#4f8cff)'},
    {e:'🧘',k:'relax',t:'Help me relax',s:'Wind down',g:'linear-gradient(135deg,#4f8cff,#7c5cff)'},
    {e:'📜',k:'quotes',t:'Give me a boost',s:'A line to carry',g:'linear-gradient(135deg,#ffd24b,#ff8a3d)'},
    {e:'✍️',k:'journal',t:'Journal it',s:'One honest line',g:'linear-gradient(135deg,#5ad48a,#bfe65a)'},
    {e:'📊',k:'stats',t:'My progress',s:'See how far you are',g:'linear-gradient(135deg,#ff6b6b,#ff8a3d)'},
    {e:'🎲',k:'random',t:'Surprise me',s:"I'll pick for you",g:'linear-gradient(135deg,#7c5cff,#2bd3c6)'}
  ];
  window.ACTS=ACTS;
  function actIdx(k){for(var i=0;i<ACTS.length;i++)if(ACTS[i].k===k)return i;return 0}
  function actCard(a,i){return '<div class="doCard" data-act="'+i+'"><div class="bg" style="background:'+a.g+'"></div><span class="e">'+a.e+'</span><b>'+a.t+'</b><span>'+a.s+'</span></div>'}
  (function(){var h=ACTS.map(actCard).join('');if($('#doGrid'))$('#doGrid').innerHTML=h;if($('#quickGrid'))$('#quickGrid').innerHTML=h;})();
  function routeAct(k){
    if(k==='today'){openDay(cur());return}
    if(k==='breathe'){openGame('breathe');return}
    if(k==='random'){var pool=['games','journeys','articles','relax','quotes','journal','breathe','today'];routeAct(pool[Math.floor(Math.random()*pool.length)]);return}
    var b=document.querySelector('.dr__nav[data-go="'+k+'"]');if(b)b.click();
  }
  function openQuick(){var q=$('#drQuick');if(q)q.classList.add('on')}
  function closeQuick(){var q=$('#drQuick');if(q)q.classList.remove('on')}
  document.addEventListener('click',function(e){
    var ac=e.target.closest('[data-act]');if(ac){closeQuick();routeAct(ACTS[+ac.getAttribute('data-act')].k);return}
    if(e.target.closest('#drFab')){openQuick();return}
    if(e.target.closest('#quickClose')){closeQuick();return}
    if(e.target.id==='drQuick'){closeQuick();return}
  });

  render();renderArts();revealPanel('today');
  if(!state.onb||!state.onb.done)openOnb();
}catch(err){
  try{var m=document.querySelector('.dr__main');if(m)m.insertAdjacentHTML('afterbegin','<div style="background:#15121d;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:20px;margin-bottom:14px;color:#f6f4ef"><b>Your reset is loaded.</b><p style="color:#b8b4ad;margin:6px 0 0">A small visual hiccup happened — tap a menu item on the left to jump in.</p></div>')}catch(e){}
}
})();
</script>
