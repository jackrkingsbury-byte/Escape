{% raw %}
<style>
  .dr{--bg:#0c0a12;--bg2:#15121d;--bg3:#1b1727;--ink:#f6f4ef;--soft:#b8b4ad;--faint:#7e7a73;
      --line:rgba(255,255,255,.09);--line2:rgba(255,255,255,.05);--amber:#ffc24b;--orange:#ff8a3d;
      --pink:#ff5c8a;--violet:#7c5cff;--good:#5ad48a;--r:18px;
      --serif:'Fraunces',Georgia,serif;--sans:'Hanken Grotesk',system-ui,sans-serif;--mono:'JetBrains Mono',monospace;}
  .dr *{box-sizing:border-box}
  .dr{font-family:var(--sans);color:var(--ink);background:var(--bg);min-height:100vh;display:grid;grid-template-columns:260px 1fr}
  .dr a{color:inherit;text-decoration:none}.dr button{font-family:inherit;cursor:pointer;border:0;background:none;color:inherit}

  .dr__side{background:linear-gradient(180deg,var(--bg2),var(--bg));border-right:1px solid var(--line);padding:24px 16px;position:sticky;top:0;height:100vh;display:flex;flex-direction:column;gap:5px}
  .dr__brand{font-family:var(--serif);font-weight:700;font-size:1.35rem;padding:6px 12px 14px}.dr__brand b{color:var(--amber)}
  .dr__navttl{font-family:var(--mono);font-size:.6rem;letter-spacing:.26em;text-transform:uppercase;color:var(--faint);padding:12px 12px 4px}
  .dr__nav{display:flex;align-items:center;gap:12px;padding:11px 14px;border-radius:12px;color:var(--soft);font-weight:600;font-size:.94rem;width:100%;text-align:left;transition:.15s}
  .dr__nav .ic{font-size:1.1rem;width:22px;text-align:center}.dr__nav:hover{background:var(--bg3);color:var(--ink)}
  .dr__nav.on{background:linear-gradient(135deg,rgba(255,194,75,.16),rgba(255,92,138,.12));color:var(--ink)}
  .dr__foot{margin-top:auto;padding:12px;border-top:1px solid var(--line2);color:var(--faint);font-size:.76rem}

  .dr__main{padding:clamp(18px,4vw,40px);max-width:1000px}
  .dr__top{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:10px;flex-wrap:wrap}
  .dr__pills{display:flex;gap:8px;flex-wrap:wrap}
  .dr__pill{display:inline-flex;align-items:center;gap:6px;background:var(--bg2);border:1px solid var(--line);border-radius:999px;padding:7px 13px;font-size:.8rem;color:var(--soft)}
  .dr__pill b{color:var(--ink);font-family:var(--mono)}
  .dr h1{font-family:var(--serif);font-size:clamp(1.7rem,4.4vw,2.5rem);font-weight:600;line-height:1.05;margin:4px 0}
  .dr h2{font-family:var(--serif);font-size:1.35rem;margin:0 0 4px}.dr h3{font-size:1.02rem;margin:0 0 6px}
  .dr p{color:var(--soft);line-height:1.55;margin:0 0 12px}
  .dr .eyebrow{font-family:var(--mono);font-size:.64rem;letter-spacing:.22em;text-transform:uppercase;color:var(--amber);margin-bottom:8px}
  .dr .panel{display:none;animation:fade .3s ease}.dr .panel.on{display:block}
  @keyframes fade{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

  /* thumbnail grid — TikTok-style */
  .dr .feed{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:14px;margin:16px 0}
  .dr .thumb{position:relative;border-radius:var(--r);overflow:hidden;aspect-ratio:3/4;border:1px solid var(--line);cursor:pointer;transition:transform .18s,box-shadow .18s;display:flex;flex-direction:column;justify-content:flex-end}
  .dr .thumb:hover{transform:translateY(-4px) scale(1.01);box-shadow:0 18px 40px rgba(0,0,0,.45)}
  .dr .thumb__bg{position:absolute;inset:0;z-index:0}
  .dr .thumb__emoji{position:absolute;top:14px;left:16px;font-size:2.6rem;z-index:1;filter:drop-shadow(0 2px 8px rgba(0,0,0,.4))}
  .dr .thumb__tag{position:absolute;top:14px;right:14px;z-index:1;background:rgba(0,0,0,.35);backdrop-filter:blur(4px);border-radius:999px;padding:5px 11px;font-family:var(--mono);font-size:.66rem;letter-spacing:.06em;color:#fff}
  .dr .thumb__cap{position:relative;z-index:1;padding:14px;background:linear-gradient(180deg,transparent,rgba(0,0,0,.55))}
  .dr .thumb__cap b{display:block;font-family:var(--serif);font-size:1.05rem;line-height:1.15;color:#fff}
  .dr .thumb__cap span{font-size:.76rem;color:rgba(255,255,255,.8)}
  .dr .thumb.done::after{content:"✓ done";position:absolute;inset:0;z-index:2;display:grid;place-items:center;background:rgba(8,36,15,.55);color:#fff;font-weight:800;font-family:var(--mono);letter-spacing:.1em}
  .dr .thumb.locked{cursor:not-allowed}
  .dr .thumb.locked::after{content:"🔒";position:absolute;inset:0;z-index:2;display:grid;place-items:center;background:rgba(0,0,0,.55);font-size:1.6rem}

  .dr .tiles{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:12px;margin:16px 0}
  .dr .tile{position:relative;border-radius:14px;overflow:hidden;aspect-ratio:1;cursor:pointer;display:grid;place-items:center;text-align:center;padding:12px;border:1px solid var(--line);transition:transform .15s}
  .dr .tile:hover{transform:translateY(-3px)}
  .dr .tile__bg{position:absolute;inset:0;z-index:0;opacity:.9}
  .dr .tile__in{position:relative;z-index:1}.dr .tile__in .e{font-size:1.9rem;display:block}.dr .tile__in b{font-size:.82rem;color:#fff;display:block;margin-top:6px;text-shadow:0 1px 6px rgba(0,0,0,.5)}

  .dr .card{background:var(--bg2);border:1px solid var(--line);border-radius:var(--r);padding:20px;margin:14px 0}
  .dr .card--hero{position:relative;overflow:hidden;border-color:rgba(255,194,75,.3)}
  .dr .card--hero .hbg{position:absolute;inset:0;z-index:0;opacity:.95}
  .dr .card--hero>*{position:relative;z-index:1}
  .dr .card--hero h2,.dr .card--hero p,.dr .card--hero .eyebrow{color:#fff}.dr .card--hero .eyebrow{color:#fff;opacity:.85}
  .dr .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-weight:800;border-radius:999px;padding:13px 24px;background:#fff;color:#2a1400;transition:transform .15s}
  .dr .btn:active{transform:scale(.97)}
  .dr .btn--g{background:linear-gradient(135deg,var(--amber),var(--orange));color:#2a1400}
  .dr .btn--ghost{background:transparent;border:1px solid rgba(255,255,255,.4);color:#fff}
  .dr .btn--sm{padding:9px 16px;font-size:.84rem}
  .dr .btn[disabled]{opacity:.55;pointer-events:none}

  .dr .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;margin:14px 0}
  .dr .stat{background:var(--bg2);border:1px solid var(--line);border-radius:14px;padding:16px}
  .dr .stat .big{font-family:var(--serif);font-size:2rem;color:var(--amber);line-height:1}.dr .stat .lbl{color:var(--faint);font-size:.8rem;margin-top:5px}
  .dr .bar{height:10px;border-radius:999px;background:var(--bg3);overflow:hidden;margin:8px 0}.dr .bar i{display:block;height:100%;background:linear-gradient(90deg,var(--amber),var(--pink));width:0;transition:width .6s}
  .dr ul.tick{list-style:none;padding:0;margin:8px 0}.dr ul.tick li{padding:9px 0 9px 26px;position:relative;color:var(--soft);border-top:1px solid var(--line2)}
  .dr ul.tick li:first-child{border:0}.dr ul.tick li::before{content:"✓";position:absolute;left:0;color:var(--good);font-weight:800}
  .dr textarea{width:100%;min-height:150px;background:var(--bg2);border:1px solid var(--line);border-radius:14px;color:var(--ink);padding:15px;font:inherit;resize:vertical}
  .dr .saved{font-size:.8rem;color:var(--good);opacity:0;transition:.3s}.dr .saved.on{opacity:1}

  /* modal */
  .dr__modal{position:fixed;inset:0;z-index:80;display:none;align-items:center;justify-content:center;padding:18px;background:rgba(5,4,8,.7);backdrop-filter:blur(6px)}
  .dr__modal.on{display:flex;animation:fade .25s}
  .dr__sheet{background:var(--bg2);border:1px solid var(--line);border-radius:22px;max-width:460px;width:100%;overflow:hidden;max-height:90vh;display:flex;flex-direction:column}
  .dr__sheet .top{position:relative;height:170px;display:grid;place-items:center}
  .dr__sheet .top .e{font-size:4rem;filter:drop-shadow(0 4px 12px rgba(0,0,0,.4))}
  .dr__sheet .x{position:absolute;top:12px;right:12px;width:34px;height:34px;border-radius:50%;background:rgba(0,0,0,.4);color:#fff;display:grid;place-items:center;font-size:1.1rem}
  .dr__sheet .body{padding:22px;overflow:auto}
  .dr__sheet .body h2{margin-bottom:8px}

  .dr__menu{display:none}
  @media(max-width:820px){
    .dr{grid-template-columns:1fr}
    .dr__side{position:fixed;inset:0 28% 0 0;z-index:90;transform:translateX(-105%);transition:transform .25s}.dr__side.open{transform:none}
    .dr__menu{display:inline-flex;align-items:center;gap:6px;font-weight:700;background:var(--bg2);border:1px solid var(--line);border-radius:999px;padding:8px 14px}
    .dr__scrim{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:85}.dr__scrim.on{display:block}
  }
  .dr .brz{display:grid;place-items:center;padding:26px 0}
  .dr .brz__c{width:210px;height:210px;border-radius:50%;background:radial-gradient(circle,rgba(255,194,75,.4),rgba(124,92,255,.14));border:1px solid rgba(255,255,255,.14);display:grid;place-items:center;font-weight:800;font-size:1.15rem;color:#fff;text-shadow:0 2px 8px rgba(0,0,0,.4);animation:brz 11s ease-in-out infinite}
  @keyframes brz{0%,100%{transform:scale(.78)}45%,55%{transform:scale(1.28)}}
  @media (prefers-reduced-motion:reduce){.dr .brz__c{animation:none}}
  .dr .moods{display:flex;gap:10px;flex-wrap:wrap;margin:16px 0}
  .dr .moodb{font-size:2rem;width:64px;height:64px;border-radius:16px;background:var(--bg2);border:1px solid var(--line);transition:.15s}
  .dr .moodb:hover,.dr .moodb.on{transform:translateY(-3px);border-color:var(--amber);background:var(--bg3)}
  .dr .moodlog{display:flex;gap:8px;flex-wrap:wrap;font-size:1.5rem}
</style>

<div class="dr" id="drApp">
  <aside class="dr__side" id="drSide">
    <div class="dr__brand">Dopamine<b>.</b>Reset</div>
    <div class="dr__navttl">Your reset</div>
    <button class="dr__nav on" data-go="today"><span class="ic">🔥</span> Today</button>
    <button class="dr__nav" data-go="plan"><span class="ic">🗓️</span> The 7 Days</button>
    <button class="dr__nav" data-go="track"><span class="ic">✅</span> Tracker</button>
    <button class="dr__nav" data-go="stats"><span class="ic">📈</span> My Stats</button>
    <div class="dr__navttl">Tools</div>
    <button class="dr__nav" data-go="toolkit"><span class="ic">🌊</span> Urge Toolkit</button>
    <button class="dr__nav" data-go="menu"><span class="ic">☀️</span> Dopamine Menu</button>
    <button class="dr__nav" data-go="breathe"><span class="ic">🫁</span> Breathe</button>
    <button class="dr__nav" data-go="mood"><span class="ic">😊</span> Mood</button>
    <button class="dr__nav" data-go="journal"><span class="ic">📓</span> Journal</button>
    <button class="dr__nav" data-go="help"><span class="ic">💬</span> Help</button>
    <div class="dr__foot">Bookmark this — it's your home base for 7 days.</div>
  </aside>
  <div class="dr__scrim" id="drScrim"></div>

  <main class="dr__main">
    <div class="dr__top">
      <button class="dr__menu" id="drBurger">☰ Menu</button>
      <div class="dr__pills">
        <span class="dr__pill">🔥 Streak <b id="pStreak">0</b></span>
        <span class="dr__pill">Day <b id="pDay">1</b>/7</span>
        <span class="dr__pill">⚡ <b id="pCrave">0</b> beaten</span>
      </div>
    </div>

    <section class="panel on" data-p="today">
      <h1>You're in. Tap to begin. 👇</h1>
      <p>Do one thing a day for 7 days. Tap today's card to open it.</p>
      <div class="card card--hero" id="todayCard">
        <div class="hbg" id="todayBg"></div>
        <div class="eyebrow">Today · <span id="tLabel">Day 1</span></div>
        <h2 id="tTitle">Delete the worst one.</h2>
        <p id="tAction"></p>
        <button class="btn btn--g" id="tDone">Mark today done ✓</button>
        <button class="btn btn--ghost btn--sm" data-go="plan" style="margin-left:8px">See all 7 →</button>
      </div>
      <div class="stats">
        <div class="stat"><div class="big" id="t1">0</div><div class="lbl">days done</div></div>
        <div class="stat"><div class="big" id="t2">0</div><div class="lbl">streak</div></div>
        <div class="stat"><div class="big" id="t3">0%</div><div class="lbl">complete</div></div>
      </div>
    </section>

    <section class="panel" data-p="plan">
      <h1>The 7 days</h1>
      <p>Tap a card to open it. Days unlock one at a time — the order is the point.</p>
      <div class="feed" id="dayFeed"></div>
    </section>

    <section class="panel" data-p="track">
      <h1>Tracker</h1>
      <p>Tap a day card to complete it. Your streak builds as you go.</p>
      <div class="feed" id="trackFeed"></div>
      <div class="card"><h3>Streak</h3><div class="bar"><i id="trackBar"></i></div><p id="trackMsg" style="margin:0"></p></div>
    </section>

    <section class="panel" data-p="stats">
      <h1>My stats</h1>
      <div class="stats">
        <div class="stat"><div class="big" id="sA">0</div><div class="lbl">days done</div></div>
        <div class="stat"><div class="big" id="sB">0</div><div class="lbl">streak</div></div>
        <div class="stat"><div class="big" id="sC">0%</div><div class="lbl">progress</div></div>
        <div class="stat"><div class="big" id="sD">0</div><div class="lbl">cravings beaten</div></div>
      </div>
      <div class="card"><h3>Progress to a rewired brain</h3><div class="bar"><i id="sBar"></i></div><p id="sMsg" style="margin:0">Every day you finish rewires your reward system a little more.</p></div>
    </section>

    <section class="panel" data-p="toolkit">
      <h1>Urge toolkit</h1>
      <p>Craving to scroll? Tap a tile, do it for 90 seconds, beat the urge.</p>
      <div class="tiles" id="urgeTiles"></div>
      <button class="btn btn--g btn--sm" id="craveBtn">I beat a craving 💪</button>
      <span style="margin-left:10px;color:var(--faint)">Beaten: <b id="craveCount">0</b></span>
    </section>

    <section class="panel" data-p="menu">
      <h1>Dopamine menu</h1>
      <p>Bored? Tap a tile and just do it. Or roll the dice.</p>
      <button class="btn btn--g" id="rollBtn">🎲 Surprise me</button>
      <div class="tiles" id="menuTiles"></div>
    </section>

    <section class="panel" data-p="breathe">
      <h1>Breathe</h1>
      <p>Craving hitting hard? Breathe <span style="color:#ffc24b">with the circle</span> for one minute — it physically calms the urge. In as it grows, out as it shrinks.</p>
      <div class="brz"><div class="brz__c" id="brzC">Breathe in</div></div>
      <p style="text-align:center;color:var(--faint)">One minute here beats ten minutes scrolling.</p>
    </section>

    <section class="panel" data-p="mood">
      <h1>How do you feel?</h1>
      <p>Tap your mood each day. Watch it <span style="color:#ff5c8a">climb</span> as the reset works — your happiness, tracked.</p>
      <div class="moods" id="moodBtns"></div>
      <div class="card"><h3>Your mood this week</h3><div class="moodlog" id="moodLog"></div><p id="moodMsg" style="margin:10px 0 0"></p></div>
    </section>

    <section class="panel" data-p="journal">
      <h1>Journal</h1>
      <p>One honest line a day. Saves on this device automatically.</p>
      <textarea id="journal" placeholder="Day 1 — didn't touch my phone for the first hour. Felt weird. Good weird."></textarea>
      <div style="margin-top:10px"><button class="btn btn--g btn--sm" id="jSave">Save</button> <span class="saved" id="jSaved">Saved ✓</span></div>
    </section>

    <section class="panel" data-p="help">
      <h1>The rules &amp; help</h1>
      <div class="card"><h3>The cheap-dopamine fast</h3>
        <ul class="tick"><li>No phone for the first hour after waking</li><li>No short-form video for 7 days</li><li>Notifications off except calls &amp; texts</li><li>One "boring on purpose" 10-min block daily</li></ul></div>
      <div class="card"><h3>Need a hand?</h3><p style="margin:0">Reply to your order confirmation email and we'll help. You've got this. 💪</p></div>
    </section>
  </main>
</div>

<div class="dr__modal" id="drModal"><div class="dr__sheet">
  <div class="top" id="mTop"><span class="e" id="mEmoji">🔥</span><button class="x" id="mClose">✕</button></div>
  <div class="body"><div class="eyebrow" id="mTag">Day 1</div><h2 id="mTitle"></h2><p id="mBody"></p><div id="mAction"></div></div>
</div></div>

<script>
(function(){
  var $=function(s,r){return (r||document).querySelector(s)},$$=function(s,r){return [].slice.call((r||document).querySelectorAll(s))};
  var KEY='dr_reset_v2',state=load();
  var GRADS=['linear-gradient(135deg,#ff8a3d,#ffc24b)','linear-gradient(135deg,#ff5c8a,#7c5cff)','linear-gradient(135deg,#2bd3c6,#4f8cff)','linear-gradient(135deg,#5ad48a,#bfe65a)','linear-gradient(135deg,#ff6b6b,#ff8a3d)','linear-gradient(135deg,#7c5cff,#ff5c8a)','linear-gradient(135deg,#ffd24b,#ff8a3d)'];
  var DAYS=[
    {e:"📵",t:"Delete the worst one",a:"Delete your single most-used app for the 7 days. Notifications off except calls & texts."},
    {e:"🌅",t:"Phone-free first hour",a:"Don't touch your phone for the first hour after waking. Leave it across the room overnight."},
    {e:"🧘",t:"Boredom on purpose",a:"Sit and do nothing for 10 minutes, no phone. Let your brain feel the quiet — this is the reset working."},
    {e:"🔁",t:"Swap one hit",a:"Every time you reach to scroll, do one thing off your dopamine menu instead. Count how many."},
    {e:"🏃",t:"Move your body",a:"20 minutes of movement — walk, gym, dance, anything. Real dopamine loves effort."},
    {e:"🤝",t:"One real connection",a:"Have one genuine, phone-down conversation. Call someone or meet up."},
    {e:"🧭",t:"Design your normal",a:"Write the 3 rules you're keeping for good. You've felt the difference — lock it in."}
  ];
  var URGES=[{e:"🗣️",k:"Name it",v:"Say out loud: \"This is just a dopamine craving.\" Naming it shrinks it instantly."},
    {e:"🌬️",k:"Breathe x10",v:"Stand up, 10 slow breaths. The urge peaks and fades in under 2 minutes."},
    {e:"💧",k:"Cold water",v:"Drink a full glass of water or splash your face. Resets the impulse."},
    {e:"☀️",k:"60s outside",v:"Step outside for 60 seconds of daylight. Real light beats the screen pull."},
    {e:"⏳",k:"Do nothing",v:"5-minute timer, do literally nothing. Boredom is the reset, not the enemy."},
    {e:"✅",k:"Tiny task",v:"Make your bed, wash a cup. One small real action kills the itch."}];
  var MENU=[{e:"🚶",t:"10-min walk, no phone"},{e:"💪",t:"20 push-ups or stretch"},{e:"💬",t:"Message a friend something real"},
    {e:"📖",t:"Read 5 pages"},{e:"🛠️",t:"Make something with your hands"},{e:"🧹",t:"Tidy one small corner"},
    {e:"🌳",t:"Step outside, look up 1 min"},{e:"✍️",t:"Write one journal line"},{e:"☕",t:"Make a slow coffee/tea"},{e:"⭐",t:"Plan something to look forward to"}];

  function load(){try{return JSON.parse(localStorage.getItem(KEY))||{}}catch(e){return {}}}
  function save(){localStorage.setItem(KEY,JSON.stringify(state))}
  if(!state.done)state.done={};if(typeof state.crave!=='number')state.crave=0;if(!state.journal)state.journal='';
  function dc(){var n=0;for(var i=0;i<7;i++)if(state.done[i])n++;return n}
  function cur(){for(var i=0;i<7;i++)if(!state.done[i])return i;return 6}
  function streak(){var s=0;for(var i=0;i<7;i++){if(state.done[i])s++;else break}return s}
  function pct(){return Math.round(dc()/7*100)}

  function open(i){
    var unlocked=i<=dc();if(!unlocked)return;
    var d=DAYS[i];
    $('#mTop').style.background=GRADS[i];$('#mEmoji').textContent=d.e;
    $('#mTag').textContent='Day '+(i+1);$('#mTitle').textContent=d.t;$('#mBody').textContent=d.a;
    var done=state.done[i];
    $('#mAction').innerHTML='<button class="btn btn--g" id="mDoneBtn">'+(done?'Mark not done':'Mark Day '+(i+1)+' done ✓')+'</button>';
    $('#mDoneBtn').onclick=function(){toggle(i);closeM();};
    $('#drModal').classList.add('on');
  }
  function openTile(o){$('#mTop').style.background='linear-gradient(135deg,var(--violet),var(--pink))';$('#mEmoji').textContent=o.e;$('#mTag').textContent=o.k?'Urge-surf':'Do it now';$('#mTitle').textContent=o.k||o.t;$('#mBody').textContent=o.v||'Go do it now — that’s the whole point.';$('#mAction').innerHTML='';$('#drModal').classList.add('on');}
  function closeM(){$('#drModal').classList.remove('on')}

  function toggle(i){if(!state.done[i]&&i>dc())return;state.done[i]=!state.done[i];if(!state.done[i]){for(var j=i+1;j<7;j++)state.done[j]=false}save();render()}

  function thumb(i,withState){var d=DAYS[i],done=state.done[i],locked=i>dc();
    return '<div class="thumb'+(done?' done':'')+(locked?' locked':'')+'" data-day="'+i+'">'+
      '<div class="thumb__bg" style="background:'+GRADS[i]+'"></div>'+
      '<span class="thumb__emoji">'+d.e+'</span><span class="thumb__tag">DAY '+(i+1)+'</span>'+
      '<div class="thumb__cap"><b>'+d.t+'</b><span>'+(done?'Completed':locked?'Locked':'Tap to open')+'</span></div></div>';}

  function render(){
    $('#pStreak').textContent=streak();$('#pDay').textContent=Math.min(dc()+1,7);$('#pCrave').textContent=state.crave;
    var c=cur();$('#todayBg').style.background=GRADS[c];$('#tLabel').textContent='Day '+(c+1);$('#tTitle').textContent=DAYS[c].t;$('#tAction').textContent=DAYS[c].a;
    var td=$('#tDone');if(state.done[c]){td.textContent='Done for today ✓';td.setAttribute('disabled','')}else{td.removeAttribute('disabled');td.textContent='Mark today done ✓'}
    $('#t1').textContent=dc();$('#t2').textContent=streak();$('#t3').textContent=pct()+'%';
    $('#dayFeed').innerHTML=DAYS.map(function(d,i){return thumb(i)}).join('');
    $('#trackFeed').innerHTML=DAYS.map(function(d,i){return thumb(i)}).join('');
    $('#trackBar').style.width=pct()+'%';
    $('#trackMsg').textContent=streak()>=7?"🏆 Full 7-day reset complete. Huge.":streak()>0?("🔥 "+streak()+"-day streak — keep it alive."):"Tap your first day to start the streak.";
    $('#sA').textContent=dc();$('#sB').textContent=streak();$('#sC').textContent=pct()+'%';$('#sD').textContent=state.crave;$('#sBar').style.width=pct()+'%';$('#craveCount').textContent=state.crave;
  }

  $('#urgeTiles').innerHTML=URGES.map(function(u,i){return '<div class="tile" data-urge="'+i+'"><div class="tile__bg" style="background:'+GRADS[(i+1)%7]+'"></div><div class="tile__in"><span class="e">'+u.e+'</span><b>'+u.k+'</b></div></div>'}).join('');
  $('#menuTiles').innerHTML=MENU.map(function(m,i){return '<div class="tile" data-menu="'+i+'"><div class="tile__bg" style="background:'+GRADS[i%7]+'"></div><div class="tile__in"><span class="e">'+m.e+'</span><b>'+m.t+'</b></div></div>'}).join('');

  document.addEventListener('click',function(e){
    var go=e.target.closest('[data-go]');if(go){var p=go.getAttribute('data-go');$$('.dr__nav').forEach(function(n){n.classList.toggle('on',n.getAttribute('data-go')===p)});$$('.panel').forEach(function(s){s.classList.toggle('on',s.getAttribute('data-p')===p)});cs();window.scrollTo(0,0);return}
    var dd=e.target.closest('[data-day]');if(dd){open(parseInt(dd.getAttribute('data-day'),10));return}
    var du=e.target.closest('[data-urge]');if(du){openTile(URGES[+du.getAttribute('data-urge')]);return}
    var dm=e.target.closest('[data-menu]');if(dm){openTile(MENU[+dm.getAttribute('data-menu')]);return}
  });
  $('#tDone').addEventListener('click',function(){toggle(cur())});
  $('#mClose').addEventListener('click',closeM);$('#drModal').addEventListener('click',function(e){if(e.target===this)closeM()});
  $('#craveBtn').addEventListener('click',function(){state.crave++;save();render();var b=this;b.textContent='Another one beaten 💪';setTimeout(function(){b.textContent='I beat a craving 💪'},1100)});
  $('#rollBtn').addEventListener('click',function(){openTile(MENU[Math.floor(Math.random()*MENU.length)])});
  var j=$('#journal');j.value=state.journal;function js(){state.journal=j.value;save();var s=$('#jSaved');s.classList.add('on');setTimeout(function(){s.classList.remove('on')},1300)}
  $('#jSave').addEventListener('click',js);var jt;j.addEventListener('input',function(){clearTimeout(jt);jt=setTimeout(js,800)});
  function os(){$('#drSide').classList.add('open');$('#drScrim').classList.add('on')}function cs(){$('#drSide').classList.remove('open');$('#drScrim').classList.remove('on')}
  $('#drBurger').addEventListener('click',os);$('#drScrim').addEventListener('click',cs);

  // mood check-in
  if(!state.moods)state.moods={};
  var FACES=['😩','😕','😐','🙂','😄'];
  var moodBtns=$('#moodBtns');
  if(moodBtns){FACES.forEach(function(f,i){var b=document.createElement('button');b.className='moodb';b.textContent=f;b.setAttribute('data-mood',i);moodBtns.appendChild(b)})}
  function renderMood(){
    var log=$('#moodLog');if(!log)return;log.innerHTML='';
    for(var d=0;d<7;d++){var s=document.createElement('span');s.textContent=(state.moods[d]!=null)?FACES[state.moods[d]]:'·';log.appendChild(s)}
    var vals=Object.keys(state.moods).map(function(k){return state.moods[k]});
    var avg=vals.length?vals.reduce(function(a,b){return a+b},0)/vals.length:0;
    $('#moodMsg').textContent=vals.length?('Average mood: '+FACES[Math.round(avg)]+(avg>=3?' — it is working. 🎉':' — keep going, it climbs.')):'Tap a face to log today.';
  }
  document.addEventListener('click',function(e){var dm=e.target.closest('[data-mood]');if(dm){state.moods[cur()]=+dm.getAttribute('data-mood');save();renderMood();$$('.moodb').forEach(function(x){x.classList.toggle('on',x===dm)})}});
  renderMood();
  // breathe phase text
  var brzC=$('#brzC'),brzP=['Breathe in','Hold','Breathe out','Hold'],brzi=0;
  if(brzC){setInterval(function(){brzi=(brzi+1)%4;brzC.textContent=brzP[brzi]},2750)}

  render();
})();
</script>
