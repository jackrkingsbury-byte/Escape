{% raw %}
<style>
  .dr{--bg:#0c0a12;--bg2:#15121d;--bg3:#1b1727;--ink:#f6f4ef;--soft:#b8b4ad;--faint:#7e7a73;
      --line:rgba(255,255,255,.09);--line2:rgba(255,255,255,.05);--amber:#ffc24b;--orange:#ff8a3d;
      --pink:#ff5c8a;--violet:#7c5cff;--blue:#4f8cff;--teal:#2bd3c6;--good:#5ad48a;--r:18px;
      --serif:'Fraunces',Georgia,serif;--sans:'Hanken Grotesk',system-ui,sans-serif;--mono:'JetBrains Mono',monospace;}
  .dr *{box-sizing:border-box}
  .dr{font-family:var(--sans);color:var(--ink);background:var(--bg);min-height:100vh;display:grid;grid-template-columns:264px 1fr}
  .dr a{color:inherit;text-decoration:none}.dr button{font-family:inherit;cursor:pointer;border:0;background:none;color:inherit}

  /* animated 3D backdrop (changes per section) */
  .dr__fx{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}
  .dr__fx .blob{position:absolute;border-radius:50%;filter:blur(60px);opacity:.55;mix-blend-mode:screen;transition:background 1s ease}
  .dr__fx .b1{width:48vmax;height:48vmax;top:-14vmax;right:-8vmax;animation:fxd1 24s ease-in-out infinite}
  .dr__fx .b2{width:42vmax;height:42vmax;bottom:-16vmax;left:-8vmax;animation:fxd2 28s ease-in-out infinite}
  .dr__fx .b3{width:34vmax;height:34vmax;top:34%;left:42%;animation:fxd1 32s ease-in-out infinite}
  @keyframes fxd1{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(5vmax,6vmax) scale(1.14)}}
  @keyframes fxd2{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(-5vmax,-5vmax) scale(1.1)}}
  .dr__fx .cube{position:absolute;top:20%;right:13%;width:116px;height:116px;transform-style:preserve-3d;animation:fxspin 22s linear infinite;opacity:.18}
  .dr__fx .cube i{position:absolute;width:116px;height:116px;border:1.5px solid rgba(255,255,255,.6);box-shadow:inset 0 0 24px rgba(124,92,255,.4)}
  .dr__fx .cube i:nth-child(1){transform:rotateY(0deg) translateZ(58px)}
  .dr__fx .cube i:nth-child(2){transform:rotateY(90deg) translateZ(58px)}
  .dr__fx .cube i:nth-child(3){transform:rotateY(180deg) translateZ(58px)}
  .dr__fx .cube i:nth-child(4){transform:rotateY(-90deg) translateZ(58px)}
  .dr__fx .cube i:nth-child(5){transform:rotateX(90deg) translateZ(58px)}
  .dr__fx .cube i:nth-child(6){transform:rotateX(-90deg) translateZ(58px)}
  .dr__fx .cube--2{top:auto;bottom:14%;left:9%;right:auto;width:80px;height:80px;animation-duration:28s;opacity:.13}
  .dr__fx .cube--2 i{width:80px;height:80px;box-shadow:inset 0 0 18px rgba(255,138,61,.4)}
  .dr__fx .cube--2 i:nth-child(1){transform:rotateY(0) translateZ(40px)}.dr__fx .cube--2 i:nth-child(2){transform:rotateY(90deg) translateZ(40px)}.dr__fx .cube--2 i:nth-child(3){transform:rotateY(180deg) translateZ(40px)}.dr__fx .cube--2 i:nth-child(4){transform:rotateY(-90deg) translateZ(40px)}.dr__fx .cube--2 i:nth-child(5){transform:rotateX(90deg) translateZ(40px)}.dr__fx .cube--2 i:nth-child(6){transform:rotateX(-90deg) translateZ(40px)}
  @keyframes fxspin{to{transform:rotateX(360deg) rotateY(360deg)}}
  .dr__fx .gly span{position:absolute;opacity:.13;animation:fxgf 16s ease-in-out infinite;filter:drop-shadow(0 4px 10px rgba(0,0,0,.45))}
  @keyframes fxgf{0%,100%{transform:translateY(0) rotate(0)}50%{transform:translateY(-28px) rotate(12deg)}}
  @media (prefers-reduced-motion:reduce){.dr__fx .blob,.dr__fx .cube,.dr__fx .gly span{animation:none}}

  .dr__side{grid-column:1;z-index:3;background:linear-gradient(185deg,#26203a,#181226);border-right:1px solid rgba(255,255,255,.12);padding:22px 14px;position:sticky;top:0;height:100vh;display:flex;flex-direction:column;gap:4px;overflow-y:auto}
  .dr__brand{font-family:var(--serif);font-weight:700;font-size:1.3rem;padding:4px 12px 10px}.dr__brand b{color:var(--amber)}
  .dr__lvlcard{margin:0 6px 10px;padding:12px;border-radius:14px;background:linear-gradient(135deg,rgba(255,194,75,.14),rgba(124,92,255,.12));border:1px solid var(--line)}
  .dr__lvlrow{display:flex;align-items:center;gap:10px}
  .dr__lvlbadge{width:40px;height:40px;border-radius:11px;display:grid;place-items:center;font-size:1.3rem;background:linear-gradient(135deg,var(--orange),var(--amber));box-shadow:0 6px 16px rgba(255,138,61,.35);transition:transform .25s}
  .dr__lvlbadge.pop{transform:scale(1.3) rotate(-8deg)}
  .dr__lvlt b{display:block;font-family:var(--serif);font-size:.98rem;line-height:1}.dr__lvlt span{font-size:.72rem;color:var(--faint)}
  .dr__lvlbar{height:7px;border-radius:999px;background:var(--bg3);overflow:hidden;margin-top:9px}
  .dr__lvlbar i{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--amber),var(--pink),var(--violet));transition:width .6s}
  .dr__navttl{font-family:var(--mono);font-size:.58rem;letter-spacing:.24em;text-transform:uppercase;color:#b6b0d8;padding:12px 12px 4px}
  .dr__nav{display:flex;align-items:center;gap:11px;padding:11px 13px;border-radius:12px;color:#f2f0ea;font-weight:650;font-size:.94rem;width:100%;text-align:left;transition:.15s;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.06)}
  .dr__nav .ic{font-size:1.12rem;width:20px;text-align:center;filter:drop-shadow(0 1px 3px rgba(0,0,0,.4))}
  .dr__nav:hover{background:rgba(255,255,255,.12);color:#fff;border-color:rgba(255,255,255,.18);transform:translateX(2px)}
  .dr__nav.on{background:linear-gradient(135deg,rgba(255,194,75,.34),rgba(255,92,138,.28));color:#fff;border-color:rgba(255,194,75,.5);box-shadow:0 6px 18px rgba(255,138,61,.22)}
  .dr__foot{margin-top:auto;padding:12px;border-top:1px solid var(--line2);color:var(--faint);font-size:.74rem}

  .dr__main{grid-column:2;position:relative;z-index:1;padding:clamp(16px,4vw,40px);max-width:1060px}
  .dr__top{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:10px;flex-wrap:wrap}
  .dr__pills{display:flex;gap:8px;flex-wrap:wrap}
  .dr__pill{display:inline-flex;align-items:center;gap:6px;background:var(--bg2);border:1px solid var(--line);border-radius:999px;padding:7px 13px;font-size:.8rem;color:var(--soft)}
  .dr__pill b{color:var(--ink);font-family:var(--mono)}
  .dr h1{font-family:var(--serif);font-size:clamp(1.6rem,4.4vw,2.4rem);font-weight:600;line-height:1.05;margin:4px 0}
  .dr h2{font-family:var(--serif);font-size:1.3rem;margin:0 0 4px}.dr h3{font-size:1.02rem;margin:0 0 6px}
  .dr p{color:var(--soft);line-height:1.55;margin:0 0 12px}
  .dr .eyebrow{font-family:var(--mono);font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--amber);margin-bottom:8px}
  .dr .panel{display:none;animation:fade .35s ease}.dr .panel.on{display:block}
  /* scroll reveal */
  .dr .rv{opacity:0;transform:translateY(24px) scale(.985)}
  .dr .rv.in{opacity:1;transform:none;transition:opacity .6s cubic-bezier(.2,.7,.2,1),transform .6s cubic-bezier(.2,.7,.2,1)}
  /* colour accents */
  .dr .card{box-shadow:inset 3px 0 0 rgba(255,194,75,.55)}
  .dr .panel p b{color:var(--amber)}
  .dr h1{letter-spacing:-.01em}
  @keyframes fade{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
  .dr .hl{background:linear-gradient(135deg,var(--amber),var(--orange));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent}
  .dr .hl2{background:linear-gradient(135deg,var(--pink),var(--violet));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent}

  /* COACH — hero */
  .dr .coach{position:relative;overflow:hidden;border-radius:24px;padding:26px;margin:6px 0 18px;border:1px solid rgba(255,194,75,.3);background:linear-gradient(135deg,#180f2e,#241a3d 55%,#2a1430)}
  .dr .coach__bg{position:absolute;inset:0;z-index:0;background:radial-gradient(55% 90% at 88% 6%,rgba(255,138,61,.4),transparent 60%),radial-gradient(50% 80% at 6% 100%,rgba(124,92,255,.36),transparent 60%)}
  .dr .coach>*{position:relative;z-index:1}
  .dr .coach__row{display:flex;align-items:center;gap:15px;margin-bottom:6px}
  .dr .coach__face{width:64px;height:64px;border-radius:50%;flex:0 0 auto;position:relative;background:radial-gradient(circle at 36% 30%,#fff,#ffd27a 32%,#ff8a3d 72%);box-shadow:0 0 0 5px rgba(255,194,75,.16),0 12px 34px rgba(255,138,61,.45);animation:coachpulse 4s ease-in-out infinite}
  .dr .coach__face .ey{position:absolute;width:7px;height:10px;border-radius:50%;background:#5a2c00;top:42%;animation:blink 5.2s infinite}
  .dr .coach__face .ey.l{left:38%}.dr .coach__face .ey.r{right:38%}
  .dr .coach__face .sm{position:absolute;left:50%;top:58%;width:22px;height:11px;transform:translateX(-50%);border:3px solid #5a2c00;border-top:0;border-radius:0 0 22px 22px}
  @keyframes blink{0%,93%,100%{transform:scaleY(1)}96%{transform:scaleY(.1)}}
  @keyframes coachpulse{0%,100%{transform:scale(1)}50%{transform:scale(1.06)}}
  .dr .coach__hi{font-family:var(--serif);font-size:clamp(1.35rem,3.8vw,2rem);font-weight:600;color:#fff;line-height:1.1}
  .dr .coach__sub{color:#d9d4ea;font-size:.92rem}
  .dr .coach__say{font-size:1.08rem;color:#fff;margin:14px 0 0;line-height:1.5;min-height:1.5em}
  .dr .coach__ask{font-family:var(--mono);font-size:.64rem;letter-spacing:.18em;text-transform:uppercase;color:#ffc24b;margin:16px 0 9px}
  .dr .chips{display:flex;gap:8px;flex-wrap:wrap}
  .dr .chip{display:inline-flex;align-items:center;gap:7px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.16);border-radius:999px;padding:9px 14px;font-size:.86rem;font-weight:600;color:#fff;transition:.15s}
  .dr .chip:hover,.dr .chip.on{background:rgba(255,194,75,.2);border-color:var(--amber)}
  .dr .coach__reply{margin-top:14px;padding:16px;border-radius:16px;background:rgba(0,0,0,.28);border:1px solid rgba(255,255,255,.1);display:none}
  .dr .coach__reply.on{display:block;animation:fade .3s}
  .dr .coach__reply p{color:#fff;margin:0 0 12px}
  .dr .coach__quote{margin-top:16px;padding-top:14px;border-top:1px solid rgba(255,255,255,.12);font-style:italic;color:#e7e2f5;font-size:.96rem}

  .dr .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-weight:800;border-radius:999px;padding:13px 22px;background:#fff;color:#2a1400;transition:transform .15s}
  .dr .btn:active{transform:scale(.96)}
  .dr .btn--g{background:linear-gradient(135deg,var(--amber),var(--orange));color:#2a1400}
  .dr .btn--ghost{background:transparent;border:1px solid rgba(255,255,255,.4);color:#fff}
  .dr .btn--sm{padding:9px 15px;font-size:.84rem}
  .dr .btn[disabled]{opacity:.55;pointer-events:none}

  .dr .secttl{display:flex;align-items:baseline;justify-content:space-between;gap:12px;margin:22px 0 2px}
  .dr .feed{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:14px;margin:14px 0}
  .dr .thumb{position:relative;border-radius:var(--r);overflow:hidden;aspect-ratio:3/4;border:1px solid var(--line);cursor:pointer;transition:transform .18s,box-shadow .18s;display:flex;flex-direction:column;justify-content:flex-end}
  .dr .thumb:hover{transform:translateY(-5px) scale(1.015);box-shadow:0 20px 44px rgba(0,0,0,.5)}
  .dr .thumb__bg{position:absolute;inset:0;z-index:0;background-size:180% 180%;animation:tgrad 8s ease infinite}
  @keyframes tgrad{0%{background-position:0 50%}50%{background-position:100% 50%}100%{background-position:0 50%}}
  .dr .thumb__bg::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.05) 40%,rgba(8,6,12,.72) 100%)}
  .dr .thumb__emoji{position:absolute;top:14px;left:16px;font-size:2.5rem;z-index:1;filter:drop-shadow(0 2px 8px rgba(0,0,0,.45));animation:tfloat 5s ease-in-out infinite}
  @keyframes tfloat{0%,100%{transform:translateY(0) rotate(0)}50%{transform:translateY(-7px) rotate(7deg)}}
  .dr .thumb__tag{position:absolute;top:14px;right:14px;z-index:1;background:rgba(0,0,0,.4);backdrop-filter:blur(4px);border-radius:999px;padding:5px 10px;font-family:var(--mono);font-size:.62rem;letter-spacing:.05em;color:#fff}
  .dr .thumb__cap{position:relative;z-index:1;padding:14px}
  .dr .thumb__cap b{display:block;font-family:var(--serif);font-size:1.04rem;line-height:1.16;color:#fff}
  .dr .thumb__cap span{font-size:.74rem;color:rgba(255,255,255,.82)}
  .dr .thumb.done::after{content:"✓ done";position:absolute;inset:0;z-index:2;display:grid;place-items:center;background:rgba(8,36,15,.5);color:#fff;font-weight:800;font-family:var(--mono);letter-spacing:.1em}
  .dr .thumb.read::after{content:"✓ read";position:absolute;top:13px;right:13px;z-index:2;background:var(--good);color:#06270f;font-weight:800;border-radius:999px;padding:4px 10px;font-size:.66rem;font-family:var(--mono)}
  .dr .thumb.locked{cursor:not-allowed}.dr .thumb.locked::after{content:"🔒";position:absolute;inset:0;z-index:2;display:grid;place-items:center;background:rgba(0,0,0,.55);font-size:1.6rem}

  .dr .card{background:var(--bg2);border:1px solid var(--line);border-radius:var(--r);padding:20px;margin:14px 0}
  .dr .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(128px,1fr));gap:12px;margin:14px 0}
  .dr .stat{background:var(--bg2);border:1px solid var(--line);border-radius:14px;padding:16px}
  .dr .stat .big{font-family:var(--serif);font-size:1.9rem;color:var(--amber);line-height:1}.dr .stat .lbl{color:var(--faint);font-size:.78rem;margin-top:5px}
  .dr .bar{height:10px;border-radius:999px;background:var(--bg3);overflow:hidden;margin:8px 0}.dr .bar i{display:block;height:100%;background:linear-gradient(90deg,var(--amber),var(--pink));width:0;transition:width .6s}

  .dr .dials{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin:14px 0}
  .dr .dial{background:var(--bg2);border:1px solid var(--line);border-radius:18px;padding:18px;text-align:center}
  .dr .ring{--v:0;width:108px;height:108px;border-radius:50%;margin:0 auto 10px;display:grid;place-items:center;
    background:radial-gradient(closest-side,var(--bg2) 70%,transparent 71%),conic-gradient(var(--c,var(--amber)) calc(var(--v)*1%),var(--bg3) 0)}
  .dr .ring b{font-family:var(--serif);font-size:1.5rem;color:#fff}
  .dr .dial .nm{font-weight:700;font-size:.95rem}.dr .dial .ds{color:var(--faint);font-size:.78rem}
  .dr .ring--big{width:150px;height:150px}.dr .ring--big b{font-size:2.1rem}

  .dr .mgraph{display:flex;align-items:flex-end;gap:8px;height:120px;margin:14px 0 6px}
  .dr .mgraph .col{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;height:100%;justify-content:flex-end}
  .dr .mgraph .bar2{width:100%;max-width:30px;border-radius:7px 7px 3px 3px;background:linear-gradient(180deg,var(--amber),var(--pink));min-height:6px;transition:height .5s}
  .dr .mgraph .dl{font-size:.66rem;color:var(--faint);font-family:var(--mono)}

  .dr .achv{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;margin:14px 0}
  .dr .ach{position:relative;border-radius:16px;border:1px solid var(--line);background:var(--bg2);padding:16px;text-align:center;transition:transform .15s}
  .dr .ach .e{font-size:2rem;filter:grayscale(1) opacity(.4)}
  .dr .ach.got{border-color:rgba(255,194,75,.5);background:linear-gradient(160deg,rgba(255,194,75,.12),var(--bg2))}
  .dr .ach.got .e{filter:none}.dr .ach.got:hover{transform:translateY(-3px)}
  .dr .ach b{display:block;font-size:.86rem;color:#fff;margin-top:8px}.dr .ach span{font-size:.72rem;color:var(--faint)}
  .dr .ach.got::after{content:"✓";position:absolute;top:9px;right:11px;width:22px;height:22px;border-radius:50%;background:var(--good);color:#06270f;font-weight:800;display:grid;place-items:center;font-size:.8rem}

  .dr .moods{display:flex;gap:10px;flex-wrap:wrap;margin:14px 0}
  .dr .moodb{font-size:1.8rem;width:60px;height:60px;border-radius:16px;background:var(--bg2);border:1px solid var(--line);transition:.15s;display:grid;place-items:center}
  .dr .moodb:hover,.dr .moodb.on{transform:translateY(-3px);border-color:var(--amber);background:var(--bg3)}

  .dr textarea{width:100%;min-height:130px;background:var(--bg2);border:1px solid var(--line);border-radius:14px;color:var(--ink);padding:15px;font:inherit;resize:vertical}
  .dr .saved{font-size:.8rem;color:var(--good);opacity:0;transition:.3s}.dr .saved.on{opacity:1}
  .dr ul.tick{list-style:none;padding:0;margin:8px 0}.dr ul.tick li{padding:9px 0 9px 26px;position:relative;color:var(--soft);border-top:1px solid var(--line2)}
  .dr ul.tick li:first-child{border:0}.dr ul.tick li::before{content:"✓";position:absolute;left:0;color:var(--good);font-weight:800}

  .dr__modal{position:fixed;inset:0;z-index:80;display:none;align-items:center;justify-content:center;padding:18px;background:rgba(5,4,8,.72);backdrop-filter:blur(6px)}
  .dr__modal.on{display:flex;animation:fade .25s}
  .dr__sheet{background:var(--bg2);border:1px solid var(--line);border-radius:22px;max-width:500px;width:100%;overflow:hidden;max-height:92vh;display:flex;flex-direction:column}
  .dr__sheet .top{position:relative;min-height:150px;display:grid;place-items:center;padding:14px}
  .dr__sheet .top .e{font-size:3.6rem;filter:drop-shadow(0 4px 12px rgba(0,0,0,.4))}
  .dr__sheet .x{position:absolute;top:12px;right:12px;width:34px;height:34px;border-radius:50%;background:rgba(0,0,0,.4);color:#fff;display:grid;place-items:center;font-size:1.1rem;z-index:2}
  .dr__prog{height:4px;background:var(--bg3);display:none}.dr__prog.on{display:block}.dr__prog i{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--amber),var(--pink))}
  .dr__sheet .body{padding:22px;overflow:auto}.dr__sheet .body h2{margin-bottom:8px}
  .dr__sheet .body .art p{font-size:1rem;line-height:1.62;color:#d7d3ca;margin:0 0 14px}
  .dr .msec{margin-top:15px;padding-top:13px;border-top:1px solid var(--line)}
  .dr .msec b{display:block;margin-bottom:6px;color:var(--amber);font-size:.92rem}.dr .msec p{margin:0;font-size:.94rem;color:var(--soft)}
  .dr .mnote{width:100%;min-height:74px;margin-top:10px;background:var(--bg3);border:1px solid var(--line);border-radius:12px;color:var(--ink);padding:11px;font:inherit;resize:vertical}

  .dr .play{min-height:210px;display:grid;place-items:center;text-align:center;background:var(--bg3);border-radius:16px;margin:6px 0 14px;position:relative;overflow:hidden}
  .dr .bubble{width:150px;height:150px;border-radius:50%;display:grid;place-items:center;color:#fff;font-weight:700;background:radial-gradient(circle,rgba(255,194,75,.5),rgba(124,92,255,.2));border:1px solid rgba(255,255,255,.18);transition:transform 4s ease-in-out}
  .dr .rt{font-family:var(--serif);font-size:1.6rem;color:#fff}
  .dr .react{position:absolute;inset:0;display:grid;place-items:center;font-weight:800;font-size:1.2rem;color:#fff}
  .dr .distract{position:absolute;font-size:2.2rem;cursor:pointer;user-select:none}
  .dr .mem{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;width:100%;max-width:300px}
  .dr .memc{aspect-ratio:1;border-radius:12px;background:var(--bg2);border:1px solid var(--line);font-size:1.6rem;display:grid;place-items:center;transition:.15s}
  .dr .memc.up{background:linear-gradient(135deg,var(--violet),var(--pink))}.dr .memc.done{opacity:.4}

  .dr .qcard{position:relative;border-radius:18px;padding:24px;border:1px solid var(--line);background:linear-gradient(135deg,#1a1330,#211a39);margin:14px 0}
  .dr .qcard p{font-family:var(--serif);font-size:1.35rem;color:#fff;line-height:1.35;font-style:italic}
  .dr .qcard .by{color:var(--amber);font-size:.86rem;font-family:var(--mono)}
  .dr .qrow{display:flex;gap:10px;margin-top:14px;flex-wrap:wrap}
  .dr .qmini{display:flex;align-items:center;gap:10px;padding:12px 14px;border:1px solid var(--line);border-radius:12px;background:var(--bg2);margin:8px 0;color:var(--soft);font-size:.95rem}

