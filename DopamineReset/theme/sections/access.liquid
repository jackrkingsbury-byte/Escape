{% raw %}
<style>
  .dr{--bg:#0c0a12;--bg2:#15121d;--bg3:#1b1727;--ink:#f6f4ef;--soft:#b8b4ad;--faint:#7e7a73;
      --line:rgba(255,255,255,.09);--line2:rgba(255,255,255,.05);--amber:#ffc24b;--orange:#ff8a3d;
      --pink:#ff5c8a;--violet:#7c5cff;--blue:#4f8cff;--teal:#2bd3c6;--good:#5ad48a;--r:18px;
      --serif:'Fraunces',Georgia,serif;--sans:'Hanken Grotesk',system-ui,sans-serif;--mono:'JetBrains Mono',monospace;}
  .dr *{box-sizing:border-box}
  .dr{font-family:var(--sans);color:var(--ink);background:var(--bg);min-height:100vh;display:grid;grid-template-columns:264px 1fr}
  .dr a{color:inherit;text-decoration:none}.dr button{font-family:inherit;cursor:pointer;border:0;background:none;color:inherit}

  .dr__side{grid-column:1;background:linear-gradient(180deg,var(--bg2),var(--bg));border-right:1px solid var(--line);padding:22px 14px;position:sticky;top:0;height:100vh;display:flex;flex-direction:column;gap:3px;overflow-y:auto}
  .dr__brand{font-family:var(--serif);font-weight:700;font-size:1.3rem;padding:4px 12px 10px}.dr__brand b{color:var(--amber)}
  .dr__lvlcard{margin:0 6px 10px;padding:12px;border-radius:14px;background:linear-gradient(135deg,rgba(255,194,75,.14),rgba(124,92,255,.12));border:1px solid var(--line)}
  .dr__lvlrow{display:flex;align-items:center;gap:10px}
  .dr__lvlbadge{width:40px;height:40px;border-radius:11px;display:grid;place-items:center;font-size:1.3rem;background:linear-gradient(135deg,var(--orange),var(--amber));box-shadow:0 6px 16px rgba(255,138,61,.35);transition:transform .25s}
  .dr__lvlbadge.pop{transform:scale(1.3) rotate(-8deg)}
  .dr__lvlt b{display:block;font-family:var(--serif);font-size:.98rem;line-height:1}.dr__lvlt span{font-size:.72rem;color:var(--faint)}
  .dr__lvlbar{height:7px;border-radius:999px;background:var(--bg3);overflow:hidden;margin-top:9px}
  .dr__lvlbar i{display:block;height:100%;width:0;background:linear-gradient(90deg,var(--amber),var(--pink),var(--violet));transition:width .6s}
  .dr__navttl{font-family:var(--mono);font-size:.58rem;letter-spacing:.24em;text-transform:uppercase;color:var(--faint);padding:11px 12px 4px}
  .dr__nav{display:flex;align-items:center;gap:11px;padding:10px 13px;border-radius:11px;color:var(--soft);font-weight:600;font-size:.92rem;width:100%;text-align:left;transition:.15s}
  .dr__nav .ic{font-size:1.05rem;width:20px;text-align:center}.dr__nav:hover{background:var(--bg3);color:var(--ink)}
  .dr__nav.on{background:linear-gradient(135deg,rgba(255,194,75,.16),rgba(255,92,138,.12));color:var(--ink)}
  .dr__foot{margin-top:auto;padding:12px;border-top:1px solid var(--line2);color:var(--faint);font-size:.74rem}

  .dr__main{grid-column:2;padding:clamp(16px,4vw,40px);max-width:1040px}
  .dr__top{display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:10px;flex-wrap:wrap}
  .dr__pills{display:flex;gap:8px;flex-wrap:wrap}
  .dr__pill{display:inline-flex;align-items:center;gap:6px;background:var(--bg2);border:1px solid var(--line);border-radius:999px;padding:7px 13px;font-size:.8rem;color:var(--soft)}
  .dr__pill b{color:var(--ink);font-family:var(--mono)}
  .dr h1{font-family:var(--serif);font-size:clamp(1.6rem,4.4vw,2.4rem);font-weight:600;line-height:1.05;margin:4px 0}
  .dr h2{font-family:var(--serif);font-size:1.3rem;margin:0 0 4px}.dr h3{font-size:1.02rem;margin:0 0 6px}
  .dr p{color:var(--soft);line-height:1.55;margin:0 0 12px}
  .dr .eyebrow{font-family:var(--mono);font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--amber);margin-bottom:8px}
  .dr .panel{display:none;animation:fade .35s ease}.dr .panel.on{display:block}
  @keyframes fade{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
  .dr .hl{background:linear-gradient(135deg,var(--amber),var(--orange));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent}
  .dr .hl2{background:linear-gradient(135deg,var(--pink),var(--violet));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent}

  /* coach */
  .dr .coach{position:relative;overflow:hidden;border-radius:22px;padding:24px;margin:6px 0 16px;border:1px solid rgba(255,194,75,.28);background:linear-gradient(135deg,#1a1330,#211a39)}
  .dr .coach__bg{position:absolute;inset:0;z-index:0;background:radial-gradient(60% 90% at 85% 10%,rgba(255,138,61,.34),transparent 60%),radial-gradient(50% 80% at 10% 100%,rgba(124,92,255,.3),transparent 60%)}
  .dr .coach>*{position:relative;z-index:1}
  .dr .coach__row{display:flex;align-items:center;gap:14px;margin-bottom:4px}
  .dr .coach__orb{width:54px;height:54px;border-radius:50%;flex:0 0 auto;background:radial-gradient(circle at 35% 30%,#fff,#ffd27a 30%,#ff8a3d 70%);box-shadow:0 0 0 4px rgba(255,194,75,.18),0 10px 30px rgba(255,138,61,.4);animation:coachpulse 4s ease-in-out infinite}
  @keyframes coachpulse{0%,100%{transform:scale(1)}50%{transform:scale(1.08)}}
  .dr .coach__hi{font-family:var(--serif);font-size:clamp(1.3rem,3.6vw,1.9rem);font-weight:600;color:#fff;line-height:1.1}
  .dr .coach__sub{color:#d9d4ea;font-size:.92rem}
  .dr .coach__say{font-size:1.04rem;color:#fff;margin:12px 0 0;line-height:1.5}
  .dr .coach__quote{margin-top:14px;padding-top:13px;border-top:1px solid rgba(255,255,255,.12);font-style:italic;color:#e7e2f5;font-size:.96rem}
  .dr .coach__cta{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px}

  .dr .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-weight:800;border-radius:999px;padding:13px 22px;background:#fff;color:#2a1400;transition:transform .15s}
  .dr .btn:active{transform:scale(.96)}
  .dr .btn--g{background:linear-gradient(135deg,var(--amber),var(--orange));color:#2a1400}
  .dr .btn--ghost{background:transparent;border:1px solid rgba(255,255,255,.4);color:#fff}
  .dr .btn--sm{padding:9px 15px;font-size:.84rem}
  .dr .btn[disabled]{opacity:.55;pointer-events:none}

  .dr .feed{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:14px;margin:16px 0}
  .dr .thumb{position:relative;border-radius:var(--r);overflow:hidden;aspect-ratio:3/4;border:1px solid var(--line);cursor:pointer;transition:transform .18s,box-shadow .18s;display:flex;flex-direction:column;justify-content:flex-end}
  .dr .thumb:hover{transform:translateY(-4px) scale(1.01);box-shadow:0 18px 40px rgba(0,0,0,.45)}
  .dr .thumb__bg{position:absolute;inset:0;z-index:0}
  .dr .thumb__emoji{position:absolute;top:14px;left:16px;font-size:2.5rem;z-index:1;filter:drop-shadow(0 2px 8px rgba(0,0,0,.4))}
  .dr .thumb__tag{position:absolute;top:14px;right:14px;z-index:1;background:rgba(0,0,0,.35);backdrop-filter:blur(4px);border-radius:999px;padding:5px 10px;font-family:var(--mono);font-size:.64rem;letter-spacing:.06em;color:#fff}
  .dr .thumb__cap{position:relative;z-index:1;padding:14px;background:linear-gradient(180deg,transparent,rgba(0,0,0,.55))}
  .dr .thumb__cap b{display:block;font-family:var(--serif);font-size:1.02rem;line-height:1.15;color:#fff}
  .dr .thumb__cap span{font-size:.74rem;color:rgba(255,255,255,.8)}
  .dr .thumb.done::after{content:"✓ done";position:absolute;inset:0;z-index:2;display:grid;place-items:center;background:rgba(8,36,15,.55);color:#fff;font-weight:800;font-family:var(--mono);letter-spacing:.1em}
  .dr .thumb.locked{cursor:not-allowed}.dr .thumb.locked::after{content:"🔒";position:absolute;inset:0;z-index:2;display:grid;place-items:center;background:rgba(0,0,0,.55);font-size:1.6rem}

  .dr .tiles{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:12px;margin:16px 0}
  .dr .tile{position:relative;border-radius:14px;overflow:hidden;aspect-ratio:1;cursor:pointer;display:grid;place-items:center;text-align:center;padding:12px;border:1px solid var(--line);transition:transform .15s}
  .dr .tile:hover{transform:translateY(-3px)}.dr .tile__bg{position:absolute;inset:0;z-index:0;opacity:.9}
  .dr .tile__in{position:relative;z-index:1}.dr .tile__in .e{font-size:1.85rem;display:block}.dr .tile__in b{font-size:.82rem;color:#fff;display:block;margin-top:6px;text-shadow:0 1px 6px rgba(0,0,0,.5)}

  .dr .card{background:var(--bg2);border:1px solid var(--line);border-radius:var(--r);padding:20px;margin:14px 0}
  .dr .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(128px,1fr));gap:12px;margin:14px 0}
  .dr .stat{background:var(--bg2);border:1px solid var(--line);border-radius:14px;padding:16px}
  .dr .stat .big{font-family:var(--serif);font-size:1.9rem;color:var(--amber);line-height:1}.dr .stat .lbl{color:var(--faint);font-size:.78rem;margin-top:5px}
  .dr .bar{height:10px;border-radius:999px;background:var(--bg3);overflow:hidden;margin:8px 0}.dr .bar i{display:block;height:100%;background:linear-gradient(90deg,var(--amber),var(--pink));width:0;transition:width .6s}

  /* score dials */
  .dr .dials{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin:14px 0}
  .dr .dial{background:var(--bg2);border:1px solid var(--line);border-radius:18px;padding:18px;text-align:center}
  .dr .ring{--v:0;width:108px;height:108px;border-radius:50%;margin:0 auto 10px;display:grid;place-items:center;
    background:radial-gradient(closest-side,var(--bg2) 70%,transparent 71%),conic-gradient(var(--c,var(--amber)) calc(var(--v)*1%),var(--bg3) 0)}
  .dr .ring b{font-family:var(--serif);font-size:1.5rem;color:#fff}
  .dr .dial .nm{font-weight:700;font-size:.95rem}.dr .dial .ds{color:var(--faint);font-size:.78rem}
  .dr .ring--big{width:150px;height:150px}.dr .ring--big b{font-size:2.1rem}

  .dr .mgraph{display:flex;align-items:flex-end;gap:8px;height:120px;margin:14px 0 6px}
  .dr .mgraph .col{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;height:100%;justify-content:flex-end}
  .dr .mgraph .bar2{width:100%;max-width:30px;border-radius:7px 7px 3px 3px;background:linear-gradient(180deg,var(--amber),var(--pink));min-height:6px;transition:height .5s}
  .dr .mgraph .dl{font-size:.66rem;color:var(--faint);font-family:var(--mono)}

  /* achievements */
  .dr .achv{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:12px;margin:14px 0}
  .dr .ach{position:relative;border-radius:16px;border:1px solid var(--line);background:var(--bg2);padding:16px;text-align:center;transition:transform .15s}
  .dr .ach .e{font-size:2rem;filter:grayscale(1) opacity(.4)}
  .dr .ach.got{border-color:rgba(255,194,75,.5);background:linear-gradient(160deg,rgba(255,194,75,.12),var(--bg2))}
  .dr .ach.got .e{filter:none}.dr .ach.got:hover{transform:translateY(-3px)}
  .dr .ach b{display:block;font-size:.86rem;color:#fff;margin-top:8px}.dr .ach span{font-size:.72rem;color:var(--faint)}
  .dr .ach.got::after{content:"✓";position:absolute;top:9px;right:11px;width:22px;height:22px;border-radius:50%;background:var(--good);color:#06270f;font-weight:800;display:grid;place-items:center;font-size:.8rem}

  /* journeys */
  .dr .moodgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:12px;margin:16px 0}
  .dr .moodc{border-radius:16px;border:1px solid var(--line);padding:16px 10px;text-align:center;cursor:pointer;transition:transform .15s;position:relative;overflow:hidden}
  .dr .moodc:hover{transform:translateY(-3px)}.dr .moodc .cbg{position:absolute;inset:0;z-index:0;opacity:.85}
  .dr .moodc>*{position:relative;z-index:1}.dr .moodc .e{font-size:2.1rem}.dr .moodc b{display:block;color:#fff;margin-top:6px;font-size:.92rem;text-shadow:0 1px 6px rgba(0,0,0,.5)}

  .dr .moods{display:flex;gap:10px;flex-wrap:wrap;margin:14px 0}
  .dr .moodb{font-size:1.8rem;width:60px;height:60px;border-radius:16px;background:var(--bg2);border:1px solid var(--line);transition:.15s;display:grid;place-items:center}
  .dr .moodb:hover,.dr .moodb.on{transform:translateY(-3px);border-color:var(--amber);background:var(--bg3)}

  .dr textarea{width:100%;min-height:130px;background:var(--bg2);border:1px solid var(--line);border-radius:14px;color:var(--ink);padding:15px;font:inherit;resize:vertical}
  .dr .saved{font-size:.8rem;color:var(--good);opacity:0;transition:.3s}.dr .saved.on{opacity:1}
  .dr ul.tick{list-style:none;padding:0;margin:8px 0}.dr ul.tick li{padding:9px 0 9px 26px;position:relative;color:var(--soft);border-top:1px solid var(--line2)}
  .dr ul.tick li:first-child{border:0}.dr ul.tick li::before{content:"✓";position:absolute;left:0;color:var(--good);font-weight:800}

  /* modal */
  .dr__modal{position:fixed;inset:0;z-index:80;display:none;align-items:center;justify-content:center;padding:18px;background:rgba(5,4,8,.72);backdrop-filter:blur(6px)}
  .dr__modal.on{display:flex;animation:fade .25s}
  .dr__sheet{background:var(--bg2);border:1px solid var(--line);border-radius:22px;max-width:480px;width:100%;overflow:hidden;max-height:92vh;display:flex;flex-direction:column}
  .dr__sheet .top{position:relative;min-height:150px;display:grid;place-items:center;padding:14px}
  .dr__sheet .top .e{font-size:3.6rem;filter:drop-shadow(0 4px 12px rgba(0,0,0,.4))}
  .dr__sheet .x{position:absolute;top:12px;right:12px;width:34px;height:34px;border-radius:50%;background:rgba(0,0,0,.4);color:#fff;display:grid;place-items:center;font-size:1.1rem;z-index:2}
  .dr__sheet .body{padding:22px;overflow:auto}.dr__sheet .body h2{margin-bottom:8px}
  .dr .msec{margin-top:15px;padding-top:13px;border-top:1px solid var(--line)}
  .dr .msec b{display:block;margin-bottom:6px;color:var(--amber);font-size:.92rem}.dr .msec p{margin:0;font-size:.94rem;color:var(--soft)}
  .dr .mnote{width:100%;min-height:74px;margin-top:10px;background:var(--bg3);border:1px solid var(--line);border-radius:12px;color:var(--ink);padding:11px;font:inherit;resize:vertical}

  /* games */
  .dr .play{min-height:210px;display:grid;place-items:center;text-align:center;background:var(--bg3);border-radius:16px;margin:6px 0 14px;position:relative;overflow:hidden}
  .dr .bubble{width:150px;height:150px;border-radius:50%;display:grid;place-items:center;color:#fff;font-weight:700;
    background:radial-gradient(circle,rgba(255,194,75,.5),rgba(124,92,255,.2));border:1px solid rgba(255,255,255,.18);transition:transform 4s ease-in-out}
  .dr .rt{font-family:var(--serif);font-size:1.6rem;color:#fff}
  .dr .react{position:absolute;inset:0;display:grid;place-items:center;font-weight:800;font-size:1.2rem;color:#fff}
  .dr .distract{position:absolute;font-size:2.2rem;cursor:pointer;user-select:none}

  /* quotes */
  .dr .qcard{position:relative;border-radius:18px;padding:22px;border:1px solid var(--line);background:linear-gradient(135deg,#1a1330,#211a39);margin:14px 0}
  .dr .qcard p{font-family:var(--serif);font-size:1.3rem;color:#fff;line-height:1.35;font-style:italic}
  .dr .qcard .by{color:var(--amber);font-size:.86rem;font-family:var(--mono)}
  .dr .qrow{display:flex;gap:10px;margin-top:14px}
  .dr .qmini{display:flex;align-items:center;gap:10px;padding:12px 14px;border:1px solid var(--line);border-radius:12px;background:var(--bg2);margin:8px 0;color:var(--soft);font-size:.95rem}

  /* toast + confetti */
  .dr__toast{position:fixed;left:50%;bottom:24px;transform:translateX(-50%) translateY(30px);z-index:120;background:linear-gradient(135deg,var(--amber),var(--orange));color:#2a1400;font-weight:800;padding:13px 20px;border-radius:999px;box-shadow:0 16px 40px rgba(255,138,61,.45);opacity:0;transition:.35s;display:flex;align-items:center;gap:9px;max-width:90vw}
  .dr__toast.on{opacity:1;transform:translateX(-50%) translateY(0)}
  .dr__cf{position:fixed;left:0;top:0;width:100%;height:100%;pointer-events:none;z-index:110}
  .dr__cf span{position:absolute;top:-12px;width:9px;height:14px;border-radius:2px;animation:cf linear forwards}
  @keyframes cf{to{transform:translateY(105vh) rotate(560deg);opacity:.2}}

  .dr__menu{display:none}
  .dr__scrim{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:85;display:none}.dr__scrim.on{display:block}
  @media(max-width:820px){
    .dr{grid-template-columns:1fr}
    .dr__main{grid-column:1}
    .dr__side{position:fixed;inset:0 26% 0 0;z-index:90;transform:translateX(-105%);transition:transform .25s}.dr__side.open{transform:none}
    .dr__menu{display:inline-flex;align-items:center;gap:6px;font-weight:700;background:var(--bg2);border:1px solid var(--line);border-radius:999px;padding:8px 14px}
  }
  @media (prefers-reduced-motion:reduce){.dr .coach__orb,.dr .bubble{animation:none}}
</style>

<div class="dr" id="drApp">
  <aside class="dr__side" id="drSide">
    <div class="dr__brand">Dopamine<b>.</b>Reset</div>
    <div class="dr__lvlcard">
      <div class="dr__lvlrow">
        <div class="dr__lvlbadge" id="lvBadge">🌱</div>
        <div class="dr__lvlt"><b id="lvName">Level 1</b><span id="lvTitle">Asleep</span></div>
      </div>
      <div class="dr__lvlbar"><i id="lvBar"></i></div>
    </div>
    <div class="dr__navttl">Your reset</div>
    <button class="dr__nav on" data-go="today"><span class="ic">🤖</span> Coach</button>
    <button class="dr__nav" data-go="plan"><span class="ic">🗓️</span> The 7 Days</button>
    <button class="dr__nav" data-go="track"><span class="ic">✅</span> Tracker</button>
    <button class="dr__nav" data-go="stats"><span class="ic">📊</span> My Stats</button>
    <button class="dr__nav" data-go="achv"><span class="ic">🏆</span> Achievements</button>
    <button class="dr__nav" data-go="vision"><span class="ic">🌟</span> Your Why</button>
    <div class="dr__navttl">Feel good now</div>
    <button class="dr__nav" data-go="games"><span class="ic">🎮</span> Mind Games</button>
    <button class="dr__nav" data-go="journeys"><span class="ic">💗</span> Mood Help</button>
    <button class="dr__nav" data-go="quotes"><span class="ic">📜</span> Quotes</button>
    <button class="dr__nav" data-go="toolkit"><span class="ic">🌊</span> Urge Toolkit</button>
    <button class="dr__nav" data-go="menu"><span class="ic">☀️</span> Dopamine Menu</button>
    <button class="dr__nav" data-go="journal"><span class="ic">📓</span> Journal</button>
    <button class="dr__nav" data-go="help"><span class="ic">💬</span> Help</button>
    <div class="dr__foot">Bookmark this — your home base for 7 days.</div>
  </aside>
  <div class="dr__scrim" id="drScrim"></div>

  <main class="dr__main">
    <div class="dr__top">
      <button class="dr__menu" id="drBurger">☰ Menu</button>
      <div class="dr__pills">
        <span class="dr__pill">⭐ <b id="pXp">0</b> XP</span>
        <span class="dr__pill">🔥 <b id="pStreak">0</b></span>
        <span class="dr__pill">Day <b id="pDay">1</b>/7</span>
      </div>
    </div>

    <section class="panel on" data-p="today">
      <div class="coach">
        <div class="coach__bg"></div>
        <div class="coach__row"><div class="coach__orb"></div>
          <div><div class="coach__hi" id="coHi">Hey there 👋</div><div class="coach__sub" id="coSub">Your coach is warming up…</div></div></div>
        <p class="coach__say" id="coSay">Let's get your first win today.</p>
        <div class="coach__quote" id="coQuote"></div>
        <div class="coach__cta">
          <button class="btn btn--g" data-open-today>Today's challenge →</button>
          <button class="btn btn--ghost btn--sm" data-go="games">I need a reset now</button>
        </div>
      </div>
      <div class="stats">
        <div class="stat"><div class="big" id="t1">0</div><div class="lbl">days done</div></div>
        <div class="stat"><div class="big" id="t2">0</div><div class="lbl">streak</div></div>
        <div class="stat"><div class="big" id="t3">0%</div><div class="lbl">complete</div></div>
        <div class="stat"><div class="big" id="t4">0</div><div class="lbl">cravings beaten</div></div>
      </div>
      <h3 style="margin-top:18px">How do you feel right now?</h3>
      <p>Tap one — your coach adjusts, and you earn XP for checking in.</p>
      <div class="moods" id="moodBtns"></div>
      <div id="moodReply" class="card" style="display:none"></div>
    </section>

    <section class="panel" data-p="plan">
      <h1>The 7 days</h1>
      <p>Tap a card to open it. Days unlock one at a time — the order is the point.</p>
      <div class="feed" id="dayFeed"></div>
    </section>

    <section class="panel" data-p="track">
      <h1>Tracker</h1>
