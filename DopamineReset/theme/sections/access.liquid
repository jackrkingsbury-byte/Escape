        <div class="dial"><div class="ring" id="ringFocus" style="--c:var(--teal)"><b id="rF">0</b></div><div class="nm">Focus</div><div class="ds">grows as you train</div></div>
        <div class="dial"><div class="ring" id="ringEnergy" style="--c:var(--orange)"><b id="rE">0</b></div><div class="nm">Energy</div><div class="ds">from days + mood</div></div>
        <div class="dial"><div class="ring" id="ringSleep" style="--c:var(--violet)"><b id="rS">0</b></div><div class="nm">Sleep</div><div class="ds">build a routine</div></div>
        <div class="dial"><div class="ring" id="ringBrain" style="--c:var(--pink)"><b id="rB">0</b></div><div class="nm">Brain health</div><div class="ds">your overall score</div></div>
      </div>
      <div class="stats">
        <div class="stat"><div class="big" id="sXp">0</div><div class="lbl">total XP</div></div>
        <div class="stat"><div class="big" id="sStreak">0</div><div class="lbl">day streak</div></div>
