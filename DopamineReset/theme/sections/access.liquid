    {e:'📱',l:'Doomscrolling',say:"The scroll isn't the problem — it's the escape hatch from a feeling. Next urge, run one Tap-to-Resist round before you open anything.",cta:{t:'game',id:'resist',label:'Play Tap to Resist'}},
