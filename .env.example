# ── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ────────────────────────────────────────────────────
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Anthropic (AI missions / coach / reviews / roadmaps) ───────
ANTHROPIC_API_KEY=sk-ant-...

# ── Paystack (payments — South Africa) ─────────────────────────
# Dashboard → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY=sk_test_...
# Plan codes from Dashboard → Plans (create a monthly and a yearly ZAR plan)
PAYSTACK_PLAN_MONTHLY=PLN_...
PAYSTACK_PLAN_YEARLY=PLN_...
# Public key (used only if you add inline checkout later — optional)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...

# ── Analytics (optional) ────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Email automation (optional, Resend) ────────────────────────
RESEND_API_KEY=
